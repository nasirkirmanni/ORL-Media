---
import '../../styles/global.css';
import '../../styles/engine.css';
import '../../styles/engine-cards.css';
import Seo from '../../components/Seo.astro';
import { graph, organization, website, faqPage, breadcrumbs } from '../../lib/schema';

/* ─────────────────────────────────────────────────────────────
   THE GROWTH ENGINE — flagship offer page.
   Per the blueprint: expanded module descriptions → month one →
   what's included → cadence → guarantee → FAQ → Book a Call.
   No pricing section; the guarantee sits where pricing would.
   Metrics lives here as a section (#metrics), never a page.
   ───────────────────────────────────────────────────────────── */

const MODULES = [
  {
    slug: 'visibility', num: '01', name: 'Visibility', verb: 'Get discovered.',
    accent: '#2e5cff', dark: '#8fa4ff', accT: '#2244bd', metric: 'Share of Answer', status: 'Live',
    line: 'Buyers ask AI before they search your name. This system puts you inside the answer — 100+ buying questions mapped, engineered, and re-scored monthly against your competitors.',
  },
  {
    slug: 'signals', num: '02', name: 'Signals', verb: 'Find demand.',
    accent: '#c98b32', dark: '#d9a45c', accT: '#724911', metric: 'Qualified meetings', status: 'Limited seats',
    line: 'Roughly 5% of your market is in a buying window right now. This system reads signal convergence — hiring, stack changes, competitor churn — and tells you which 5%, with the evidence attached.',
  },
  {
    slug: 'proof', num: '03', name: 'Proof', verb: 'Win the deal.',
    accent: '#3e8e5a', dark: '#6fbb90', accT: '#235c38', metric: 'No-decision rate', status: '3 seats',
    line: 'Deals die in security review, in committee, in silence. This system maps where yours stall, builds the third-party evidence that unsticks them, and fires it into live deals at the stall moment.',
  },
  {
    slug: 'pricing', num: '04', name: 'Pricing', verb: 'Monetize & expand.',
    accent: '#2b7f86', dark: '#64b4bb', accT: '#1a5a60', metric: 'Net revenue / account', status: 'In build',
    line: 'Expansion costs half of what acquisition does. This system instruments usage, tests packaging against real conversion, and fires expansion plays the week an account is ready.',
  },
];

/* The service mark: nine overlapping arcs swept around a ring, reading as a
   braided rope. One shape recoloured per module — the same device the
   reference uses. Nine at 40° with a 50° sweep gives a 10° overlap, which is
   what makes it read as braided rather than as a dashed circle. */
const RING = Array.from({ length: 9 }, (_, i) => i * 40);

/* Per-module centre emblem, held inside the braided ring — the woven-ring +
   symbol pairing from the reference logos, drawn as clean line glyphs in the
   site's own stroke style rather than the raster illustrations (which don't
   survive at 30–40px). Centred on 24,24 in the 48 viewBox; inherit the
   module accent via currentColor. Filled dots set fill inline. */
const EMBLEM: Record<string, string> = {
  /* eye with two ripple arcs above it — the "vision/waves" reference */
  visibility: '<path d="M14 27c4-5.4 16-5.4 20 0-4 5.4-16 5.4-20 0Z"/><circle cx="24" cy="27" r="2.9"/><path d="M17.5 19.6a9 9 0 0 1 13 0"/><path d="M20 15.8a5 5 0 0 1 8 0"/>',
  /* concentric target rings + centre dot */
  signals: '<circle cx="24" cy="24" r="2.4" fill="currentColor" stroke="none"/><circle cx="24" cy="24" r="6.5"/><circle cx="24" cy="24" r="10.4"/>',
  /* two overlapping rounded squares → an interlaced woven-knot read */
  proof: '<rect x="16.6" y="16.6" width="14.8" height="14.8" rx="4"/><rect x="16.6" y="16.6" width="14.8" height="14.8" rx="4" transform="rotate(45 24 24)"/>',
  /* stacked coins */
  pricing: '<ellipse cx="24" cy="19" rx="8" ry="3"/><path d="M16 19v6.8c0 1.6 3.6 3 8 3s8-1.4 8-3V19"/><path d="M16 22.4c0 1.6 3.6 3 8 3s8-1.4 8-3"/>',
};

/* Real brand-logo images (client-supplied), keyed to transparency and label-
   trimmed into public/logos. Where a module has one, the image replaces the
   drawn ring + emblem entirely — the logos already contain their own woven
   ring. Visibility has no image yet (the supplied file was a page mockup, not
   the eye logo), so it keeps the drawn emblem in brand blue below. */
const LOGO_IMG: Record<string, string> = {
  visibility: '/logos/visibility.png',
  signals: '/logos/signals.png',
  proof: '/logos/proof.png',
  pricing: '/logos/pricing.png',
};
/* every module now has a real logo image; the drawn EMBLEM/RING is kept only
   as the fallback if an image key is ever missing */
const LOGO_COLOR: Record<string, string> = {};

const FAQ = [
  {
    q: 'Can we just buy one module?',
    a: 'Yes. Visibility and Signals run standalone; Proof is design-partner only right now; Pricing is in build. The Engine is for companies that want the whole machine — every module, one senior team, one weekly cadence, with the Metrics layer bundled.',
  },
  {
    q: 'What does it cost?',
    a: 'Scoped on the call — every engagement is a flat retainer matched to the modules and volume you need. Flat fee, never a percentage of ad spend. Ask on the call and you will get numbers immediately; we don’t do the coy-pricing dance.',
  },
  {
    q: 'What if it doesn’t work?',
    a: 'Engine engagements carry the 90-day guarantee: installed and generating qualified pipeline within 90 days, or we work free until it is. We can offer that because we don’t start engagements we don’t believe in — the Audit exists to find that out first, cheaply, for both of us.',
  },
  {
    q: 'Do you do social media or paid ads?',
    a: 'Paid runs inside the Engine when it is the right channel — retargeting real intent, launching into a named segment. We don’t sell channel management as a product. We sell the system that makes channels worth paying for.',
  },
  {
    q: 'You dropped churn/retention — why?',
    a: 'Because we’d rather be excellent at four things than adequate at five. Expansion revenue moved into Pricing, where it belongs. Churn defense is a real problem and we’re not the right people for it yet — ask us and we’ll tell you who is.',
  },
];

/* FAQ schema is generated from the array rendered below — one source
   of truth, so the structured data can never drift from the copy. */
const ld = graph([
  organization(),
  website(),
  faqPage(FAQ),
  breadcrumbs([
    { name: 'Home', path: '/' },
    { name: 'The Growth Engine', path: '/engine/' },
  ]),
]);
import GlassNav from '../../components/GlassNav.astro';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <Seo
    title="The ORL Growth Engine — Four systems. One layer of truth."
    description="ORL installs the Growth Engine: Visibility, Signals, Proof, and Pricing — four revenue systems on one metrics layer, operated by one senior team. Installed and generating pipeline in 90 days, or we work free until it is."
    ogTitle="The ORL Growth Engine"
    ogDescription="Four revenue systems — discovery, demand, deals, monetization — installed on your data and run by one senior team. When we leave, it keeps working."
    image="/og/engine.jpg"
  >
    <script type="application/ld+json" is:inline set:html={ld} />
  </Seo>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@600&display=swap" rel="stylesheet" />
</head>
<body class="blg-body eng-body">

<nav class="sitenav sitenav--page is-visible" aria-label="Site">
  <a class="sitenav__brand" href="/">
    <span class="sitenav__mark" aria-hidden="true"></span>
    ORL
  </a>
  <div class="sitenav__links">
    <a href="/engine" class="sitenav__link" aria-current="page">Engine</a>
    <a href="/audit" class="sitenav__link">Audit</a>
    <a href="/results" class="sitenav__link">Results</a>
    <a href="/about" class="sitenav__link">About</a>
    <a href="/blog" class="sitenav__link">Blog</a>
  </div>
  <a class="sitenav__pill" href="/book">Book a call</a>
</nav>
<GlassNav />

<main class="eng" id="main">

  <!-- ── hero ── -->
  <header class="eng__hero">
    <div class="eng__heroinner">
      <p class="eng__eyebrow mono" data-e-in>The ORL Growth Engine</p>
      <h1 class="eng__title" data-e-in>We don&rsquo;t run<br />your marketing.<br /><em>We install the machine.</em></h1>
      <p class="eng__sub" data-e-in>Four revenue systems — discovery, demand, deals, monetization — built on your data, run by one senior team, reporting into one layer of truth. When we leave, it keeps working. That is the entire difference.</p>

      <!-- The schematic: four systems drain into the layer. Decorative here —
           every module below is a real link with the same content, so this
           preview stays out of the accessibility tree rather than repeating it.
           The hairlines are the point: four verticals meeting one rule is the
           architecture of the offer, drawn rather than described. -->
      <div class="eng__schematic" data-e-in aria-hidden="true">
        {MODULES.map((mo) => (
          <span class="eng__schip" style={`--acc:${mo.accent}; --acc-t:${mo.accT}; --mark:${LOGO_COLOR[mo.slug] ?? mo.accT}`}>
            {LOGO_IMG[mo.slug] ? (
              <img class="eng__logo" src={LOGO_IMG[mo.slug]} width="256" height="256" decoding="async" alt="" aria-hidden="true" />
            ) : (
              <svg class="eng__mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <g class="eng__ring">
                  {RING.map((a) => (
                    <path d="M24 10A14 14 0 0 1 34.7 15" transform={`rotate(${a} 24 24)`} />
                  ))}
                </g>
                <g class="eng__glyph" set:html={EMBLEM[mo.slug]} />
              </svg>
            )}
            <b class="eng__schnum mono">{mo.num}</b>
            <span class="eng__schname">{mo.name}</span>
            <span class="eng__schverb">{mo.verb}</span>
            <i class="eng__sline"><em data-e-schpulse></em></i>
            <span class="eng__schmetric mono">{mo.metric}</span>
          </span>
        ))}
        <span class="eng__sbar"><span class="mono">Metrics layer</span></span>
      </div>
    </div>
  </header>


  <!-- ── the four systems ── -->
  <section class="eng__systems" aria-label="The four systems">
    <div class="eng__inner">
      {/* Split header — statement left, the qualifier right. Keeps the serif
          line short enough to break well while the supporting copy carries
          the detail that used to crowd it. */}
      <div class="eng__shead">
        <div data-e-in>
          <p class="eng__seyebrow mono">The systems</p>
          <h2 class="eng__h2">Four installations.<br />Each accountable<br />to one number.</h2>
        </div>
        <div class="eng__sheadside" data-e-in>
          <p class="eng__sheadlede">Every system is installed on your data and your instances, operated by one senior team, and reporting into a single metrics layer. Run one. Run all four.</p>
          <ul class="eng__sheadmeta">
            {MODULES.map((mo) => (
              <li style={`--acc:${mo.accent}`}><i aria-hidden="true"></i><b class="mono">{mo.name}</b><span class="mono">{mo.metric}</span></li>
            ))}
          </ul>
        </div>
      </div>

      {/* Four full-width system cards. The whole card is the link; the CTA
          pill inside is a span (one target, one tab stop). Each carries a
          native, animated dashboard thumbnail on the right. */}
      <div class="ec-grid">

        {/* ── 01 · VISIBILITY ── */}
        <a class="ec" href="/engine/visibility" style="--ca:#9a7b43" data-e-in data-ec="visibility" aria-label="Visibility — get discovered">
          <span class="ec__radar" aria-hidden="true"><span class="ec__radarspin"></span><i></i></span>
          <i class="ec__status is-live" style="--sd:#c04a30" aria-hidden="true"><b></b>Live</i>
          <span class="ec__left">
            <span class="ec__num mono">01</span>
            <span class="ec__name">Visibility</span>
            <em class="ec__verb">Get discovered.</em>
            <span class="ec__line">Buyers ask AI before they search your name. This system puts you inside the answer — 100+ buying questions mapped, engineered, and re-scored monthly against your competitors.</span>
            <span class="ec__foot">
              <span class="ec__pill">Explore Visibility<svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="ec__metric">Share of Answer</span>
            </span>
          </span>
          <span class="ec__right">
            <span class="ec__dash">
              <span class="ec__dashbody">
                <span class="ecv__prompt">
                  <p><span data-ec-type>What are the best growth partners for B2B SaaS companies?</span><span class="ecv__caret" data-ec-caret></span></p>
                  <span class="ecv__send" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M4 12l16-7-7 16-2.5-6.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg></span>
                </span>
                <span data-ec-reveal>
                  <span class="ecv__ovhead">
                    <svg class="ecv__spark4" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3l1.7 5.3L19 10l-5.3 1.7L12 17l-1.7-5.3L5 10l5.3-1.7z"/></svg>
                    <b>AI Overview</b>
                    <span class="ecv__sources">Sources<i class="ecv__srcdot"></i><i class="ecv__srcdot"></i><i class="ecv__srcdot"></i>+3</span>
                  </span>
                  <p class="ecv__body">Based on expertise, client results, and market presence, here are the top growth partners for B2B SaaS companies:</p>
                  <ul class="ecv__ranks">
                    <li class="ecv__rank ecv__rank--top" data-ec-row>
                      <span class="ecv__rk">1</span>
                      <span class="ecv__logo">ORL<br/>MEDIA</span>
                      <span><span class="ecv__rname">ORL Media</span><br/><span class="ecv__rdesc">AI search visibility, demand generation &amp; growth systems.</span></span>
                      <span class="ecv__rmetric"><span class="ecv__rpct">↑<span data-count="72" data-suffix="%">0%</span></span><br/><span class="ecv__rlabel">Visibility</span></span>
                    </li>
                    <li class="ecv__rank" data-ec-row>
                      <span class="ecv__rk">2</span>
                      <span class="ecv__rname" style="flex:1">Competitor A</span>
                      <span class="ecv__rpct" style="color:var(--ink-3)">↑<span data-count="24" data-suffix="%">0%</span></span>
                    </li>
                    <li class="ecv__rank" data-ec-row>
                      <span class="ecv__rk">3</span>
                      <span class="ecv__rname" style="flex:1">Competitor B</span>
                      <span class="ecv__rpct" style="color:var(--ink-3)">↑<span data-count="11" data-suffix="%">0%</span></span>
                    </li>
                  </ul>
                  <span class="ecv__foot" data-ec-row>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" stroke="currentColor" stroke-width="1.5"/></svg>
                    Answer based on <span data-count="36">0</span> sources
                    <span class="ecv__viewall">View all<svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                  </span>
                </span>
              </span>
            </span>
          </span>
        </a>

        {/* ── 02 · SIGNALS ── */}
        <a class="ec" href="/engine/signals" style="--ca:#9a7b43" data-e-in data-ec="signals" aria-label="Signals — find demand">
          <span class="ec__radar" aria-hidden="true"><span class="ec__radarspin"></span><i></i></span>
          <i class="ec__status" style="--sd:#c9902f" aria-hidden="true"><b></b>Limited seats</i>
          <span class="ec__left">
            <span class="ec__num mono">02</span>
            <span class="ec__name">Signals</span>
            <em class="ec__verb">Find demand.</em>
            <span class="ec__line">Roughly 5% of your market is in a buying window right now. This system reads signal convergence — hiring, stack changes, competitor churn — and tells you which 5%, with the evidence attached.</span>
            <span class="ec__foot">
              <span class="ec__pill">Explore Signals<svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="ec__metric">Qualified meetings</span>
            </span>
          </span>
          <span class="ec__right">
            <span class="ec__dash">
              <span class="ec__dashbar">
                <span class="ec__dashtitle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M4 20v-5M9 20V9M14 20v-8M19 20V5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>Live Signal Feed</span>
                <span class="ec__dashlive"><b></b>Live</span>
              </span>
              <span class="ec__dashbody" style="padding-top:0.4rem">
                <span class="ecs__row" data-ec-row>
                  <span class="ecs__ico"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><rect x="4" y="7" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M9 7V5h6v2" stroke="currentColor" stroke-width="1.6"/></svg></span>
                  <span class="ecs__mid"><span class="ecs__t">Hiring Surge</span><br/><span class="ecs__s">12 new growth roles</span></span>
                  <span class="ec__badge">High Intent</span>
                  <svg class="ec__spark" viewBox="0 0 46 22" preserveAspectRatio="none" aria-hidden="true"><path data-spark d="M1 18 L10 15 L18 16 L27 9 L36 10 L45 3"/></svg>
                </span>
                <span class="ecs__row" data-ec-row>
                  <span class="ecs__ico"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M12 3l8 4-8 4-8-4 8-4zM4 12l8 4 8-4M4 16l8 4 8-4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></span>
                  <span class="ecs__mid"><span class="ecs__t">Tech Stack Change</span><br/><span class="ecs__s">Added Segment + Intercom</span></span>
                  <span class="ec__badge">High Intent</span>
                  <svg class="ec__spark" viewBox="0 0 46 22" preserveAspectRatio="none" aria-hidden="true"><path data-spark d="M1 16 L10 17 L18 11 L27 12 L36 6 L45 4"/></svg>
                </span>
                <span class="ecs__row" data-ec-row>
                  <span class="ecs__ico"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.2" stroke="currentColor" stroke-width="1.6"/><path d="M5 20c0-3.5 3-6 7-6s7 2.5 7 6" stroke="currentColor" stroke-width="1.6"/></svg></span>
                  <span class="ecs__mid"><span class="ecs__t">Competitor Churn</span><br/><span class="ecs__s">3 customers left</span></span>
                  <span class="ec__badge ec__badge--rose">Medium Intent</span>
                  <svg class="ec__spark" viewBox="0 0 46 22" preserveAspectRatio="none" aria-hidden="true"><path data-spark d="M1 8 L10 10 L18 9 L27 13 L36 12 L45 15"/></svg>
                </span>
                <span class="ecs__row" data-ec-row>
                  <span class="ecs__ico"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.6"/><path d="M12 8v8M9.5 10.2c0-1.2 1.1-1.8 2.5-1.8s2.5.7 2.5 1.6-1 1.4-2.5 1.6-2.5.6-2.5 1.6 1.1 1.6 2.5 1.6 2.5-.6 2.5-1.8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
                  <span class="ecs__mid"><span class="ecs__t">Funding Activity</span><br/><span class="ecs__s">Series B raised</span></span>
                  <span class="ec__badge ec__badge--rose">Medium Intent</span>
                  <svg class="ec__spark ec__spark--pos" viewBox="0 0 46 22" preserveAspectRatio="none" aria-hidden="true"><path data-spark d="M1 17 L10 13 L18 14 L27 8 L36 9 L45 2"/></svg>
                </span>
                <span class="ecs__foot" data-ec-row>
                  <span class="ec__cap"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.6"/><path d="M8 12l3 3 5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>Signals scanned today</span>
                  <span class="ecs__count"><span data-count="128">0</span></span>
                </span>
              </span>
            </span>
          </span>
        </a>

        {/* ── 03 · PROOF ── */}
        <a class="ec" href="/engine/proof" style="--ca:#3e7d4f" data-e-in data-ec="proof" aria-label="Proof — win the deal">
          <span class="ec__radar" aria-hidden="true"><span class="ec__radarspin"></span><i></i></span>
          <i class="ec__status" style="--sd:#3e7d4f" aria-hidden="true"><b></b>3 seats</i>
          <span class="ec__left">
            <span class="ec__num mono">03</span>
            <span class="ec__name">Proof</span>
            <em class="ec__verb">Win the deal.</em>
            <span class="ec__line">Deals die in security review, in committee, in silence. This system maps where yours stall, builds the third-party evidence that unsticks them, and fires it into live deals at the stall moment.</span>
            <span class="ec__foot">
              <span class="ec__pill">Explore Proof<svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="ec__metric">No-decision rate</span>
            </span>
          </span>
          <span class="ec__right">
            <span class="ec__dash">
              <span class="ec__dashbar">
                <span class="ec__dashtitle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>Proof Engine</span>
                <span class="ec__dashlive"><b></b>Live</span>
              </span>
              <span class="ec__dashbody">
                <span class="ec__tiles ecp__tiles3">
                  <span class="ec__tile" data-ec-row><span class="ec__tilecap">Stalls Unstuck</span><span class="ec__tileval"><span data-count="27">0</span></span><span class="ec__up">↑<span data-count="38" data-suffix="%">0%</span></span><br/><span class="ec__tilesub">vs last 30 days</span></span>
                  <span class="ec__tile" data-ec-row><span class="ec__tilecap">Evidence Delivered</span><span class="ec__tileval"><span data-count="64">0</span></span><span class="ec__up">↑<span data-count="42" data-suffix="%">0%</span></span><br/><span class="ec__tilesub">vs last 30 days</span></span>
                  <span class="ec__tile" data-ec-row><span class="ec__tilecap">Deals Influenced</span><span class="ec__tileval"><span data-count="18">0</span></span><span class="ec__up">↑<span data-count="29" data-suffix="%">0%</span></span><br/><span class="ec__tilesub">vs last 30 days</span></span>
                </span>
                <span class="ec__section">
