<script>
  import { gsap } from 'gsap';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const main = document.querySelector<HTMLElement>('.eng');

  if (main && !reduce) {
    const ins = [...main.querySelectorAll<HTMLElement>('[data-e-in]')];
    gsap.set(ins, { autoAlpha: 0, y: 16 });
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        io.unobserve(e.target);
        gsap.to(e.target, { autoAlpha: 1, y: 0, duration: 0.6, ease: 'power2.out' });
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -8%' });
    ins.forEach((el) => io.observe(el));

    /* Schematic pulses drain into the layer, staggered per system — the one
       animated moment in the hero, and it earns its place by showing what the
       diagram claims: each system feeding the metrics layer. Travel is read
       from the rendered line height rather than hardcoded, since the line is
       now clamped against viewport height. */
    main.querySelectorAll<HTMLElement>('[data-e-schpulse]').forEach((p, i) => {
      const track = p.parentElement as HTMLElement;
      const run = () => {
        const dist = track.getBoundingClientRect().height;
        gsap.fromTo(p, { y: -3, autoAlpha: 0 }, {
          y: dist, autoAlpha: 1, duration: 1.1, ease: 'power1.in',
          repeat: -1, repeatDelay: 2.2, delay: i * 0.55,
          onRepeat: () => gsap.set(p, { autoAlpha: 0 }),
        });
      };
      run();
      window.addEventListener('resize', () => { gsap.killTweensOf(p); run(); });
    });

    /* month-one line draw */
    main.querySelectorAll<HTMLElement>('[data-e-draw]').forEach((el) => {
      gsap.set(el, { scaleX: 0, transformOrigin: '0% 50%' });
      new IntersectionObserver(([e], o) => {
        if (!e.isIntersecting) return;
        o.disconnect();
        gsap.to(el, { scaleX: 1, duration: 1.6, ease: 'power2.inOut' });
      }, { threshold: 0.1 }).observe(el.parentElement!);
    });

    setTimeout(() => {
      ins.forEach((el) => {
        if (gsap.getProperty(el, 'opacity') === 0) gsap.set(el, { autoAlpha: 1, y: 0 });
      });
    }, 5000);
  }
</script>

<script>
  /* ══════════ engine card dashboards ══════════
     Each of the four cards carries a native, animated dashboard. On first
     viewport entry a per-card timeline runs ONCE: (visibility) the prompt
     types, then the AI overview reveals; rows rise in sequence, sparklines
     draw left→right, badges fade after their row, and every [data-count]
     number counts from 0 to its value.

     No new dependency — gsap (already imported) drives it all. Resting CSS is
     the finished card, so reduced-motion and a JS failure both show the final
     state with real numbers. */
  import { gsap } from 'gsap';

  const ecReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const cards = [...document.querySelectorAll<HTMLElement>('[data-ec]')];

  /* ── reusable CountUp: ints, decimals, %, $, commas ── */
  function fmt(el: HTMLElement, v: number) {
    const dec = Number(el.dataset.decimals || 0);
    let s = dec ? v.toFixed(dec) : String(Math.round(v));
    if ('commas' in el.dataset) s = Number(s).toLocaleString('en-US');
    return (el.dataset.prefix || '') + s + (el.dataset.suffix || '');
  }
  function setFinal(el: HTMLElement) { el.textContent = fmt(el, Number(el.dataset.count || 0)); }
  function countUp(el: HTMLElement, tl: gsap.core.Timeline, at: number) {
    const o = { v: 0 };
    tl.to(o, {
      v: Number(el.dataset.count || 0), duration: 1.1, ease: 'power2.out',
      onUpdate: () => { el.textContent = fmt(el, o.v); },
    }, at);
  }

  if (cards.length && !ecReduce) {
    cards.forEach((card) => {
      const typeEl = card.querySelector<HTMLElement>('[data-ec-type]');
      const caret = card.querySelector<HTMLElement>('[data-ec-caret]');
      const reveal = card.querySelector<HTMLElement>('[data-ec-reveal]');
      const rows = [...card.querySelectorAll<HTMLElement>('[data-ec-row]')];
      const badges = [...card.querySelectorAll<HTMLElement>('[data-ec-badge]')];
      const sparks = [...card.querySelectorAll<SVGPathElement>('[data-spark]')];
      const counts = [...card.querySelectorAll<HTMLElement>('[data-count]')];

      /* hidden state — applied by JS, so no-JS keeps the finished card */
      gsap.set(rows, { autoAlpha: 0, y: 10 });
      gsap.set(badges, { autoAlpha: 0 });
      if (reveal) gsap.set(reveal, { autoAlpha: 0 });
      let fullText = '';
      if (typeEl) { fullText = typeEl.textContent || ''; typeEl.textContent = ''; }
      sparks.forEach((p) => {
        const len = p.getTotalLength();
        gsap.set(p, { strokeDasharray: len, strokeDashoffset: len });
      });

      /* force the finished state, unconditionally and idempotently — plain DOM
         writes plus gsap.set (which applies synchronously, no ticker needed),
         so it works even if the animation's rAF ticker never advanced */
      function forceFinal() {
        gsap.set(rows, { autoAlpha: 1, y: 0 });
        gsap.set(badges, { autoAlpha: 1 });
        if (reveal) gsap.set(reveal, { autoAlpha: 1 });
        sparks.forEach((p) => gsap.set(p, { strokeDashoffset: 0 }));
        if (typeEl) typeEl.textContent = fullText;
        if (caret) gsap.set(caret, { autoAlpha: 0 });
        counts.forEach(setFinal);
      }

      let played = false;
      function play() {
        if (played) return;
        played = true;
        /* self-heal: whatever the animation's fate, this card is guaranteed
           finished 6s after it starts. Fires off the timer (not rAF), so a
           stalled or interrupted timeline can never leave it half-built. */
        setTimeout(forceFinal, 6000);
        const tl = gsap.timeline({ delay: 0.15 });
        let t = 0;

        /* 1 — typewriter (visibility) */
        if (typeEl && fullText) {
          const chars = fullText.length;
          const dur = Math.min(1.1, chars * 0.016);
          tl.to({ i: 0 }, {
            i: chars, duration: dur, ease: 'none',
            onUpdate() { typeEl.textContent = fullText.slice(0, Math.round(this.targets()[0].i)); },
          }, 0);
          t = dur + 0.1;
          if (caret) tl.to(caret, { autoAlpha: 0, duration: 0.2 }, t);
          if (reveal) tl.to(reveal, { autoAlpha: 1, duration: 0.35 }, t);
          t += 0.25;
        } else if (reveal) {
          tl.to(reveal, { autoAlpha: 1, duration: 0.35 }, 0);
        }

        /* 2 — rows rise in sequence, sparks draw with them */
        rows.forEach((row, i) => {
          const at = t + i * 0.09;
          tl.to(row, { autoAlpha: 1, y: 0, duration: 0.42, ease: 'power2.out' }, at);
          const spark = row.querySelector<SVGPathElement>('[data-spark]');
          if (spark) tl.to(spark, { strokeDashoffset: 0, duration: 0.7, ease: 'power2.out' }, at + 0.1);
          const badge = row.querySelector<HTMLElement>('[data-ec-badge]');
          if (badge) tl.to(badge, { autoAlpha: 1, duration: 0.3 }, at + 0.28);
        });

        /* any sparks not inside a row (none currently) draw at the end */
        sparks.filter((s) => !s.closest('[data-ec-row]')).forEach((s, i) =>
          tl.to(s, { strokeDashoffset: 0, duration: 0.7, ease: 'power2.out' }, t + i * 0.1));

        /* badges not tied to a row */
        badges.filter((b) => !b.closest('[data-ec-row]')).forEach((b, i) =>
          tl.to(b, { autoAlpha: 1, duration: 0.3 }, t + 0.4 + i * 0.1));

        /* 3 — numbers count up, once the content is arriving */
        counts.forEach((c) => countUp(c, tl, t + 0.15));
      }

      /* Trigger the moment the card enters the viewport. IntersectionObserver
         is the primary path; a scroll/resize check is the fallback for
         environments where IO is flaky or never composites. We deliberately do
         NOT force the finished state on a timer — the systems section sits well
         down the page, so a visitor who takes >9s to reach it must still see
         the animation run rather than arrive to find every number already
         static. A card below the fold simply waits at its resting (hidden)
         state until it is actually scrolled into view. */
      function tryPlay() {
        if (played) return true;
        const r = card.getBoundingClientRect();
        const vh = window.innerHeight || document.documentElement.clientHeight;
        if (r.top < vh * 0.94 && r.bottom > vh * 0.06) { play(); return true; }
        return false;
      }

      const io = new IntersectionObserver(([e], o) => {
        if (!e.isIntersecting) return;
        o.disconnect();
        play();
      }, { threshold: 0.3, rootMargin: '0px 0px -6%' });
      io.observe(card);

      const onScrollEc = () => {
        if (tryPlay()) {
          window.removeEventListener('scroll', onScrollEc);
          window.removeEventListener('resize', onScrollEc);
        }
      };
      window.addEventListener('scroll', onScrollEc, { passive: true });
      window.addEventListener('resize', onScrollEc, { passive: true });
      tryPlay(); /* in case the card is already in view on load */
    });
  } else {
    /* reduced motion: format the numbers to their final values (markup ships
       them at 0) and leave everything else at its resting, visible state */
    cards.forEach((card) =>
      card.querySelectorAll<HTMLElement>('[data-count]').forEach(setFinal));
  }
</script>
</body>
</html>
