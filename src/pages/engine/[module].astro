---
import '../../styles/global.css';
import '../../styles/engine.css';
import Seo from '../../components/Seo.astro';
import { graph, organization, website, service, faqPage, breadcrumbs } from '../../lib/schema';
import { MODULES, ORDER } from '../../lib/modules';

/* ─────────────────────────────────────────────────────────────
   MODULE PAGES — one template, three systems.
   Design intent: the visitor steps INTO the panel they watched on
   the homepage. Dark hero in the module's accent, the one metric
   it is accountable to, the problem it exists for, the pipeline
   it runs, what gets installed, and what the client keeps.
   Systems language throughout: install, run, own — never "offer".

   Visibility is NOT generated here: it has a bespoke page at
   engine/visibility.astro. It stays in ORDER (and in MODULES)
   because the system strip and the wrap-around "next system"
   link still have to name it.

   The filter is load-bearing, not cosmetic. Astro's route-collision
   check only fires when BOTH routes are fully static, so a dynamic
   route shadowed by a static one never errors — the static page
   silently wins and this route's copy is dropped with a build
   warning on every run. experimental.failOnPrerenderConflict
   exists to promote that to a hard error later.
   ───────────────────────────────────────────────────────────── */

export async function getStaticPaths() {
  return ORDER.filter((m) => m !== 'visibility').map((module) => ({ params: { module } }));
}

const { module: slug } = Astro.params;
const m = MODULES[slug!];
/* ORDER still holds all four — pricing's "next system" wraps to visibility,
   whose page lives elsewhere. */
const idx = ORDER.indexOf(slug! as (typeof ORDER)[number]);
const nextSlug = ORDER[(idx + 1) % ORDER.length];
const next = MODULES[nextSlug];
const metricRest = `${m.metric.to}${m.metric.fmt}`;

const modPath = `/engine/${slug}/`;
const ld = graph([
  organization(),
  website(),
  service({ name: m.name, description: m.sub, path: modPath }),
  faqPage(m.faq),
  breadcrumbs([
    { name: 'Home', path: '/' },
    { name: 'The Growth Engine', path: '/engine/' },
    { name: m.name, path: modPath },
  ]),
]);
import GlassNav from '../../components/GlassNav.astro';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <Seo
    title={m.seoTitle}
    description={m.seoDescription}
    ogTitle={`ORL ${m.name} — ${m.pos}`}
    image={`/og/${slug}.jpg`}
  >
    <script type="application/ld+json" is:inline set:html={ld} />
  </Seo>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="blg-body eng-body">

<a class="skip-link" href="#main">Skip to content</a>

<nav class="sitenav sitenav--page is-visible" aria-label="Site">
  <a class="sitenav__brand" href="/">
    <span class="sitenav__mark" aria-hidden="true"></span>
    ORL
  </a>
  <div class="sitenav__links">
    <a href="/engine" class="sitenav__link" aria-current="true">Engine</a>
    <a href="/audit" class="sitenav__link">Audit</a>
    <a href="/results" class="sitenav__link">Results</a>
    <a href="/about" class="sitenav__link">About</a>
    <a href="/blog" class="sitenav__link">Blog</a>
  </div>
  <a class="sitenav__pill" href="/book">Book a call</a>
</nav>
<GlassNav />

<main class="mod" id="main" style={`--acc:${m.accent}; --acc-d:${m.accentDark}; --acc-t:${m.accentText};`}>

  <!-- ── hero: inside the system ── -->
  <header class="mod__hero">
    <span class="mod__watermark" aria-hidden="true">{m.num}</span>
    <div class="mod__heroinner">
      <p class="mod__crumb mono" data-e-in>
        <a href="/engine">The Growth Engine</a>
        <span aria-hidden="true">/</span>
        System {m.num}
        <i class={`mod__status mod__status--${m.status.tone}`}><b aria-hidden="true"></b>{m.status.label}</i>
      </p>
      <h1 class="mod__title" data-e-in>{m.name}<em>.</em></h1>
      <p class="mod__pos" data-e-in>{m.pos}</p>
      <p class="mod__sub" data-e-in>{m.sub}</p>

      <div class="mod__metric" data-e-in>
        <p class="mod__metriclabel mono">Accountable to one number</p>
        <p class="mod__metricrow">
          <strong data-e-count={m.metric.to} data-e-from={m.metric.from} data-e-suffix={m.metric.fmt}>{metricRest}</strong>
          <span>{m.metric.label}</span>
        </p>
      </div>
    </div>
    <i class="mod__heroline" aria-hidden="true"><em data-e-pulse></em></i>
  </header>

  <!-- ── the problem this system exists for ── -->
  <section class="mod__problem" aria-label="The problem">
    <div class="mod__inner mod__problemgrid">
      <div class="mod__probleft" data-e-in>
        <p class="mod__eyebrow mono">Why this system exists</p>
        <h2 class="mod__h2">{m.problem.headline}</h2>
        {/* Standalone answer passage — sits directly under the top H2 so
            an answer engine extracting this section gets a complete,
            self-contained definition of the system. */}
        <p class="mod__answer" data-e-in>{m.answer}</p>
        <p class="mod__bigstat"><strong data-e-in>{m.problem.stat}</strong></p>
        <p class="mod__bigstatline mono">{m.problem.statLine}</p>
      </div>
      <div class="mod__probright">
        <p class="mod__body" data-e-in>{m.problem.body}</p>
        <ul class="mod__support">
          {m.problem.support.map((s) => (
            <li data-e-in><strong class="mono">{s.n}</strong><span>{s.l}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── the pipeline ── -->
  <section class="mod__pipe" aria-label="How the system runs">
    <div class="mod__inner">
      <p class="mod__eyebrow mono" data-e-in>How the system runs</p>
      <h2 class="mod__h2" data-e-in>Not a campaign. A loop.</h2>
      <div class="mod__steps">
        <i class="mod__pipeline" aria-hidden="true"><em data-e-draw></em></i>
        {m.steps.map((s, i) => (
          <article class="mod__step" data-e-in>
            <span class="mod__stepnum mono"><i aria-hidden="true"></i>{String(i + 1).padStart(2, '0')}</span>
            <h3 class="mod__stepname">{s.t}</h3>
            <p class="mod__stepdesc">{s.d}</p>
          </article>
        ))}
        <p class="mod__loopnote mono" data-e-in>&#8635; Step four feeds step one. The system compounds; a campaign would end here.</p>
      </div>
    </div>
  </section>

  <!-- ── installed, not rented ── -->
  <section class="mod__keeps" aria-label="What you own">
    <div class="mod__inner mod__keepsgrid">
      <div data-e-in>
        <p class="mod__eyebrow mod__eyebrow--dark mono">Installed, not rented</p>
        <h2 class="mod__h2 mod__h2--dark">Fire us. Keep the system.</h2>
        <p class="mod__body mod__body--dark">The difference between a service and an installation is what exists the day after the engagement ends. Here is what stays:</p>
      </div>
      <ul class="mod__keeplist">
        {m.keeps.map((k) => (
          <li data-e-in>
            <span class="mod__check" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12.5 4.5 4.5L19 7"/></svg></span>
            {k}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── what gets installed ── -->
  <section class="mod__deliver" aria-label="What gets installed">
    <div class="mod__inner">
      <p class="mod__eyebrow mono" data-e-in>What gets installed</p>
      <h2 class="mod__h2" data-e-in>The build sheet.</h2>
      <ul class="mod__delivergrid">
        {m.deliver.map((d) => (
          <li data-e-in><i aria-hidden="true"></i>{d}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── the metric, stated plainly ── -->
  <section class="mod__metricpanel" aria-label="The metric">
    <div class="mod__inner" data-e-in>
      <p class="mod__eyebrow mod__eyebrow--acc mono">The only report that matters</p>
      <p class="mod__metricbig">
        <strong data-e-count={m.metric.to} data-e-from={m.metric.from} data-e-suffix={m.metric.fmt}>{metricRest}</strong>
        <span>{m.metric.label}</span>
      </p>
      <p class="mod__metricdef">{m.metric.def}</p>
    </div>
  </section>

  <!-- ── position in the engine ── -->
  <nav class="mod__strip" aria-label="The Growth Engine systems">
    <div class="mod__inner">
      <p class="mod__eyebrow mono">Part of the Growth Engine</p>
      <ol class="mod__stripline">
        {ORDER.map((s) => (
          <li class={s === slug ? 'is-here' : ''}>
            <a href={`/engine/${s}`}><b class="mono">{MODULES[s].num}</b>{MODULES[s].name}</a>
          </li>
        ))}
        <li class="mod__striplayer"><a href="/engine#metrics"><b class="mono">&mdash;</b>Metrics layer</a></li>
      </ol>
    </div>
  </nav>

  <!-- ── faq ──
       Rendered from m.faq, the same array faqPage() serializes into
       JSON-LD, so the marked-up Q&A always matches what is on screen. -->
  <section class="mod__faq" aria-label="Frequently asked questions">
    <div class="mod__inner">
      <p class="mod__eyebrow mono" data-e-in>Before you ask</p>
      <h2 class="mod__h2" data-e-in>{m.name} questions.</h2>
      <div class="mod__faqlist" data-e-in>
        {m.faq.map((f) => (
          <details class="mod__faqitem">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── cta ── -->
  <section class="mod__cta" aria-label="Next step">
    <div class="mod__inner" data-e-in>
      <h2 class="mod__ctah">{m.cta.h}</h2>
      <p class="mod__ctas">{m.cta.s}</p>
      <a class="mod__ctabtn" href="/book">{m.cta.btn}
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <p class="mod__ctanote mono">{m.cta.note}</p>
    </div>
  </section>

  <footer class="mod__foot">
    <a class="mod__next" href={`/engine/${nextSlug}`}>
      <span class="mono">Next system</span>
      <strong>{next.num} &mdash; {next.name}</strong>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <p class="mono">&copy; 2026 ORL Media &mdash; Growth infrastructure for B2B</p>
  </footer>
</main>

<script>
  import { gsap } from 'gsap';

  /* Shared engine-page motion: reveals, counters, line draws, hero pulse.
     Resting CSS is the finished page; a failed script degrades to static. */
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const main = document.querySelector<HTMLElement>('.mod, .eng');

  if (main && !reduce) {
    const ins = [...main.querySelectorAll<HTMLElement>('[data-e-in]')];
    gsap.set(ins, { autoAlpha: 0, y: 16 });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        io.unobserve(e.target);
        gsap.to(e.target, { autoAlpha: 1, y: 0, duration: 0.6, ease: 'power2.out' });
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -8%' });
    ins.forEach((el) => io.observe(el));

    /* counters */
    main.querySelectorAll<HTMLElement>('[data-e-count]').forEach((el) => {
      const to = parseFloat(el.dataset.eCount || '0');
      const from = parseFloat(el.dataset.eFrom || '0');
      const suf = el.dataset.eSuffix || '';
      new IntersectionObserver(([e], o) => {
        if (!e.isIntersecting) return;
        o.disconnect();
        const p = { v: from };
        gsap.to(p, {
          v: to, duration: 1.4, ease: 'power2.out',
          onUpdate: () => { el.textContent = `${Math.round(p.v)}${suf}`; },
        });
      }, { threshold: 0.5 }).observe(el);
    });

    /* pipeline draw */
    main.querySelectorAll<HTMLElement>('[data-e-draw]').forEach((el) => {
      gsap.set(el, { scaleY: 0, transformOrigin: '50% 0%' });
      new IntersectionObserver(([e], o) => {
        if (!e.isIntersecting) return;
        o.disconnect();
        gsap.to(el, { scaleY: 1, duration: 1.6, ease: 'power2.inOut' });
      }, { threshold: 0.1 }).observe(el.parentElement!);
    });

    /* hero pulse travels the accent line, forever, cheaply */
    const pulse = main.querySelector<HTMLElement>('[data-e-pulse]');
    if (pulse) {
      gsap.fromTo(pulse, { xPercent: -110 }, {
        xPercent: 1100, duration: 4.6, ease: 'power1.inOut', repeat: -1, repeatDelay: 1.4,
      });
    }

    /* failsafe: nothing on this page may stay invisible */
    setTimeout(() => {
      ins.forEach((el) => {
        if (gsap.getProperty(el, 'opacity') === 0) gsap.set(el, { autoAlpha: 1, y: 0 });
      });
    }, 5000);
  }
</script>
</body>
</html>
