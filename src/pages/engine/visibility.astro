<script>
  import { gsap } from 'gsap';

  /* ══════════ shared engine-page motion ══════════
     Reveals, counters, line draws — identical to [module].astro.
     Resting CSS is the finished page; a failed script degrades to static. */
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const main = document.querySelector<HTMLElement>('.vis');

  if (main && !reduce) {
    const ins = [...main.querySelectorAll<HTMLElement>('[data-e-in]')];
    gsap.set(ins, { autoAlpha: 0, y: 16 });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        io.unobserve(e.target);
        gsap.to(e.target, { autoAlpha: 1, y: 0, duration: 0.6, ease: 'power2.out' });
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -8%' });
    ins.forEach((el) => io.observe(el));

    main.querySelectorAll<HTMLElement>('[data-e-count]').forEach((el) => {
      const to = parseFloat(el.dataset.eCount || '0');
      const from = parseFloat(el.dataset.eFrom || '0');
      const suf = el.dataset.eSuffix || '';
      new IntersectionObserver(([e], o) => {
        if (!e.isIntersecting) return;
        o.disconnect();
        const p = { v: from };
        gsap.to(p, {
          v: to, duration: 1.4, ease: 'power2.out',
          onUpdate: () => { el.textContent = `${Math.round(p.v)}${suf}`; },
        });
      }, { threshold: 0.5 }).observe(el);
    });

    main.querySelectorAll<HTMLElement>('[data-e-draw]').forEach((el) => {
      gsap.set(el, { scaleY: 0, transformOrigin: '50% 0%' });
      new IntersectionObserver(([e], o) => {
        if (!e.isIntersecting) return;
        o.disconnect();
        gsap.to(el, { scaleY: 1, duration: 1.6, ease: 'power2.inOut' });
      }, { threshold: 0.1 }).observe(el.parentElement!);
    });

    /* failsafe: nothing on this page may stay invisible */
    setTimeout(() => {
      ins.forEach((el) => {
        if (gsap.getProperty(el, 'opacity') === 0) gsap.set(el, { autoAlpha: 1, y: 0 });
      });
    }, 5000);
  }
</script>

<script>
  /* ══════════ the video hero ══════════
     Architecture mirrors bennettandclive.com, whose source I read rather than
     guessed at:

       • Pin is CSS `position: sticky` on .vh__sticky, gated by html.vhpin-on.
         Not ScrollTrigger's pin — that injects a spacer and switches to fixed,
         which fights the `html { overflow-x: hidden }` in global.css.
       • Scroll budget is a zero-width column of spacers, one per clip, so the
         pacing is CSS (--vh-step) and never hard-coded here.
       • Each clip owns its own trigger: start 'top center', end 'bottom
         center', scrubbed, ease 'none'.
       • The wipe is the equal-and-opposite pair — mask yPercent 100 → 0 while
         the figure inside goes -100 → 0. Because they cancel, the footage
         holds still and the mask sweeps off it.
       • Clip 01 never animates. It is the permanent base layer underneath.
       • Every clip plays continuously. Pausing the inactive ones saved a
         decode but left the incoming clip frozen on a still frame for the
         first half of its own wipe, which is what made the transitions snag.

     ScrollTrigger is dynamically imported so reduced-motion users never
     download it. */
  import { gsap } from 'gsap';

  const vh = document.querySelector<HTMLElement>('[data-vh]');

  if (vh) {
    const root = document.documentElement;
    const assets = [...vh.querySelectorAll<HTMLElement>('[data-vh-asset]')];
    const figs = assets.map((a) => a.querySelector<HTMLElement>('[data-vh-fig]')!);
    const videos = assets.map((a) => a.querySelector<HTMLVideoElement>('video')!);
    const triggers = [...vh.querySelectorAll<HTMLElement>('[data-vh-trigger]')];

    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    /* Touch devices take the same static-frame path as reduced-motion: a
       scroll-jacked, pinned WebGL-shader wipe is the heaviest, most fragile
       interaction on the site for a phone. That fallback is already designed. */
    const mqTouch = window.matchMedia('(hover: none) and (pointer: coarse)');
    /* ≤767px: the video hero is hidden entirely (a text hero replaces it in the
       markup), so the clips must never load and the pin must never build. */
    const mqMobile = window.matchMedia('(max-width: 767px)');

    let ST: any = null;
    let made: any[] = [];
    let enabling = false;
    let active = -1;

    /* One decode at a time. play() rejects if the tab is backgrounded or the
       file is missing — neither is an error worth surfacing. */
    function attemptPlay(v: HTMLVideoElement) {
      const p = v.play();
      /* A refusal is expected and recoverable — a tab opened in the
         background, iOS low-power mode, a strict autoplay setting. Swallow it
         here and let the visibilitychange handler below re-assert. */
      if (p) p.catch(() => {});
    }

    /* ── auto-advance ──
       Four seconds after a clip becomes active, glide to the next one. The
       hero plays itself for a visitor who does nothing, and stays fully
       scrubbable for one who doesn't.

       Rules it will not break:
       • Any real input — wheel, touch, key, pointer — hands control back
         permanently. Nothing is worse than a page that fights your scroll,
         and re-arming after the visitor has taken over would do exactly that.
         Note these are input events, NOT 'scroll': the glide below moves the
         scroll position itself and would otherwise cancel itself instantly.
       • Never advances from the last clip — the statement is the payoff and
         yanking it away mid-read would be the one unforgivable move.
       • Never scrolls backwards. If the visitor is already past the target,
         it stands down.
       • Nothing runs while the tab is hidden. */
    /* per-clip, read off the same data the markup is built from — clip 01 is
       shorter so the opening beat does not outstay its 6.75s loop */
    /* ── the shader clip ──
       Clip 03 is a live WebGL fragment shader rather than footage. Three
       rules, because a full-viewport shader left running is one of the
       cheapest ways to flatten a laptop battery:
         • the module is dynamically imported, so anyone who never reaches
           clip 03 never downloads it and no GL context is ever created
         • it only animates while it is the active clip AND the tab is visible
         • under prefers-reduced-motion it renders exactly one frame and stops,
           so the panel is a still image rather than either black or moving */
    const shaderHost = vh.querySelector<HTMLElement>('[data-vh-shader]');
    const shaderIndex = assets.findIndex((a) => a.querySelector('[data-vh-shader]'));
    let shader: import('../../lib/shader-animation').ShaderHandle | null = null;
    let shaderRequested = false;

    function syncShader() {
      if (!shader) return;
      const run =
        active === shaderIndex && !mqReduce.matches && document.visibilityState === 'visible';
      if (run) shader.start();
      else {
        shader.stop();
        /* on screen but not animating — leave a frame up, not a black hole.
           Under reduced motion the hero is an ordinary stack and every panel
           is on screen, so that panel gets its still frame too. */
        if (active === shaderIndex || mqReduce.matches) shader.renderOnce();
      }
    }

    async function ensureShader() {
      if (shaderRequested || !shaderHost) return;
      shaderRequested = true;
      try {
        const mod = await import('../../lib/shader-animation');
        shader = mod.createShaderAnimation(shaderHost);
      } catch {
        shader = null;
      }
      /* null means no WebGL or a failed compile — the figure's --tint is
         matched to the shader's black, so the fallback is simply a dark panel */
      syncShader();
    }

    const HOLD = assets.map((a) => Number(a.dataset.hold) || 4000);
    /* per-clip brand-mark tone, read off the same markup */
    const MARK = assets.map((a) => a.dataset.mark || 'dark');
    const markEl = vh.querySelector<HTMLElement>('[data-vh-mark]');
    let advTimer = 0;
    let advTween: gsap.core.Tween | null = null;
    let autoAdvance = true;

    function stopAdvance(permanent = false) {
      clearTimeout(advTimer);
      if (advTween) { advTween.kill(); advTween = null; }
      if (permanent) autoAdvance = false;
    }

    function scheduleAdvance(i: number) {
      clearTimeout(advTimer);
      /* triggers.length - 1 is the last clip: there is nothing after it */
      if (!autoAdvance || i < 0 || i >= triggers.length - 1) return;
      advTimer = window.setTimeout(() => {
        if (!autoAdvance || document.visibilityState !== 'visible') return;
        const t = triggers[i + 1];
        /* matches the wipe trigger's own `end: 'bottom center'` — the point at
           which the next clip is fully revealed */
        const target =
          t.getBoundingClientRect().top + window.scrollY + t.offsetHeight - window.innerHeight / 2;
        if (target <= window.scrollY + 2) return;      // already past it
        const proxy = { y: window.scrollY };
        advTween = gsap.to(proxy, {
          y: target,
          duration: 1.1,
          ease: 'power2.inOut',
          onUpdate: () => window.scrollTo(0, proxy.y),
          onComplete: () => { advTween = null; },
        });
      }, HOLD[i] ?? 4000);
    }

    (['wheel', 'touchstart', 'pointerdown', 'keydown'] as const).forEach((ev) =>
      window.addEventListener(ev, () => stopAdvance(true), { passive: true }),
    );

    /* Every clip plays, all the time.

       This used to pause everything except the active clip — one decode at a
       time, which is cheaper. But the playback trigger fires at 'top center',
       which is AFTER its clip has already begun wiping into view, so the
       incoming clip was frozen on a still frame for the first part of its own
       reveal and only started once it was half on screen. That reads as a
       stutter, and it is the reason the wipes felt like they were snagging.
       Three muted 720p/1080p loops is a cost worth paying to have every clip
       already in motion the instant its mask starts to lift. */
    function playAll() {
      videos.forEach((v) => { if (v && v.paused) attemptPlay(v); });
    }

    function setActive(i: number) {
      if (i === active) return;
      active = i;
      playAll();
      /* the mark is black over the two bright clips and light over the shader,
         which is near-black in the corner */
      if (markEl && i >= 0) markEl.classList.toggle('is-light', MARK[i] === 'light');
      /* build the GL context one clip early so it is warm before the wipe,
         rather than compiling a program mid-transition */
      if (shaderIndex >= 0 && i >= shaderIndex - 1) ensureShader();
      syncShader();
      scheduleAdvance(i);
    }

    /* Without this the hero can stay frozen on a poster permanently: open the
       page in a background tab and the browser refuses the initial play(),
       nothing retries, and the clip is still paused when the visitor finally
       switches to it. Re-assert the active clip whenever the page becomes
       visible. Cheap, and it is the difference between a working hero and a
       still image for anyone who middle-clicks a link. */
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState !== 'visible') {
        /* don't let a timer fire against a tab nobody is looking at — the
           visitor would return to find the hero had scrolled without them */
        stopAdvance();
        syncShader();          // and stop burning GPU on a tab nobody sees
        return;
      }
      playAll();
      syncShader();
      scheduleAdvance(active);
    });

    async function enable() {
      if (made.length || enabling || mqReduce.matches || mqTouch.matches || mqMobile.matches) return;
      enabling = true;
      if (!ST) {
        const mod = await import('gsap/ScrollTrigger');
        ST = mod.ScrollTrigger;
        gsap.registerPlugin(ST);
      }
      /* the query may have flipped while the chunk was in flight */
      if (mqReduce.matches) { enabling = false; return; }

      root.classList.add('vhpin-on');

      assets.forEach((a, i) => {
        /* clip 01 is the base layer — nothing to wipe it over */
        if (i > 0) {
          gsap.set(a, { yPercent: 100 });
          gsap.set(figs[i], { yPercent: -100 });
          const tl = gsap.timeline()
            .to(a, { yPercent: 0, force3D: true, duration: 1, ease: 'none' }, 0)
            .to(figs[i], { yPercent: 0, force3D: true, duration: 1, ease: 'none' }, 0);
          made.push(ST.create({
            animation: tl,
            trigger: triggers[i],
            start: 'top center',
            end: 'bottom center',
            scrub: 0.6,
            invalidateOnRefresh: true,
          }));
        }
        /* playback + label, one per clip including the first */
        made.push(ST.create({
          trigger: triggers[i],
          start: 'top center',
          end: 'bottom center',
          onEnter: () => setActive(i),
          onEnterBack: () => setActive(i),
        }));
      });

      /* trigger 0's start is already behind us at scroll 0, so onEnter will
         never fire for it — prime it explicitly */
      setActive(0);
      enabling = false;
    }

    function disable() {
      /* reduced-motion or teardown: no pinned scene means nothing to advance
         through, and a stray timer would scroll a page that is now ordinary
         flow */
      stopAdvance();
      made.forEach((t) => t.kill());
      made = [];
      root.classList.remove('vhpin-on');
      gsap.set([...assets, ...figs], { clearProps: 'all' });
      videos.forEach((v) => v && v.pause());
      active = -1;
      /* reduced motion / teardown: leave one still frame, never a loop */
      if (shader) { shader.stop(); shader.renderOnce(); }
    }

    function sync() {
      /* Mobile: the hero is hidden and a text hero replaces it — pause/reset
         only, never build the WebGL shader for an element that never shows. */
      if (mqMobile.matches) { disable(); return; }
      if (mqReduce.matches || mqTouch.matches) {
        disable();
        /* still build it — one static frame reads far better than a black
           rectangle behind the statement */
        ensureShader();
      } else enable();
    }

    /* ── pick the cut that matches the stage's aspect ──
       object-fit:cover crops the source to the viewport, and the loss is
       brutal in both directions: a 16:9 master on a 375x812 phone loses 74%
       of its width; a 9:16 cut on a 1440x900 desktop loses 65% of its height.
       Where a portrait variant exists we swap to it under 900px.

       Assigned here rather than via <source media>: browsers evaluate
       <source> once at parse time and never re-check on resize, and Safari's
       handling of `media` on a video source is unreliable. All three clips are
       preload="auto" now that all three play continuously — together they are
       ~1MB, which is the cost of having every clip already in motion before
       its mask lifts. */
    const mqPortrait = window.matchMedia('(max-width: 900px)');
    function pickSources() {
      if (mqMobile.matches) return;   // hero hidden on mobile — never load the clips
      const p = mqPortrait.matches;
      videos.forEach((v) => {
        if (!v) return;
        const want = (p && v.dataset.srcP) || v.dataset.src || '';
        if (v.dataset.applied === want) return;   // no needless reload
        v.dataset.applied = want;
        const wasPlaying = !v.paused;
        v.poster = (p && v.dataset.posterP) || v.dataset.poster || '';
        v.src = want;
        if (wasPlaying) { const pr = v.play(); if (pr) pr.catch(() => {}); }
      });
    }
    pickSources();
    mqPortrait.addEventListener('change', pickSources);

    /* ── the nav ──
       Hidden while the hero owns the screen, slid in once it releases.
       Keyed to the hero's real bottom edge rather than a magic scroll number,
       so it stays correct when --vh-step is retuned or a clip is added.
       A plain passive scroll listener toggling one class is cheaper than a
       ScrollTrigger here, and it keeps working in the reduced-motion branch
       where ScrollTrigger is never loaded. */
    const nav = document.querySelector<HTMLElement>('.sitenav--page');
    if (nav) {
      const onScroll = () => {
        /* 72px ≈ the nav's own height: it starts arriving just before the
           last frame of video clears, so the two motions overlap instead of
           leaving a bare gap */
        nav.classList.toggle('is-in', vh.getBoundingClientRect().bottom <= 72);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      onScroll();
    }

    sync();
    mqReduce.addEventListener('change', sync);

    /* Height changes (mobile chrome show/hide, rotation) move every trigger.
       ScrollTrigger.refresh remeasures; the debounce keeps it off the
       scroll path. */
    let rt = 0;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = window.setTimeout(() => ST && ST.refresh(), 150);
    }, { passive: true });

    if (import.meta.env.DEV) {
      (window as any).__vh = {
        gsap, assets, figs, videos, triggers, setActive, ensureShader, shaderHost, shaderIndex,
        get made() { return made; },
        get shader() { return shader; },
      };
    }
  }
</script>





<script>
  /* ══════════ the fourth wipe ══════════
     Carries the hero's clip-to-clip move one step further, so the AEO content
     is uncovered over the held shader rather than arriving as a new page.

     Same equal-and-opposite pair the hero uses: the mask travels
     yPercent 100 → 0 while the section inside travels -100 → 0, which cancels,
     so the content holds still and the mask sweeps off it.

     This lives entirely outside the hero. It waits for the hero's own
     html.vhpin-on class rather than setting it, reads the hero's geometry
     rather than changing it, and adds nothing to the hero's DOM. */
  import { gsap } from 'gsap';

  const slotEl = document.querySelector<HTMLElement>('[data-aeo-enterslot]');
  const enterEl = slotEl?.querySelector<HTMLElement>('[data-aeo-enter]');
  const shiftEl = enterEl?.querySelector<HTMLElement>('.aeo__shift');

  if (slotEl && enterEl && shiftEl) {
    const root = document.documentElement;
    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    /* The hero pins asynchronously — it dynamically imports ScrollTrigger
       before adding the class — so the class is usually not there yet when
       this runs. Watch for it instead of racing it. */
    function whenPinned(cb: () => void) {
      if (root.classList.contains('vhpin-on')) { cb(); return; }
      const mo = new MutationObserver(() => {
        if (!root.classList.contains('vhpin-on')) return;
        mo.disconnect();
        cb();
      });
      mo.observe(root, { attributes: true, attributeFilter: ['class'] });
      /* if the hero never pins (reduced motion, or it bailed on the fit
         check) there is nothing to wipe over — stop watching */
      setTimeout(() => mo.disconnect(), 10000);
    }

    async function build() {
      if (mqReduce.matches) return;      // CSS already removed the overlap
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');
      gsap.registerPlugin(ScrollTrigger);

      const tl = gsap.timeline({ paused: true, defaults: { ease: 'none' } })
        .fromTo(enterEl, { yPercent: 100 }, { yPercent: 0, force3D: true, duration: 1 }, 0)
        .fromTo(shiftEl, { yPercent: -100 }, { yPercent: 0, force3D: true, duration: 1 }, 0);

      ScrollTrigger.create({
        animation: tl,
        /* The SLOT, never the mask. ScrollTrigger measures its trigger's rect
           including any transform already on it, so pointing this at enterEl
           measured it with its own parked yPercent:100 and put start/end a
           full element-height late. The slot carries the overlap and is never
           animated, so its rect is the true layout position. */
        trigger: slotEl,
        /* 40vh of travel, matching the -40lvh overlap in the CSS. The slot's
           top starts at the viewport bottom and finishes at 60% — which is
           the exact moment the hero's wrapper bottom reaches the viewport
           bottom and its sticky lets go. The wipe therefore ends precisely as
           the hero hands over, never sweeping against the page below it. */
        start: 'top bottom',
        /* 'top top', not 'top 60%'. With a full-viewport overlap the slot's
           top reaching the viewport top IS the moment the hero's wrapper
           bottom reaches the viewport bottom and the sticky lets go — so the
           curtain finishes covering the screen on the exact frame the hero
           hands over. At the old 40% overlap this had to stop short, which is
           what left the sweep looking unfinished. */
        end: 'top top',
        scrub: 0.6,
        invalidateOnRefresh: true,
      });
    }

    whenPinned(build);
    mqReduce.addEventListener('change', () => { if (!mqReduce.matches) whenPinned(build); });
  }
</script>


<script>
  /* ══════════ box entrance ══════════
     Every box on the page rises into place while de-blurring, staggered —
     the same treatment the four service cards use on the homepage
     (index.astro: opacity 0 → 1, y offset → 0, blur(7px) → 0, 0.9s,
     power3.out, 70ms apart). Reused deliberately so the two pages feel
     like one product.

     Stagger is per ROW, not per element across the whole page: a global
     index would give the last card on a six-card grid a 0.42s delay, which
     reads as lag rather than rhythm. Elements are grouped by their top
     offset so a row animates together and the next row follows.

     Resting CSS is the finished page — JS applies the hidden state, so a
     failed script leaves everything visible rather than blank. */
  import { gsap } from 'gsap';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const aeo = document.querySelector<HTMLElement>('.aeo');

  if (aeo && !reduce) {
    const boxes = [...aeo.querySelectorAll<HTMLElement>('[data-aeo-card]')];

    /* group into rows by vertical position so the stagger reads as a row
       arriving, not as a queue draining */
    const rowOf = new Map<HTMLElement, number>();
    const seen: number[] = [];
    boxes.forEach((el) => {
      const top = Math.round(el.getBoundingClientRect().top + window.scrollY);
      let row = seen.findIndex((t) => Math.abs(t - top) < 40);
      if (row === -1) { seen.push(top); row = seen.length - 1; }
      rowOf.set(el, row);
    });
    const indexInRow = new Map<HTMLElement, number>();
    const counts = new Map<number, number>();
    boxes.forEach((el) => {
      const r = rowOf.get(el)!;
      const n = counts.get(r) ?? 0;
      indexInRow.set(el, n);
      counts.set(r, n + 1);
    });

    gsap.set(boxes, { opacity: 0, y: 26, filter: 'blur(7px)' });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        io.unobserve(e.target);
        const el = e.target as HTMLElement;
        gsap.to(el, {
          opacity: 1, y: 0, filter: 'blur(0px)',
          duration: 0.9,
          delay: (indexInRow.get(el) ?? 0) * 0.07,
          ease: 'power3.out',
          /* drop the filter once done — leaving blur(0) on dozens of boxes
             keeps them all on their own composited layers for nothing */
          clearProps: 'filter',
        });
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -6%' });
    boxes.forEach((el) => io.observe(el));

    /* ── the discovery graph: bars draw + values count up on entry ──
       The bars grow via a staggered CSS transition off .is-drawn (one class
       beats tweening five elements). The percentages count 0 → target on the
       same trigger, each delayed to land as its own bar finishes filling, so
       the number and the bar arrive together. */
    const graph = aeo.querySelector<HTMLElement>('[data-aeo-graph]');
    function countGraph() {
      graph?.querySelectorAll<HTMLElement>('[data-aeo-count]').forEach((el, i) => {
        const to = Number(el.dataset.aeoCount || '0');
        const p = { v: 0 };
        gsap.to(p, {
          v: to, duration: 1, ease: 'power2.out',
          delay: 0.22 + i * 0.12,               // matches the bar's --i stagger
          onUpdate: () => { el.textContent = `${Math.round(p.v)}%`; },
          onComplete: () => { el.textContent = `${to}%`; },
        });
      });
    }
    if (graph) {
      new IntersectionObserver(([e], o) => {
        if (!e.isIntersecting) return;
        o.disconnect();
        setTimeout(() => graph.classList.add('is-drawn'), 220);
        countGraph();
      }, { threshold: 0.4 }).observe(graph);
    }

    /* failsafe: nothing on this page may stay invisible */
    setTimeout(() => {
      boxes.forEach((el) => {
        if (gsap.getProperty(el, 'opacity') === 0) {
          gsap.set(el, { opacity: 1, y: 0, clearProps: 'filter' });
        }
      });
      if (graph && !graph.classList.contains('is-drawn')) {
        graph.classList.add('is-drawn');
        graph.querySelectorAll<HTMLElement>('[data-aeo-count]').forEach((el) => {
          el.textContent = `${el.dataset.aeoCount || '0'}%`;
        });
      }
    }, 6000);
  } else if (aeo) {
    /* reduced motion: resting CSS is the finished design. Bars sit at full
       width and the numbers show their real values, just without animating. */
    const g = aeo.querySelector('[data-aeo-graph]');
    g?.classList.add('is-drawn');
    g?.querySelectorAll<HTMLElement>('[data-aeo-count]').forEach((el) => {
      el.textContent = `${el.dataset.aeoCount || '0'}%`;
    });
  }
</script>

<script>
  /* ══════════ card deep-dive modals ══════════
     The diagnosis and service cards are buttons that open a shared native
     <dialog>. Native showModal() is doing the accessibility heavy lifting:
     focus is trapped inside the dialog, Escape closes it, and focus returns
     to the card that opened it when it closes — none of which I have to
     hand-roll. The ::backdrop blur is pure CSS. */
  const modal = document.querySelector<HTMLDialogElement>('[data-aeo-modal]');
  const dataEl = document.querySelector<HTMLElement>('[data-aeo-modals]');

  if (modal && dataEl && typeof modal.showModal === 'function') {
    const DATA = JSON.parse(dataEl.textContent || '{}') as Record<string, {
      eyebrow: string; title: string; lead: string; points: string[];
    }>;
    const eyebrow = modal.querySelector<HTMLElement>('[data-aeo-modaleyebrow]')!;
    const title = modal.querySelector<HTMLElement>('[data-aeo-modaltitle]')!;
    const lead = modal.querySelector<HTMLElement>('[data-aeo-modallead]')!;
    const points = modal.querySelector<HTMLElement>('[data-aeo-modalpoints]')!;
    const closeBtn = modal.querySelector<HTMLButtonElement>('[data-aeo-modalclose]')!;

    function open(key: string) {
      const d = DATA[key];
      if (!d) return;
      eyebrow.textContent = d.eyebrow;
      title.textContent = d.title;
      lead.textContent = d.lead;
      points.replaceChildren(
        ...d.points.map((p) => { const li = document.createElement('li'); li.textContent = p; return li; }),
      );
      const card = modal.querySelector<HTMLElement>('.aeo__modalcard');
      if (card) card.scrollTop = 0;
      /* showModal() throws if already open — can't happen through the UI (the
         modal blocks the page) but guard anyway so a stray call is harmless */
      if (!modal.open) modal.showModal();
    }

    document.querySelectorAll<HTMLElement>('[data-modal]').forEach((card) => {
      card.addEventListener('click', () => open(card.dataset.modal!));
    });

    closeBtn.addEventListener('click', () => modal.close());
    /* click the dimmed area (the dialog element itself, not the card inside)
       to dismiss — the everyday expectation for a modal */
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
  }
</script>
</body>
