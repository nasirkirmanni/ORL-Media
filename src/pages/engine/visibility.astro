---
import '../../styles/global.css';
import '../../styles/engine.css';
import '../../styles/visibility.css';
import '../../styles/aeo.css';
import Seo from '../../components/Seo.astro';
import GlassNav from '../../components/GlassNav.astro';
import { graph, organization, website, service, breadcrumbs } from '../../lib/schema';
import { MODULES, ORDER } from '../../lib/modules';

/* ─────────────────────────────────────────────────────────────
   VISIBILITY — system 01, forked from the shared module template.

   Why this page is bespoke: Visibility is the entry point of the
   ladder (Audit → Modules → Engine). On the shared template it
   looked identical to the module that is still in build.

   The hero is a pinned scroll scene: the giant word recedes in Z
   while three cards emerge from behind it, hold as one composition
   at three depths, then separate to reveal the transition into the
   Problem section. Everything below the hero is the shared
   .mod__* markup, unchanged.

   Sections 2–8 read from the SAME record the other three modules
   use (src/lib/modules.ts), so the copy cannot drift.
   ───────────────────────────────────────────────────────────── */

const m = MODULES.visibility;
const slug = 'visibility';
const nextSlug = 'signals';
const next = MODULES[nextSlug];
const metricRest = `${m.metric.to}${m.metric.fmt}`;

const modPath = `/engine/${slug}/`;
const ld = graph([
  organization(),
  website(),
  service({ name: m.name, description: m.sub, path: modPath }),
  breadcrumbs([
    { name: 'Home', path: '/' },
    { name: 'The Growth Engine', path: '/engine/' },
    { name: m.name, path: modPath },
  ]),
]);

/* The three hero clips.

   ASPECT — the primary is LANDSCAPE 1920x1080, H.264, no audio track,
   faststart. The stage is object-fit:cover at full bleed, so the source
   aspect is cropped to whatever the viewport is:
     • a 9:16 source on a 1440x900 desktop loses 65% of its HEIGHT
     • a 16:9 source on a 375x812 phone loses 74% of its WIDTH
   No single file survives both. So: shoot 16:9 and keep everything that
   carries meaning inside the CENTRE SQUARE of the frame — the desktop then
   gets the full composition and the mobile crop still contains it.

   `portrait` is optional. Set it only once a real 1080x1920 cut exists at
   <src>-p.mp4, and the swap below picks it up under 900px. Leaving it off
   is the safe default — a missing file would fall through to the tint. */
type Clip = {
  kind?: 'video' | 'shader';   // default 'video'
  src?: string;                // video only
  alt: string;             // the accessible description of the footage
  tint: string;            // fallback ground while the file loads
  hold: number;            // ms on screen before the hero glides to the next
  /* Brand-mark tone for this clip. Measured top-left luma of each master:
     vis-01 ~210, vis-02 ~145, vis-03 ~2. Black reads on the first two and is
     literally invisible on the third, so the mark flips per clip. */
  mark: 'dark' | 'light';
  statement?: string[];    // big type burned over this clip; one entry per line
  portrait?: boolean;
};
const CLIPS: Clip[] = [
  /* 01 — a buyer types the question. Encoded at 1.5x (baked into the file
     with setpts, not set via playbackRate: it removes a runtime dependency
     and made the file a third shorter, 10.0s -> 6.75s). */
  { src: '/video/vis-01', tint: '#1d2b4a', hold: 3500, mark: 'dark',
    alt: 'A person typing a question to an AI assistant, asking which companies solve their problem.' },

  /* 02 — the assistant answers. */
  { src: '/video/vis-02', tint: '#232a2e', hold: 4000, mark: 'dark',
    alt: 'An AI assistant replying with its answer.' },

  /* 03 — the shader. Not footage: a live WebGL fragment shader (see
     src/lib/shader-animation.ts). Near-black with bright diagonal light bands
     sweeping the corners, so the mark goes light here or it vanishes.
     `tint` is the pre-init / no-WebGL ground and is matched to the shader's
     own black so the fallback is invisible rather than a brown flash.
     `hold` is unused on the last clip: nothing follows it inside the hero and
     the statement is never scrolled away automatically. */
  { kind: 'shader', tint: '#050507', hold: 4000, mark: 'light',
    alt: 'An animated field of diagonal light bands.',
    statement: ['Discover ORL Visibility'] },
];

/* Journey pills for the "Why it matters" section — icon + label. The icons
   are small stroke SVGs (lucide-style), rendered via set:html so the paths
   inherit currentColor. Kept as data so the two rows stay in sync. */
const ICON: Record<string, string> = {
  search: '<circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/>',
  link: '<path d="M9 15l6-6"/><path d="M11.5 6.5l1-1a3.5 3.5 0 0 1 5 5l-1 1"/><path d="M12.5 17.5l-1 1a3.5 3.5 0 0 1-5-5l1-1"/>',
  globe: '<circle cx="12" cy="12" r="9"/><line x1="3" y1="12" x2="21" y2="12"/><path d="M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>',
  clipboard: '<rect x="8.5" y="3.5" width="7" height="4" rx="1"/><path d="M8.5 5.5H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-12a2 2 0 0 0-2-2h-2.5"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/>',
  cart: '<circle cx="9.5" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/><path d="M2 3.5h3l2.2 11a1.6 1.6 0 0 0 1.6 1.3h8.2a1.6 1.6 0 0 0 1.6-1.3L21 7.5H6"/>',
  question: '<circle cx="12" cy="12" r="9"/><path d="M9.3 9.2a2.8 2.8 0 0 1 5.4.8c0 1.9-2.7 2.4-2.7 2.4"/><circle cx="12" cy="16.6" r="0.7" fill="currentColor" stroke="none"/>',
  sparkle: '<path d="M12 3.5l1.9 5.6L19.5 11l-5.6 1.9L12 18.5l-1.9-5.6L4.5 11l5.6-1.9z"/>',
  thumb: '<path d="M7 11.5v8.5H4.5a1 1 0 0 1-1-1v-6.5a1 1 0 0 1 1-1z"/><path d="M7 11.5l3.7-6.6a1.8 1.8 0 0 1 3.3 1.3l-.7 3.3h4.6a1.8 1.8 0 0 1 1.8 2.2l-1.2 5.6A1.8 1.8 0 0 1 16.7 20H7"/>',
};
const OLD_JOURNEY: Array<[string, string]> = [
  ['search', 'Google search'], ['link', 'Ten blue links'], ['globe', 'Website'],
  ['clipboard', 'Research'], ['cart', 'Purchase'],
];
const NEW_JOURNEY: Array<[string, string]> = [
  ['question', 'Question'], ['sparkle', 'AI answer'], ['thumb', 'Brand recommendation'],
  ['clipboard', 'Research'], ['cart', 'Purchase'],
];
const GRAPH: Array<[string, number]> = [
  ['2022', 12], ['2023', 27], ['2024', 44], ['2025', 57], ['2026', 71],
];
const COMPARE: Array<[string, string]> = [
  ['Search keywords', 'Ask complete questions'],
  ['Open multiple links', 'Receive synthesised answers'],
  ['Compare websites manually', 'Ask AI to compare options'],
  ['Find companies', 'Get recommended companies'],
  ['Rankings matter', 'Mentions and citations matter'],
];

/* Deep-dive content for the clickable diagnosis and service cards. Each card
   carries a data-modal key; clicking it opens a shared <dialog> populated
   from here. Keeping the copy as data (not in markup) means the cards, their
   summaries and the modal bodies can't drift apart. */
type Modal = { eyebrow: string; title: string; lead: string; points: string[] };
const MODALS: Record<string, Modal> = {
  'diag-authority': {
    eyebrow: 'Diagnosis',
    title: 'Not enough authoritative mentions',
    lead: 'AI models rank sources by trust. If the places they read — review platforms, analyst pages, industry publications — rarely name you next to your category, the model has little evidence that you belong in the answer.',
    points: [
      'Language models weight third-party sources far more heavily than your own website when deciding who to recommend.',
      'A brand named by three trusted sources loses to one named by thirty, even when its product is better.',
      'We map which sources each AI engine actually cites in your category, then build presence in the ones that move the answer.',
    ],
  },
  'diag-competitors': {
    eyebrow: 'Diagnosis',
    title: 'Competitors own the conversation',
    lead: 'The models are not biased against you — they reflect the web as it is. If competitors appear more often across the pages AI reads, they become the default answer, and every new query reinforces it.',
    points: [
      'AI recommendations compound: the more a brand is cited, the more it gets recommended, the more it gets cited.',
      'Being absent is not neutral — it trains the model that the category is solved without you.',
      'We quantify the citation gap between you and each competitor, question by question, so the fight is specific rather than vague.',
    ],
  },
  'diag-positioning': {
    eyebrow: 'Diagnosis',
    title: "Your positioning isn't clear",
    lead: 'The model may understand what you do, but not the moment you are the right choice. Without a clear, machine-readable answer to "when and why choose this," you get left out of the comparison even when you would win it.',
    points: [
      'AI answers are decision-shaped: "best for X," "alternative to Y," "when you need Z." If your positioning does not map to those, you are invisible to them.',
      'Vague, feature-led messaging reads as noise to a model trying to match a buyer’s specific situation.',
      'We restructure your entity and content around the exact decisions buyers put to AI, so the model can place you with confidence.',
    ],
  },
  'diag-coverage': {
    eyebrow: 'Diagnosis',
    title: 'Missing answer coverage',
    lead: 'Buyers ask AI dozens of questions before they ever reach a vendor. If your brand shows up for only a handful of them, you lose the ones you never knew were being asked.',
    points: [
      'Most categories have 100+ real buying questions; most brands appear in only a fraction of them.',
      'The questions you are missing are often mid-funnel comparisons — exactly where decisions get made.',
      'We map the full question set, score where you appear, and prioritise the gaps with the most buying intent.',
    ],
  },
  'svc-audit': {
    eyebrow: 'Deliverable 01',
    title: 'AI Visibility Audit',
    lead: 'A complete read of where your brand stands across the AI engines buyers actually use — ChatGPT, Gemini, Claude and AI-powered search — for the real questions in your category.',
    points: [
      'We test 100+ category questions across four engines and record where you appear, where you don’t, and in what light.',
      'You get a single Share-of-Answer baseline plus a question-by-question breakdown.',
      'Fixed scope, delivered in days, with a prioritised list of what to fix first.',
    ],
  },
  'svc-benchmark': {
    eyebrow: 'Deliverable 02',
    title: 'Competitor Benchmark',
    lead: 'Visibility only means something relative to the people you are up against. We show exactly who the AI recommends in your place, and how far ahead they are.',
    points: [
      'Side-by-side Share of Answer for you and up to eight competitors.',
      'The specific questions where a competitor wins and you are absent.',
      'Which of their citations and sources are doing the work — your roadmap to close the gap.',
    ],
  },
  'svc-questions': {
    eyebrow: 'Deliverable 03',
    title: 'Question Intelligence',
    lead: 'Not every question is worth winning. We identify the prompts and buyer questions that actually precede a purchase, so effort goes where the revenue is.',
    points: [
      'We separate high-intent, decision-stage questions from top-of-funnel curiosity.',
      'Each question is scored by buying intent and by how winnable it is today.',
      'The result is a focused target list, not a spray of keywords.',
    ],
  },
  'svc-citation': {
    eyebrow: 'Deliverable 04',
    title: 'Citation Intelligence',
    lead: 'AI recommendations are built on sources. We trace the exact pages, reviews and references each engine leans on for your category — the leverage points for changing the answer.',
    points: [
      'We identify which domains and source types each AI engine trusts most in your space.',
      'We find where competitors earn their citations and where you realistically can too.',
      'Presence is then built deliberately in the sources that move the model.',
    ],
  },
  'svc-strategy': {
    eyebrow: 'Deliverable 05',
    title: 'AEO Strategy',
    lead: 'The audit tells you where you stand; the strategy tells you what to change. A concrete plan for content, entities and authority signals, sequenced by impact.',
    points: [
      'Entity and structured-data work so engines understand what you are and when to recommend you.',
      'Decision-stage content mapped to the specific questions you are losing.',
      'A citation and third-party-proof plan targeting the sources that count.',
    ],
  },
  'svc-measurement': {
    eyebrow: 'Deliverable 06',
    title: 'Ongoing Measurement',
    lead: 'AI answers change constantly. We re-score your Share of Answer every month so you can see whether the work is moving the number — and where next month’s effort goes.',
    points: [
      'Monthly re-scoring across every tracked question and engine.',
      'Movement attributed to specific changes, so you know what is working.',
      'A living priority list, not a one-off report.',
    ],
  },
};

---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <Seo
    title={`${m.name} — ${m.pos} | ORL Growth Engine`}
    description={`System ${m.num} of the ORL Growth Engine. ${m.sub}`}
    ogTitle={`ORL ${m.name} — ${m.pos}`}
    image={`/og/${slug}.jpg`}
  >
    <script type="application/ld+json" is:inline set:html={ld} />
  </Seo>
  <!-- No font preload here on purpose. The Switzer preload that used to sit
       on this line became dead weight once the statement moved to Pierson —
       Switzer is now only a fallback in that stack, and preloading a fallback
       fetches 14KB nothing renders (and trips Chrome's "preloaded but not
       used" warning). Pierson is not preloaded either: the statement is laid
       out from first paint even though the mask clips it, so the browser
       fetches the face on its own, and clip 03 is several seconds of
       scrolling away. The video is the thing worth the bandwidth. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <!-- Cormorant Garamond is loaded on THIS page only, for the hero brand mark.
       It is a fifth family site-wide, so it is deliberately not added to the
       shared font link the other pages use. -->
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@600&display=swap" rel="stylesheet" />
  <!-- Gate for the hide-then-reveal nav, set before first paint so the nav
       never flashes over the opening frame of the hero. Deliberately inline
       and blocking — it is one class, and deferring it would cost the flash
       it exists to prevent.
       With JS off the class is never added, the rules under html.vhnav-on
       never apply, and the nav stays visible and sticky as on every other
       page. Navigation must not depend on a script running. -->
  <script is:inline>document.documentElement.classList.add('vhnav-on');</script>
</head>
<body class="blg-body eng-body">

<nav class="sitenav sitenav--page is-visible" aria-label="Site">
  <a class="sitenav__brand" href="/">
    <span class="sitenav__mark" aria-hidden="true"></span>
    ORL
  </a>
  <div class="sitenav__links">
    <a href="/engine" class="sitenav__link" aria-current="true">Engine</a>
    <a href="/audit" class="sitenav__link">Audit</a>
    <a href="/results" class="sitenav__link">Results</a>
    <a href="/about" class="sitenav__link">About</a>
    <a href="/blog" class="sitenav__link">Blog</a>
  </div>
  <a class="sitenav__pill" href="/book">Book a call</a>
</nav>
<GlassNav />

<main class="vis" id="main" style={`--acc:${m.accent}; --acc-d:${m.accentDark}; --acc-t:${m.accentText};`}>

  <!-- Mobile (≤767px): the 3-video wipe hero is hidden and its clips never
       load; the page starts on this text hero instead. -->
  <header class="vmhero">
    <p class="vmhero__crumb mono">
      <a href="/engine">The Growth Engine</a>
      <span aria-hidden="true">/</span> System {m.num}
    </p>
    <h1 class="vmhero__title">{m.name}<em>.</em></h1>
    <p class="vmhero__pos">{m.pos}</p>
    <p class="vmhero__sub">{m.sub}</p>
  </header>

  <!-- ══════════ the video hero ══════════
       Three full-bleed clips of AI engines answering a real buying question.
       Landscape 16:9 masters, composed centre-safe; an optional 9:16 cut is
       swapped in under 900px (see the `portrait` flag in CLIPS).

       The reveal is a masked curtain wipe, not a slide. The outer mask moves
       yPercent 100 → 0 while the inner figure moves -100 → 0 — equal and
       opposite, so the footage never travels across the screen. The mask
       sweeps OFF it and the clip appears to be uncovered in place. That is
       what makes it read as expensive rather than as a slideshow.
       (Mechanic verified against bennettandclive.com's implementation.)

       Scroll budget lives in .vh__triggers: a zero-width column of one spacer
       per clip. Retiming the whole sequence is one number — --vh-step.

       Ungated (no html.vhpin-on) this is an ordinary stack of three posters in
       normal flow. That is the no-JS and reduced-motion state, and it is a
       finished layout rather than a broken one. -->
  <section class="vh" data-vh aria-label="AI engines answering buying questions">
    <div class="vh__wrapper">

      <!-- zero-width scroll budget: the spacers give the section its height -->
      <div class="vh__triggers" aria-hidden="true">
        {CLIPS.map(() => <div class="vh__trigger" data-vh-trigger></div>)}
      </div>

      <div class="vh__inner">
        <div class="vh__sticky" data-vh-sticky>

          <div class="vh__assets" data-vh-assets>
            {CLIPS.map((c, i) => (
              <div class="vh__asset" data-vh-asset data-i={i} data-hold={c.hold} data-mark={c.mark}>
                <figure class="vh__fig" data-vh-fig style={`--tint:${c.tint}`}>
                  {/* No `autoplay` attribute by design: JS starts clip 01 only
                      when motion is allowed, so reduced-motion and no-JS both
                      rest on the poster instead of playing footage at someone
                      who asked for stillness. */}
                  {/* Sources are set by JS, not by <source media>: browsers
                      evaluate <source> once at parse time and never re-check
                      it on resize, and Safari's support for `media` on a
                      video source is unreliable. data-* + one matchMedia read
                      is deterministic. Nothing is wasted — clips 2 and 3 are
                      preload="none" until they're needed. */}
                  {c.kind === 'shader' ? (
                    /* The WebGL canvas is created and appended by JS. If
                       WebGL is unavailable, or the context is lost, this stays
                       empty and the figure's own --tint shows through — which
                       is why that tint is matched to the shader's black. */
                    <div class="vh__shader" data-vh-shader role="img" aria-label={c.alt}></div>
                  ) : (
                    <video
                      class="vh__video"
                      data-vh-video
                      data-src={`${c.src}.mp4`}
                      data-src-p={c.portrait ? `${c.src}-p.mp4` : undefined}
                      data-poster={`${c.src}.jpg`}
                      data-poster-p={c.portrait ? `${c.src}-p.jpg` : undefined}
                      poster={`${c.src}.jpg`}
                      muted
                      loop
                      playsinline
                      disablepictureinpicture
                      preload="auto"
                      aria-label={c.alt}
                    ></video>
                  )}

                  {/* The statement rides INSIDE the figure, not in a separate
                      overlay layer. Two consequences, both wanted:
                        • the mask reveals the words and the footage together,
                          as one image, instead of text fading in on top
                        • it counter-translates with the figure, so the type
                          holds dead still while the curtain sweeps off it
                      Only clip 03 carries one — clips 01 and 02 are clean
                      footage, nothing over them. */}
                  {c.statement && (
                    <figcaption class="vh__statement">
                      {c.statement.map((line) => <span>{line}</span>)}
                    </figcaption>
                  )}
                </figure>
              </div>
            ))}
          </div>


          {/* Brand mark. Lives in the sticky layer rather than inside a figure,
              so it sits above every clip and holds still through the wipes
              instead of being masked away with the footage. aria-hidden: the
              site nav already carries "ORL Media" as a link, and a second
              copy would just be noise to a screen reader. */}
          <p class="vh__mark" data-vh-mark aria-hidden="true">ORL Media</p>

          {/* The hero is deliberately wordless, so the document still needs a
              level-one heading for structure and for anything reading the
              outline. Visually hidden, not display:none — it has to stay in
              the accessibility tree. */}
          <h1 class="vis__sr">{m.name} — {m.pos} {m.sub}</h1>

        </div>
      </div>
    </div>
  </section>
  <!-- ══════════════════════════════════════════════════════════
       VISIBILITY — everything below the locked 3-video hero.

       Order is the argument: state the shift (01), define AEO by
       showing it (02), prove the behaviour change (03), make it
       personal (04), introduce the system (05), only then reveal
       the product (06), diagnose (07), sell the deliverable (08),
       show the outcome (09), and close on the question the page
       opened with (10).

       Beige and white throughout — no dark slabs. Every section
       title is centred and large so the section is identifiable
       at a glance. Every box is a .aeo__card and animates in on
       the same depth-graded rise the homepage service cards use.
       ══════════════════════════════════════════════════════════ -->
  <div class="aeo">

  <!-- ── 01 · the shift ── -->
  <div class="aeo__enterslot" data-aeo-enterslot>
  <div class="aeo__enter" data-aeo-enter>
  <section class="aeo__sec aeo__shift" aria-labelledby="aeo-shift-h">
    <div class="aeo__in--narrow">
      <h2 class="aeo__h2" id="aeo-shift-h" data-aeo-card>The shift</h2>
      <p class="aeo__sub aeo__sub--lead" data-aeo-card>
        Your customers are asking AI who to choose.
        <span>The question is whether AI chooses you.</span>
      </p>
      <p class="aeo__lede" data-aeo-card>
        Search is moving beyond Google. Buyers now ask ChatGPT, Gemini, Claude
        and AI-powered search engines for recommendations, comparisons and
        solutions.
      </p>
      <div class="aeo__ctacenter" data-aeo-card>
        <a class="aeo__btn" href="/audit">
          Discover your AI visibility
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>
  </div>
  </div>

  <!-- ── 02 · what is AEO ── -->
  <section class="aeo__sec aeo__sec--beige" aria-labelledby="aeo-what-h">
    <div class="aeo__in">
      <div class="aeo__head">
        <h2 class="aeo__h2" id="aeo-what-h" data-aeo-card>What is AEO?</h2>
        <p class="aeo__sub" data-aeo-card>
          SEO helps you rank in search.<br />AEO helps you <em>become the answer</em>.</p>
      </div>

      <div class="aeo__convo">
        <div class="aeo__bubble aeo__bubble--user" data-aeo-card>
          <span class="aeo__bubbletag">Buyer asks</span>
          What are the best growth partners for B2B SaaS companies?
        </div>
        <div class="aeo__bubble aeo__bubble--ai" data-aeo-card>
          <span class="aeo__bubbletag">AI responds</span>
          Based on visibility, expertise and market presence, here are several
          companies worth considering…
        </div>
      </div>

      <div class="aeo__picks">
        <article class="aeo__card aeo__pick" data-aeo-card>
          <span class="aeo__pickrank">Recommended 01</span>
          <p class="aeo__pickname">Northwind Growth</p>
          <p class="aeo__pickmeta">Cited by 14 sources</p>
        </article>
        <article class="aeo__card aeo__pick" data-aeo-card>
          <span class="aeo__pickrank">Recommended 02</span>
          <p class="aeo__pickname">Meridian Partners</p>
          <p class="aeo__pickmeta">Cited by 11 sources</p>
        </article>
        <article class="aeo__card aeo__pick" data-aeo-card>
          <span class="aeo__pickrank">Recommended 03</span>
          <p class="aeo__pickname">Halcyon Labs</p>
          <p class="aeo__pickmeta">Cited by 9 sources</p>
        </article>
      </div>

      <p class="aeo__absent" data-aeo-card>
        <i class="aeo__dot" aria-hidden="true"></i>
        <span><b>Your company isn't mentioned.</b></span>
      </p>

      <p class="aeo__define" data-aeo-card>
        <b>Answer Engine Optimization (AEO)</b> is the process of increasing how
        often your brand is discovered, cited and recommended when people ask AI
        systems questions relevant to your market.
      </p>

      <p class="aeo__note">Company names above are illustrative.</p>
    </div>
