<!-- Section 2B — Revenue Leak Map: stage interaction + per-panel viz.
     Own block on purpose: this section must stay readable and operable even if
     an unrelated script above throws, so it shares no scope with the hero/GSAP
     code. (An unrelated null in that block silently killed three features
     earlier in this project.)

     Resting DOM is the FINISHED state; gsap applies the hidden state only when
     it runs, so no-JS and reduced-motion show every stage fully populated. -->
<script>
  import { gsap } from 'gsap';

  const rl = document.querySelector('.rl');

  if (rl) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const tabs = [...rl.querySelectorAll('[data-rl-tab]')];
    const panels = [...rl.querySelectorAll('[data-rl-panel]')];

    /* ── count-up formatter ── */
    const fmt = (el, v) => {
      const dec = Number(el.dataset.rlDec || 0);
      const s = dec ? v.toFixed(dec) : String(Math.round(v));
      return s + (el.dataset.rlSuffix || '');
    };
    const finalizeCounts = (panel) =>
      panel.querySelectorAll('[data-rl-count]').forEach((el) => { el.textContent = fmt(el, Number(el.dataset.rlCount || 0)); });

    /* ── build + play one panel's visualization (replays on each activation) ── */
    function playViz(panel) {
      if (panel._rlTl) { panel._rlTl.kill(); panel._rlTl = null; }
      if (panel._rlHeal) { clearTimeout(panel._rlHeal); panel._rlHeal = null; }
      const steps = [...panel.querySelectorAll('[data-rl-step]')];
      const sparks = [...panel.querySelectorAll('[data-rl-spark]')];
      const counts = [...panel.querySelectorAll('[data-rl-count]')];
      const typeEl = panel.querySelector('[data-rl-type]');
      const caret = panel.querySelector('[data-rl-caret]');
      const fullText = typeEl ? (typeEl.dataset.rlFull || typeEl.textContent || '') : '';
      if (typeEl) typeEl.dataset.rlFull = fullText;

      if (reduce) {
        gsap.set(steps, { autoAlpha: 1, y: 0 });
        sparks.forEach((p) => gsap.set(p, { strokeDashoffset: 0 }));
        if (typeEl) typeEl.textContent = fullText;
        if (caret) gsap.set(caret, { autoAlpha: 0 });
        finalizeCounts(panel);
        return;
      }

      /* hidden initial state — JS-applied, so a dead ticker leaves resting DOM */
      gsap.set(steps, { autoAlpha: 0, y: 10 });
      sparks.forEach((p) => { const len = p.getTotalLength(); gsap.set(p, { strokeDasharray: len, strokeDashoffset: len }); });
      if (typeEl) typeEl.textContent = '';
      if (caret) gsap.set(caret, { autoAlpha: 1 });

      const tl = gsap.timeline();
      let t = 0;

      if (typeEl && fullText) {
        const dur = Math.min(1.0, fullText.length * 0.014);
        tl.to({ i: 0 }, { i: fullText.length, duration: dur, ease: 'none',
          onUpdate() { typeEl.textContent = fullText.slice(0, Math.round(this.targets()[0].i)); } }, 0);
        t = dur + 0.15;
        if (caret) tl.to(caret, { autoAlpha: 0, duration: 0.2 }, t);
      }

      steps.forEach((s, i) => tl.to(s, { autoAlpha: 1, y: 0, duration: 0.4, ease: 'power2.out' }, t + i * 0.09));
      sparks.forEach((p, i) => tl.to(p, { strokeDashoffset: 0, duration: 0.85, ease: 'power2.out' }, t + 0.25 + i * 0.1));
      counts.forEach((el) => {
        const o = { v: 0 };
        tl.to(o, { v: Number(el.dataset.rlCount || 0), duration: 1.0, ease: 'power2.out',
          onUpdate: () => { el.textContent = fmt(el, o.v); } }, t + 0.2);
      });

      /* self-heal: whatever the ticker's fate, the panel is guaranteed finished */
      const heal = () => {
        gsap.set(steps, { autoAlpha: 1, y: 0 });
        sparks.forEach((p) => gsap.set(p, { strokeDashoffset: 0 }));
        if (typeEl) typeEl.textContent = fullText;
        if (caret) gsap.set(caret, { autoAlpha: 0 });
        finalizeCounts(panel);
      };
      tl.eventCallback('onComplete', heal);
      panel._rlHeal = setTimeout(heal, 6000);
      panel._rlTl = tl;
    }

    /* ── stage selection ── */
    const select = (idx, focus, play) => {
      tabs.forEach((t, i) => {
        const on = i === idx;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.setAttribute('tabindex', on ? '0' : '-1');   // roving tabindex
      });
      panels.forEach((pl, i) => { pl.hidden = i !== idx; });
      if (focus) tabs[idx].focus();
      if (play) playViz(panels[idx]);
    };

    tabs.forEach((t, i) => {
      t.addEventListener('click', () => select(i, false, true));
      t.addEventListener('keydown', (e) => {
        const k = e.key;
        let next = -1;
        if (k === 'ArrowRight' || k === 'ArrowDown') next = (i + 1) % tabs.length;
        else if (k === 'ArrowLeft' || k === 'ArrowUp') next = (i - 1 + tabs.length) % tabs.length;
        else if (k === 'Home') next = 0;
        else if (k === 'End') next = tabs.length - 1;
        if (next < 0) return;
        e.preventDefault();
        select(next, true, true);
      });
    });

    /* ── entrance + first-viz trigger ── */
    if (reduce) {
      panels.forEach(finalizeCounts);
    } else {
      rl.classList.add('is-armed');
      const items = [...rl.querySelectorAll('[data-rl-in]')];
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          io.unobserve(e.target);
          const idx = items.indexOf(e.target);
          e.target.style.transitionDelay = (Math.max(0, idx) * 0.05) + 's';
          e.target.classList.add('is-in');
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -5%' });
      items.forEach((el) => io.observe(el));
      setTimeout(() => items.forEach((el) => el.classList.add('is-in')), 4000);

      /* play the default (Visibility) viz when the panel first enters view.
         IntersectionObserver is primary; a scroll/rect check is the fallback for
         environments where IO is flaky, and never force-finalizes an unseen
         panel prematurely. */
      let started = false;
      const start = () => { if (started) return; started = true; playViz(panels[0]); };
      const panelIO = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { panelIO.disconnect(); start(); } });
      }, { threshold: 0.2 });
      panelIO.observe(panels[0]);
      const onScroll = () => {
        const r = panels[0].getBoundingClientRect();
        const vh = window.innerHeight || document.documentElement.clientHeight;
        if (r.top < vh * 0.9 && r.bottom > 0) { window.removeEventListener('scroll', onScroll); start(); }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  }
</script>

<!-- ══════════ SECTION 3 — the sky (scroll-driven ground colour) ══════════
     Deliberately its OWN script block, importing nothing. It previously
     lived in the GSAP block above and was never reaching the browser: an
     unrelated null in that block's entrance loop threw, aborting every
     statement after it. The section's legibility depends on this ground
     being dark, so it must not share a failure domain with animation code. -->
<script>
  const sky = document.querySelector('.orl3__fade');
  const flowEl = document.querySelector('.orl3__flow');
  if (sky instanceof HTMLElement && flowEl instanceof HTMLElement) {
    const chapters = [...flowEl.querySelectorAll('[data-chapter]')];
    const rail = document.querySelector('[data-orl3-rail]');
    const intro = document.querySelector('.orl3__intro');
    /* the point where the intro's descent band is halfway down — past here
       the ground under the rail is dark enough to need the light palette */
    let darkStart = 0;
    const readVar = (el, n) => {
      const v = getComputedStyle(el).getPropertyValue(n).trim().replace('#', '');
      return [0, 2, 4].map((i) => parseInt(v.substr(i, 2), 16));
    };
    let bands = [];
    const measure = () => {
      if (intro) {
        const ir = intro.getBoundingClientRect();
        /* band is the intro's bottom 30% (see .orl3__intro::after) */
        darkStart = ir.bottom + window.scrollY - ir.height * 0.15;
      }
      bands = chapters.map((c) => {
        const r = c.getBoundingClientRect();
        return {
          top: r.top + window.scrollY,
          h: r.height,
          from: readVar(c, '--o3-from'),
          hold: readVar(c, '--o3-hold'),
          to: readVar(c, '--o3-to'),
          enter: parseFloat(getComputedStyle(c).getPropertyValue('--o3-enter')) || 50,
        };
      });
    };
    const mix = (a, b, t) => a.map((v, i) => Math.round(v + (b[i] - v) * t));
    const paint = () => {
      if (!bands.length) return;
      /* sample at the viewport centre — the tone the screen reads as "now" */
      const y = window.scrollY + window.innerHeight / 2;
      const first = bands[0], last = bands[bands.length - 1];
      let c;
      if (y <= first.top) c = first.from;
      else if (y >= last.top + last.h) c = last.to;
      else {
        const b = bands.find((b) => y >= b.top && y < b.top + b.h) || last;
        const f = ((y - b.top) / b.h) * 100;
        c = f < b.enter
          ? mix(b.from, b.hold, f / b.enter)
          : mix(b.hold, b.to, (f - b.enter) / (100 - b.enter));
      }
      sky.style.backgroundColor = `rgb(${c[0]}, ${c[1]}, ${c[2]})`;

      /* The rail is position:fixed and floats over both the cream intro and
         the dark run, so it has to swap palettes. Driving that from the
         ground colour we just computed is exact — an IntersectionObserver
         on the flow flipped it at the wrong moment, because the intro's
         own descent band goes dark before the flow starts. */
      if (rail) {
        const lin = (v) => { v /= 255; return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4); };
        const lum = 0.2126 * lin(c[0]) + 0.7152 * lin(c[1]) + 0.0722 * lin(c[2]);
        /* above the run the ground is the intro: light until its band falls */
        const darkGround = y >= darkStart && lum < 0.22;
        rail.classList.toggle('is-dark', darkGround);
      }
    };
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { paint(); ticking = false; });
    };
    const remeasure = () => { measure(); paint(); };
    measure();
    paint();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', remeasure);
    window.addEventListener('load', remeasure);
    /* chapter heights shift as fonts land and the demos lay out */
    if ('ResizeObserver' in window) new ResizeObserver(remeasure).observe(flowEl);
  }
</script>

</body>
