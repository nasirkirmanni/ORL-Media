---
import Seo from '../components/Seo.astro';
import { graph, organization, website } from '../lib/schema';

import '../styles/global.css';
import '../styles/revenue-leak.css';
import '../styles/mobile-home.css';
import { getCollection } from 'astro:content';

// ── The ORL Journal: featured posts for the Insights teaser ───
const journalPosts = (await getCollection('blog'))
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const CAT_COLOR: Record<string, string> = {
  'AI Search': '#8a5320',
  'Retention': '#b0532f',
  'Pipeline': '#279a58',
  'Market': '#a5824c',
  'Operations': '#6e6759',
};
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

// ── Three acts: Founder → Machine → Signal ────────────────────
// A person builds the machine; the machine makes you the answer.
const slides = [
  {
    key: 'founder',
    name: 'The Founder',
    index: 'Founder',
    orb: true,
    hero: {
      l1: 'Built for',
      l2: 'founders.',
      subL: 'Growth systems, content, and AI\nthat drive real results.',
      r1: 'AI Systems',
      r2: 'that work.',
      subR: 'Automate. Scale. Outperform.\nWe build what moves the needle.',
      tagline: 'アイデアを、システムに。\nシステムを、成長に。',
    },
  },
  {
    key: 'machine',
    name: 'The Machine',
    index: 'The Machine',
    metric: 'ACT TWO · THE MACHINE',
    titleL1: 'What we',
    titleL2: 'build,',
    dreamL1: 'Systems that',
    dreamL2: 'never sleep.',
    line: 'AI that works while you rest — outbound, buyer trust, and analytics in one engine.',
    actLabel: 'Act Two',
    actName: 'Built to Compound',
    img: '/p2.webp',
    imgW: 552,
    imgH: 1462,
  },
  {
    key: 'crew',
    name: 'The Crew',
    index: 'The Crew',
    metric: 'ACT THREE · THE CREW',
    titleL1: 'Growth needs',
    titleL2: 'a crew,',
    dreamL1: 'Operators,',
    dreamL2: 'not vendors.',
    line: 'Senior people who install the machine — and stay to run it.',
    actLabel: 'Act Three',
    actName: 'On Your Side',
    img: '/p3.webp',
    imgW: 1254,
    imgH: 1254,
    frame: true, // full-scene photo, shown framed & centered (not a cutout)
  },
];

// endless background: /bg-tile.webp is bg.png + mirrored copy (3530×891),
// so repeating it horizontally is always seamless
const TILE_ASPECT = 3530 / 891;


/* Section 2B — Revenue Leak Map.
   The four stages of the buyer journey where revenue leaks. Rail nodes are
   data-driven from here; each panel body is authored by hand below because the
   visualisations differ per stage. Accents are the AA-on-ivory variants.

   GROUNDING: the per-stage $ leak figures are an ILLUSTRATIVE split of a
   nominal $1M opportunity (marked as such in the UI). The metric-strip numbers
   inside each panel are the market figures already published elsewhere on this
   site / the engine pages — no new or fabricated research is introduced, and
   no "ORL Research — analysis of N answers" citation is claimed. */
const STAGES = [
  {
    key: 'visibility', n: '01', label: 'VISIBILITY', head: 'Get discovered',
    acc: '#2244bd', soft: '#eef1fb', href: '/engine/visibility',
    leak: '$540K', leakNote: 'invisible in AI answers',
    kicker: '01 / VISIBILITY', ph: 'Ranked, not recommended.',
    psub: 'Buyers discover the shortlist before they ever reach your website.',
    cta: 'Explore Visibility',
  },
  {
    key: 'signals', n: '02', label: 'SIGNALS', head: 'Find demand',
    acc: '#8a5a1e', soft: '#f5efe2', href: '/engine/signals',
    leak: '$430K', leakNote: 'not currently in-market',
    kicker: '02 / SIGNALS', ph: 'You meet them too late.',
    psub: 'Most of your market isn’t buying today — and nothing tells you which few are.',
    cta: 'Explore Signals',
  },
  {
    key: 'proof', n: '03', label: 'PROOF', head: 'Win the deal',
    acc: '#235c38', soft: '#e9f1ea', href: '/engine/proof',
    leak: '$250K', leakNote: 'deals stall in security & validation',
    kicker: '03 / PROOF', ph: 'The deal dies in silence.',
    psub: 'Pipeline doesn’t die at the top of the funnel. It stalls in security, procurement, and committee.',
    cta: 'Explore Proof',
  },
  {
    key: 'pricing', n: '04', label: 'PRICING', head: 'Monetize & expand',
    acc: '#1a5a60', soft: '#e6f0f0', href: '/engine/pricing',
    leak: '$150K', leakNote: 'expansion revenue left on the table',
    kicker: '04 / PRICING', ph: 'Growth stops at signature.',
    psub: 'Winning the deal is half the revenue. The other half never gets instrumented.',
    cta: 'Explore Pricing',
  },
];

const ld = graph([organization(), website()]);
import GlassNav from '../components/GlassNav.astro';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <Seo
    title="ORL Media — Inside the Growth Engine"
    description="ORL Media installs AI-powered growth systems for B2B SaaS and AI startups — discovery, demand, deals, and monetization in one engine, on one set of numbers."
    ogTitle="We don’t run your marketing. We install the machine."
    ogDescription="Growth infrastructure for B2B SaaS and AI companies: AI search visibility, buying-signal intelligence, deal-stage proof, and monetization — four systems on one layer of truth."
    image="/og/default.jpg"
  >
    <script type="application/ld+json" is:inline set:html={ld} />
  </Seo>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <!-- Inter 900 is requested for the pinned wordmark. Without it the browser
       synthesises a fake black from 600, which smears at 240px+. -->
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <!-- Switzer 900 (the pinned wordmark) is self-hosted — see @font-face in
       global.css. It is NOT requested here: api.fontshare.com currently answers
       with "Access to the Fontshare API has been temporarily restricted", so
       any face behind it silently never arrives. -->
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@600&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════
     MOBILE-ONLY HOMEPAGE (≤767px)
     Replaces the wheel-driven hero + heavy animated sections with a
     lean, natively-scrollable layout. Hidden on desktop via .m-only;
     the desktop sections below are hidden on mobile in mobile-home.css.
     ═══════════════════════════════════════════════════════════════ -->
<main id="main">
<section class="m-only mhero" aria-label="ORL Media">
  <p class="mhero__wordmark">ORL MEDIA</p>
  <p class="mhero__eye">Growth infrastructure for B2B SaaS &amp; AI startups</p>
  <h1 class="mhero__h1">We build the machine that grows your revenue.</h1>
  <p class="mhero__sub">We install AI-powered growth systems for B2B SaaS and AI startups &mdash; discovery, demand, deals, and monetization in one engine, on one set of numbers.</p>
  <div class="mhero__cta">
    <a class="mbtn mbtn--primary" href="/audit">Start with the Audit
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <a class="mbtn" href="/book">Book a call</a>
  </div>
  <p class="mhero__trust">Built for seed&ndash;Series B &middot; $1M&ndash;$20M ARR</p>
</section>

<section class="m-only mflow" aria-label="The Growth Engine">
  <p class="mflow__eye">One system. Four modules.</p>
  <h2 class="mflow__h2">Four systems.<br />One growth infrastructure.</h2>
  <div class="mflow__diagram">
    <ol class="mflow__row">
      <li style="--ca:#8a5320">Visibility<span>Get discovered</span></li>
      <li style="--ca:#9a6417">Signals<span>Find demand</span></li>
      <li style="--ca:#2f7d4c">Proof<span>Win the deal</span></li>
      <li style="--ca:#1f6b72">Pricing<span>Monetize</span></li>
    </ol>
    <div class="mflow__bar">
      <span class="mflow__bar-k">Metrics layer</span>
      <span class="mflow__bar-c">One set of numbers under all four</span>
    </div>
  </div>
</section>

<section class="m-only mprob" aria-label="What we solve">
  <p class="mprob__eye">What we solve</p>
  <h2 class="mprob__h2">Where B2B SaaS loses the revenue.</h2>
  <ul class="mprob__list">
    <li><span class="mprob__n">01</span><div><b>You&rsquo;re not in the AI answer.</b><p>Buyers ask ChatGPT before they ever search your name &mdash; and you&rsquo;re not the recommendation they get.</p></div></li>
    <li><span class="mprob__n">02</span><div><b>Outbound timed by luck, not signals.</b><p>You emailed 10,000 people and 120 replied, because 95% of them weren&rsquo;t buying this quarter.</p></div></li>
    <li><span class="mprob__n">03</span><div><b>Deals reach security review and go quiet.</b><p>Pipeline doesn&rsquo;t die at the top of the funnel. It dies in committee, in &ldquo;no decision.&rdquo;</p></div></li>
    <li><span class="mprob__n">04</span><div><b>Board-deck week, shaky numbers.</b><p>Four days building the deck and attribution still can&rsquo;t say what actually drove revenue.</p></div></li>
  </ul>
</section>

<section class="m-only msvc" aria-label="What we install">
  <p class="msvc__eye">The growth engine</p>
  <h2 class="msvc__h1">What we<br />install</h2>
  <p class="msvc__sub">Four systems. Install one &mdash; or all four.</p>
  <div class="msvc__grid">
    <a class="msvc__card" href="/engine/visibility" style="--ca:#8a5320; --soft:#f4ede1">
      <span class="msvc__tile"><img class="msvc__logo" src="/logos/visibility.webp" width="160" height="160" alt="" aria-hidden="true" loading="lazy" decoding="async" /></span>
      <span class="msvc__body">
        <span class="msvc__num">01 &middot; Get discovered</span>
        <h3 class="msvc__name">Visibility</h3>
        <p class="msvc__desc">Be the company AI search engines recommend &mdash; not just Google. We put you inside the answer and keep you there.</p>
      </span>
      <span class="msvc__chev" aria-hidden="true">&rsaquo;</span>
    </a>
    <a class="msvc__card" href="/engine/signals" style="--ca:#9a6417; --soft:#f6efe1">
      <span class="msvc__tile"><img class="msvc__logo" src="/logos/signals.webp" width="160" height="160" alt="" aria-hidden="true" loading="lazy" decoding="async" /></span>
      <span class="msvc__body">
        <span class="msvc__num">02 &middot; Find demand</span>
        <h3 class="msvc__name">Signals</h3>
        <p class="msvc__desc">Reach buyers the week they enter a buying window, with outreach written from real context &mdash; not spray-and-pray.</p>
      </span>
      <span class="msvc__chev" aria-hidden="true">&rsaquo;</span>
    </a>
    <a class="msvc__card" href="/engine/proof" style="--ca:#2f7d4c; --soft:#e9f2ec">
      <span class="msvc__tile"><img class="msvc__logo" src="/logos/proof.webp" width="160" height="160" alt="" aria-hidden="true" loading="lazy" decoding="async" /></span>
      <span class="msvc__body">
        <span class="msvc__num">03 &middot; Win the deal</span>
        <h3 class="msvc__name">Proof</h3>
        <p class="msvc__desc">Arm the buying committee with third-party evidence that unsticks deals stalled in security review and no-decision.</p>
      </span>
      <span class="msvc__chev" aria-hidden="true">&rsaquo;</span>
    </a>
    <a class="msvc__card" href="/engine/pricing" style="--ca:#1f6b72; --soft:#e6f1f1">
      <span class="msvc__tile"><img class="msvc__logo" src="/logos/pricing.webp" width="160" height="160" alt="" aria-hidden="true" loading="lazy" decoding="async" /></span>
      <span class="msvc__body">
        <span class="msvc__num">04 &middot; Monetize &amp; expand</span>
        <h3 class="msvc__name">Pricing</h3>
        <p class="msvc__desc">Turn packaging, usage, and expansion into revenue you can forecast &mdash; the other half of growth, at half the CAC.</p>
      </span>
      <span class="msvc__chev" aria-hidden="true">&rsaquo;</span>
    </a>
  </div>
</section>

<div class="stage" id="stage" data-count={slides.length}>

  <!-- ══════════ ENDLESS BACKGROUND (one continuous world) ══════════ -->
  <div class="bg" aria-hidden="true">
    <div class="bg__track" data-bg-track>
      <img class="bg__tile" src="/bg-tile.webp" alt="" width="3530" height="891" />
      <img class="bg__tile" src="/bg-tile.webp" alt="" width="3530" height="891" />
      <img class="bg__tile" src="/bg-tile.webp" alt="" width="3530" height="891" />
    </div>
  </div>

  <!-- ══════════ SLIDES (horizontal curtain slider) ══════════ -->
  <div class="slides">
    {slides.map((s, i) => (
      <div class="slide" data-slide={i}>
        <div class="slide__panel" data-panel>
          <div class="slide__inner" data-inner>

            {s.orb && (
              <div class="person person--orb" aria-hidden="true">
                <div class="orb">
                  <span class="orb__glow"></span>
                  <svg class="orb__svg" viewBox="0 0 440 440" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                      <radialGradient id="orbCore" cx="50%" cy="42%" r="60%">
                        <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
                        <stop offset="32%" stop-color="#f3e9d6" stop-opacity="0.78" />
                        <stop offset="66%" stop-color="#b89264" stop-opacity="0.28" />
                        <stop offset="100%" stop-color="#000000" stop-opacity="0" />
                      </radialGradient>
                      <linearGradient id="orbPulse" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.18" />
                        <stop offset="55%" stop-color="#fbf3e2" stop-opacity="0.72" />
                        <stop offset="100%" stop-color="#ffffff" stop-opacity="1" />
                      </linearGradient>
                    </defs>
                    <circle class="orb__core" cx="220" cy="200" r="58" fill="url(#orbCore)" />
                    <g class="orb__ring orb__ring--1" transform="rotate(18 220 200)">
                      <ellipse cx="220" cy="200" rx="186" ry="66" stroke="rgba(255,255,255,0.3)" stroke-width="1.2" />
                      <ellipse cx="220" cy="200" rx="186" ry="66" stroke="url(#orbPulse)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="46 900" class="orb__pulse orb__pulse--1" />
                    </g>
                    <g class="orb__ring orb__ring--2" transform="rotate(-32 220 200)">
                      <ellipse cx="220" cy="200" rx="150" ry="122" stroke="rgba(255,255,255,0.28)" stroke-width="1.2" />
                      <ellipse cx="220" cy="200" rx="150" ry="122" stroke="url(#orbPulse)" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="42 950" class="orb__pulse orb__pulse--2" />
                    </g>
                    <g class="orb__ring orb__ring--3" transform="rotate(74 220 200)">
                      <ellipse cx="220" cy="200" rx="202" ry="44" stroke="rgba(255,255,255,0.26)" stroke-width="1.1" />
                      <ellipse cx="220" cy="200" rx="202" ry="44" stroke="url(#orbPulse)" stroke-width="2.1" stroke-linecap="round" stroke-dasharray="40 940" class="orb__pulse orb__pulse--3" />
                    </g>
                  </svg>
                  <span class="orb__lbl orb__lbl--tl">Visibility</span>
                  <span class="orb__lbl orb__lbl--tr">Signals</span>
                  <span class="orb__lbl orb__lbl--bl">Pricing</span>
                  <span class="orb__lbl orb__lbl--br">Proof</span>
                </div>
              </div>
            )}

            {s.img && !s.frame && (
              <div class="person" style={s.size ? `height:${s.size * 100}dvh` : undefined}>
                <img src={s.img} alt="" width={s.imgW} height={s.imgH} loading="eager" decoding="async" />
              </div>
            )}

            {s.frame && (
              <div class="photo">
                <img src={s.img} alt="" width={s.imgW} height={s.imgH} loading="eager" decoding="async" />
              </div>
            )}

            {s.card && (
              <div class="answer">
                <div class="chat">
                  <div class="chat__head">
                    <span class="chat__avatar" aria-hidden="true"></span>
                    <div class="chat__who">
                      <span class="chat__name">The Market</span>
                      <span class="chat__status"><i class="chat__online" aria-hidden="true"></i>online now</span>
                    </div>
                  </div>
                  <div class="chat__thread">
                    <div class="bubble bubble--me">who actually builds growth systems for AI startups?</div>
                    <div class="bubble bubble--them">ORL Media.</div>
                    <div class="bubble bubble--me">and if I just wing it?</div>
                    <div class="bubble bubble--them">bold. your competitor already called them.</div>
                    <div class="bubble bubble--them bubble--typing" aria-hidden="true">
                      <span></span><span></span><span></span>
                    </div>
                  </div>
                </div>
              </div>
            )}

          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- ══════════ TEXT OVERLAYS (crossfade, mirrored by parity) ══════════ -->
  {slides.map((s, i) => (
    <div class={`overlay ${i % 2 === 0 ? 'overlay--a' : 'overlay--b'} ${s.hero ? 'overlay--hero' : ''} ${s.frame ? 'overlay--frame' : ''}`} data-overlay={i}>
      {s.hero ? (
        <>
          <div class="overlay__title">
            <p class="t-serif t-line1">{s.hero.l1}</p>
            <p class="t-serif t-line2">{s.hero.l2}</p>
            <p class="overlay__subL">
              {s.hero.subL.split('\n').map((ln, k) => <>{k > 0 && <br />}{ln}</>)}
            </p>
          </div>
          <div class="overlay__dreams overlay__dreams--hero">
            <p class="t-serif d-line1">{s.hero.r1}</p>
            <p class="t-serif d-line2">{s.hero.r2}</p>
            <p class="overlay__sub">
              {s.hero.subR.split('\n').map((ln, k) => <>{k > 0 && <br />}{ln}</>)}
            </p>
          </div>
        </>
      ) : (
        <>
          <div class="overlay__title">
            <p class="t-serif t-line1">{s.titleL1}</p>
            <p class="t-serif t-line2"><em>{s.titleL2}</em></p>
            <p class="t-serif t-num">{String(i + 1).padStart(2, '0')}</p>
          </div>
          <p class="overlay__metric">{s.metric}</p>
          <div class="overlay__dreams">
            <p class="t-serif d-line1">{s.dreamL1}</p>
            <p class="t-serif d-line2"><em>{s.dreamL2}</em></p>
            <p class="overlay__sub">{s.line}</p>
          </div>
          <div class="overlay__info">
            <p class="info-label">{s.actLabel}</p>
            <p class="info-cat">{s.name}</p>
            <p class="info-name">{s.actName}</p>
          </div>
        </>
      )}
    </div>
  ))}

  <!-- ══════════ FIXED CHROME ══════════ -->
  <header class="chrome-top">
    <a class="brand" href="/">
      <span class="brand__mark" aria-hidden="true"></span>
      ORL
    </a>
    <nav class="menu" aria-label="Primary">
      <div class="menu__col">
        <a href="/engine" class="menu__link">Services</a>
        <a href="/about" class="menu__link">About us</a>
        <a href="#" class="menu__link">Contact</a>
      </div>
    </nav>
<GlassNav />
    <div class="chrome-top__right">
      <a class="pill" href="/book">Book a call <span class="pill__dot" aria-hidden="true"></span></a>
    </div>
  </header>

  <footer class="chrome-bottom">
    <nav class="index" aria-label="Modules">
      {slides.map((s, i) => (
        <button class={`index__item ${i === 0 ? 'is-active' : ''}`} data-index={i}>
          <span class="index__dot" aria-hidden="true"></span>
          <span class="index__num">{String(i + 1).padStart(2, '0')}</span>
          <span class="index__sep">|</span>
          <span class="index__name">{s.name}</span>
        </button>
      ))}
    </nav>
    <div class="marquee" aria-hidden="true">
      <div class="marquee__track">
        <span>SCROLL TO EXPLORE&ensp;·&ensp;</span><span>SCROLL TO EXPLORE&ensp;·&ensp;</span>
        <span>SCROLL TO EXPLORE&ensp;·&ensp;</span><span>SCROLL TO EXPLORE&ensp;·&ensp;</span>
      </div>
    </div>
  </footer>

  <!-- film grain -->
  <div class="grain" aria-hidden="true"></div>
</div>

<!-- ══════════ SITE NAV (fixed; appears after leaving the hero) ══════════ -->
<nav class="sitenav" data-sitenav aria-label="Site">
  <a class="sitenav__brand" href="/">
    <span class="sitenav__mark" aria-hidden="true"></span>
    ORL
  </a>
  <div class="sitenav__links">
    <a href="/engine" class="sitenav__link">Services</a>
    <a href="/audit" class="sitenav__link">Audit</a>
    <a href="/about" class="sitenav__link">About us</a>
    <a href="/results" class="sitenav__link">Case Studies</a>
    <a href="/blog" class="sitenav__link">Blog</a>
    <a href="#" class="sitenav__link">Pricing</a>
  </div>
  <a class="sitenav__pill" href="/book">Book a call</a>
</nav>

<!-- ══════════ SECTION — GROWTH INFRASTRUCTURE (3D floating dashboard) ══════════ -->
<!-- ══════════ PINNED SCENE + WORDMARK PASS ══════════
     The card scene holds still while ORL MEDIA travels up through it, and the
     page only moves on once the wordmark has cleared the top. .s3dpin is the
     scroll track — its extra height IS the pin duration — and .s3d itself is
     what sticks, so #infra stays on the section and the hero handoff that
     targets it is untouched. -->
<div class="s3dpin">
<section class="s3d" id="infra" aria-label="Growth infrastructure">
  <!-- Decorative: the page says ORL Media in the nav and the <title>, so the
       wordmark stays out of the accessibility tree. -->
  <div class="s3dmark" aria-hidden="true" data-s3dmark>
    <span class="s3dmark__text">ORL MEDIA</span>
  </div>
  <div class="s3d__canvas">

    <!-- the suspended card scene (full-bleed floating wall) -->
    <div class="s3d__scene" data-s3d-scene>

      <!-- 1 · AI SEARCH (ChatGPT) -->
      <article class="s3dcard s3dcard--ai" data-s3d-card data-depth="0.85" data-hs="1.02" data-float>
        <div class="s3dcard__par"><div class="s3dcard__float"><div class="s3dcard__body" data-s3d-body>
          <div class="s3dai__head">
            <span class="s3dai__logo" aria-hidden="true">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.9 2.9M15.5 15.5l2.9 2.9M18.4 5.6l-2.9 2.9M8.5 15.5l-2.9 2.9"/></svg>
            </span>
