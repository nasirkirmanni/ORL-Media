<script>
  import { gsap } from 'gsap';
  import { Observer } from 'gsap/Observer';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  gsap.registerPlugin(Observer, ScrollTrigger);

  const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── smooth momentum scrolling (Lenis) ─────────────────────────
  // Damps the wheel so the page glides instead of snapping. Kept in sync with
  // GSAP ScrollTrigger (pinned vapor bridge + section reveals) via the raf +
  // scroll hooks. Disabled for reduced-motion and left off on touch (native
  // touch scroll feels better on phones). While the hero owns the wheel it's
  // paused; it resumes the moment the hero hands off to the page.
  let lenis: Lenis | null = null;
  /* Native momentum scroll on touch devices beats pumping Lenis' rAF every
     frame; the hero handoff below is fully null-guarded for a missing lenis. */
  if (!REDUCED && !window.matchMedia('(hover: none) and (pointer: coarse)').matches) {
    lenis = new Lenis({
      // Both were set BELOW Lenis' own defaults (lerp 0.1, wheelMultiplier 1),
      // which is what made the page feel heavy: each notch travelled less than
      // a native scroll AND took longer to settle. Now above default on both.
      lerp: 0.13,            // higher = catches up faster, less float
      wheelMultiplier: 1.15, // more distance per wheel notch
      smoothWheel: true,
      touchMultiplier: 1,
    });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => lenis!.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);
    lenis.stop();            // hero owns the wheel until it hands off
  }

  // smooth in-page anchor jumps too (CTAs like "#section3")
  if (lenis) {
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.getAttribute('href');
        if (!id || id === '#') return;
        const target = document.querySelector(id);
        if (!target) return;
        e.preventDefault();
        lenis!.scrollTo(target as HTMLElement, { offset: 0, duration: 0.9 });
      });
    });
  }

  const panels = gsap.utils.toArray<HTMLElement>('[data-panel]');
  const inners = gsap.utils.toArray<HTMLElement>('[data-inner]');
  const overlays = gsap.utils.toArray<HTMLElement>('[data-overlay]');
  const indexItems = gsap.utils.toArray<HTMLElement>('[data-index]');
  const COUNT = panels.length;

  let current = 0;
  let animating = false;
  let coolUntil = 0;               // cooldown so momentum can't chain slides
  const COOLDOWN = 480;            // ms of quiet required after each transition

  // initial state: slide 0 in place, the rest staged right (curtain closed)
  panels.forEach((p, i) => gsap.set(p, { xPercent: i === 0 ? 0 : 100 }));
  inners.forEach((el, i) => gsap.set(el, { xPercent: i === 0 ? 0 : -50 }));
  overlays.forEach((o, i) => gsap.set(o, { opacity: i === 0 ? 1 : 0 }));

  // endless background: pans with each transition, wraps seamlessly.
  // The tile is bg + mirrored bg, so wrapping by one tile width is invisible.
  const bgTrack = document.querySelector<HTMLElement>('[data-bg-track]');
  const TILE_AR = 3530 / 891;
  const tileW = () => TILE_AR * window.innerHeight;
  const BG_PAN = () => window.innerWidth * 0.35; // parallax: world moves slower than the curtain
  let bgX = 0;
  if (bgTrack) gsap.set(bgTrack, { x: 0 });

  function wrapBg() {
    if (!bgTrack) return;
    bgX = gsap.utils.wrap(-tileW(), 0, bgX);
    gsap.set(bgTrack, { x: bgX });
  }

  function setIndex(i: number) {
    indexItems.forEach((el, j) => el.classList.toggle('is-active', j === i));
  }

  function goto(next: number, dir: 1 | -1) {
    if (animating || next < 0 || next > COUNT - 1 || next === current) return;
    animating = true;

    const outP = panels[current], outI = inners[current], outO = overlays[current];
    const inP = panels[next], inI = inners[next], inO = overlays[next];

    setIndex(next);

    if (REDUCED) {
      gsap.set(outP, { xPercent: -dir * 100 });
      gsap.set(outI, { xPercent: dir * 50 });
      gsap.set(outO, { opacity: 0 });
      gsap.set(inP, { xPercent: 0 });
      gsap.set(inI, { xPercent: 0 });
      gsap.set(inO, { opacity: 1 });
      // reduced motion: the cutout is placed, never travels
      gsap.set(inI.querySelectorAll('.person'), { yPercent: 0, xPercent: -50, opacity: 1 });
      if (bgTrack) {
        bgX -= dir * BG_PAN();
        wrapBg();
      }
      current = next;
      animating = false;
      coolUntil = performance.now() + COOLDOWN;
      return;
    }

    const tl = gsap.timeline({
      defaults: { duration: 0.75, ease: 'power3.inOut' },
      onComplete() {
        coolUntil = performance.now() + COOLDOWN;
        wrapBg(); // invisible modulo-snap once the pan settles
        current = next;
        animating = false;
      },
    });

    // world pans with the curtain (parallax fraction, direction-aware)
    if (bgTrack) {
      bgX -= dir * BG_PAN();
      tl.to(bgTrack, { x: bgX }, 0);
    }

    // curtain: panels slide, inner content counter-slides (the reveal)
    tl.fromTo(inP, { xPercent: dir * 100 }, { xPercent: 0 }, 0)
      .fromTo(inI, { xPercent: -dir * 50 }, { xPercent: 0 }, 0)
      .to(outP, { xPercent: -dir * 100 }, 0)
      .to(outI, { xPercent: dir * 50 }, 0);

    /* The cutout rises into frame as the curtain lands, instead of arriving
       flat with the panel. It runs longer than the 0.75s curtain and starts
       slightly late, so the figure is still settling after the slide has
       stopped — that lag is what makes it read as rising rather than sliding.
       Always upward regardless of direction: this is an entrance, not a
       mirror of the scroll.

       xPercent is pinned at -50 in BOTH keyframes because .person is centred
       with a CSS translateX(-50%); once GSAP owns the transform, omitting it
       here would drop the centring and jump the figure sideways. */
    const inPerson = inI.querySelector<HTMLElement>('.person');
    if (inPerson) {
      tl.fromTo(
        inPerson,
        { yPercent: 20, xPercent: -50, opacity: 0.65 },
        { yPercent: 0, xPercent: -50, opacity: 1, duration: 1.05, ease: 'power2.out' },
        0.06,
      );
    }

    tl
      // text rides the curtain: drift shares the panel's ease and duration,
      // only opacity crossfades on top — no rhythm mismatch, no pop
      .to(outO, { x: -dir * 60 }, 0)
      .to(outO, { opacity: 0, duration: 0.4, ease: 'sine.in' }, 0)
      .fromTo(inO, { x: dir * 60 }, { x: 0 }, 0)
      .fromTo(
        inO,
        { opacity: 0 },
        { opacity: 1, duration: 0.5, ease: 'sine.out' },
        0.25,
      );
  }

  // ── hero → page scroll handoff (REVERSIBLE) ───────────────────
  // While locked, the hero owns the wheel (Observer preventDefault) and the
  // slides step forward/back. On the last slide, scrolling forward RELEASES
  // to native scroll and glides into the first page section. When the visitor
  // scrolls all the way back to the very top, the hero RE-ARMS so the slides
  // are reversible — the earlier "one-way" version left you frozen on the
  // last hero image with no way back. A short guard after release prevents
  // the release scroll from instantly re-locking (the old freeze trap).
  const afterHero = document.getElementById('infra');
  /* Mobile (≤767px) has no hero slideshow — a new single hero replaces it in
     the layout and .stage is display:none. Never arm the wheel/touch hijack or
     the document lock there, or the page would be frozen behind a hidden hero.
     Width-based so it stays in lockstep with the mobile-redesign CSS. */
  const HERO_OFF = window.matchMedia('(max-width: 767px)').matches;
  let heroLocked = !HERO_OFF;
  let relockGuard = 0;             // suppress re-lock until this timestamp

  /* The document-level half of the lock. The Observer below only intercepts
     wheel/touch/pointer; this is what stops every OTHER way a page can be
     scrolled (scrollbar drag, track click, autoscroll, find-in-page, browser
     scroll restoration). Without it the page could slide past hero 1 while
     the slider was still on slide 0, and the re-arm listener — which bails
     when heroLocked is true — would never resync it. */
  /* Measure the scrollbar before the first lock, while the document is still
     in its normal scrolling state — see --sbw in global.css. */
  document.documentElement.style.setProperty(
    '--sbw', (window.innerWidth - document.documentElement.clientWidth) + 'px',
  );

  function setDocScroll(locked: boolean) {
    document.documentElement.classList.toggle('hero-locked', locked);
  }
  /* NB: the lock is armed further down, only once the Observer that can
     release it exists. Locking here would mean any error in between left the
     page permanently unscrollable with no way out. */

  function releaseHero() {
    if (!heroLocked) return;
    heroLocked = false;
    relockGuard = performance.now() + 1300;   // don't re-lock during the glide down
    obs.disable();
    setDocScroll(false);           // give the document its scroll back first
    if (lenis) {
      lenis.start();
      /* Toggling document overflow changes the scroll geometry Lenis caches,
         so recompute it before asking Lenis to scroll into that geometry. */
      lenis.resize();
      lenis.scrollTo(afterHero!, { duration: 0.85 });
    } else {
      window.scrollTo({ top: afterHero!.offsetTop, behavior: 'smooth' });
    }
  }

  /* Release WITHOUT the glide. releaseHero() assumes the visitor is finishing
     the hero and animates them down to #infra; this is for the case where they
     are already somewhere else entirely and simply need the lock taken off. */
  function forceRelease() {
    if (!heroLocked) return;
    heroLocked = false;
    relockGuard = performance.now() + 800;
    obs.disable();
    setDocScroll(false);
    lenis?.start();
    lenis?.resize();          // overflow just changed; Lenis caches geometry
  }

  function relockHero() {
    if (heroLocked || HERO_OFF) return;
    heroLocked = true;
    animating = false;             // clear any stale transition state
    coolUntil = performance.now() + COOLDOWN;
    lenis?.stop();                 // hand the wheel back to the hero
    setDocScroll(true);
    obs.enable();
  }

  // wheel / touch / pointer drive (GSAP Observer)
  const obs = Observer.create({
    target: window,
    type: 'wheel,touch,pointer',
    wheelSpeed: -1,
    tolerance: 10,
    preventDefault: true,
    // with wheelSpeed:-1, wheel-down / swipe-up fire onUp → forward
    onUp: () => {
      if (performance.now() < coolUntil) return;   // ignore momentum after a slide
      if (current < COUNT - 1) goto(current + 1, 1); else releaseHero();
    },
    onDown: () => {
      if (performance.now() < coolUntil) return;
      if (current > 0) goto(current - 1, -1);
    },
  });

  // the Observer that releases the lock now exists, so it is safe to lock —
  // but on mobile the hero is off: disable the interceptor and never lock.
  if (HERO_OFF) obs.disable();
  else setDocScroll(true);

  // if the browser restored a mid-page scroll position (reload / back-nav),
  // the visitor is NOT at the hero — never hijack their wheel in that case
  function syncToRestoredScroll() {
    if (window.scrollY > 2 && heroLocked) {
      heroLocked = false;
      obs.disable();
      setDocScroll(false);
      lenis?.start();             // smooth scrolling active straight away
    }
  }
  syncToRestoredScroll();

  /* Chrome restores scroll position asynchronously — often AFTER this script
     runs — so the synchronous check above can read 0 on a reload that is
     actually mid-page. Taking scroll restoration into our own hands removes
     the race entirely: we decide where the page starts. 'load' is a
     belt-and-braces resync for engines that restore on their own schedule. */
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  window.addEventListener('load', syncToRestoredScroll);

  /* Desync guard. The `hero-locked` class and the heroLocked flag must never
     disagree: the flag decides behaviour, the class decides whether the whole
     document has overflow:hidden. If anything ever leaves the class applied
     while the hero is not actually locked, every sticky section on the page
     dies silently and there is no error to find. Reconcile instead of
     trusting — this costs one check and closes the entire failure class. */
  function reconcileLock() {
    const stuck = !heroLocked
      && document.documentElement.classList.contains('hero-locked');
    if (stuck) setDocScroll(false);
  }
  window.addEventListener('load', reconcileLock);
  setTimeout(reconcileLock, 1500);

  // re-arm the hero once the visitor scrolls back to the very top, so the
  // slides can be scrolled through in reverse (fixes the "stuck on the last
  // hero image" trap). The guard blocks re-locking during a release glide.
  window.addEventListener('scroll', () => {
    if (heroLocked) {
      /* A LARGE jump is not drift. It is a visitor who genuinely left the hero
         by a route the Observer never saw — scrollbar drag, keyboard, an
         in-page anchor, or scroll restoration that landed after our sync.
         Snapping them back to 0 fights them, and leaving the lock on is worse
         than that: `html.hero-locked` puts overflow:hidden on <html> AND
         <body>, and a non-visible overflow on an ancestor silently kills
         position:sticky for every pinned section below. That is what breaks
         the 3D scene's pin and takes the rising ORL MEDIA wordmark with it —
         the wordmark still travels, but the scene slides out from under it.
         So: release rather than snap back. */
      if (window.scrollY > window.innerHeight * 0.75) { forceRelease(); return; }
      /* Small drift with the hero genuinely on screen — correct it, as before. */
      if (window.scrollY > 0) window.scrollTo(0, 0);
      return;
    }
    if (window.scrollY <= 1 && performance.now() > relockGuard) relockHero();
  }, { passive: true });

  // keyboard (only while the hero is locked; otherwise native keys scroll)
  window.addEventListener('keydown', (e) => {
    if (!heroLocked) return;
    if (['ArrowRight', 'ArrowDown', 'PageDown', ' '].includes(e.key)) {
      if (current < COUNT - 1) goto(current + 1, 1); else releaseHero();
    }
    if (['ArrowLeft', 'ArrowUp', 'PageUp'].includes(e.key)) {
      if (current > 0) goto(current - 1, -1);
    }
  });

  // index click
  indexItems.forEach((el) => {
    el.addEventListener('click', () => {
      const i = Number(el.dataset.index);
      goto(i, i > current ? 1 : -1);
    });
  });

  // dev-only hook for automated handoff verification
  if (import.meta.env.DEV) {
    (window as any).__hero = {
      release: releaseHero,
      lenis,
      state: () => ({ heroLocked, current, scrollY: Math.round(window.scrollY) }),
    };
  }

</script>

<!-- ══════════ SITE NAV visibility driver ══════════ -->
<script>
  const sitenav = document.querySelector<HTMLElement>('[data-sitenav]');
  if (sitenav) {
    // hidden over the hero (which carries its own chrome); slides in once the
    // visitor is genuinely in the page sections, back out on return to top
    const onScroll = () =>
      sitenav.classList.toggle('is-visible', window.scrollY > window.innerHeight * 0.5);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
