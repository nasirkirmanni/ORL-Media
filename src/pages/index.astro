    }, { threshold: 0.3 }).observe(prRoot);

    /* failsafe — a static dashboard beats an empty one */
    gsap.delayedCall(4, () => {
      if (intro.progress() > 0) return;
      const r = prRoot.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) intro.progress(1).pause();
    });
    setTimeout(() => {
      if (intro.progress() === 0 && intro.totalTime() === 0) intro.progress(1).pause();
    }, 8000);

    if (import.meta.env.DEV) {
      (window as any).__pr = { intro, loops, gsap };
    }
  }
</script>

<!-- ══════════ THE METRICS LAYER — substrate animation ══════════ -->
<script>
  import { gsap } from 'gsap';

  /* The layer is not an app demo, so its motion language is different from
     the four chapters: no cursor, no window, no dashboard assembly theatre.
     Data drains INTO it (conduit pulses), the strip breathes (value drift),
     and the intelligence line retypes. Calm, continuous, substrate-like. */
  const ml = document.querySelector<HTMLElement>('.mlayer');
  const mlReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (ml && !mlReduce) {
    const q = (sel: string) => ml.querySelector<HTMLElement>(sel)!;
    const qa = (sel: string) => [...ml.querySelectorAll<HTMLElement>(sel)];

    const heads = qa('[data-ml-in]');
    const ports = qa('[data-ml-port]');
    const lines = qa('[data-ml-line]');
    const pulses = qa('[data-ml-pulse]');
    const tiles = qa('[data-ml-tile]');
    const intel = q('[data-ml-intel]');
    const insight = q('[data-ml-insight]');
    const caret = q('[data-ml-caret]');

    const count = (tl: gsap.core.Timeline, el: Element, from: number, to: number,
                   fmt: (v: number) => string, dur: number, pos: gsap.Position) => {
      const p = { v: from };
      tl.fromTo(p, { v: from }, {
        v: to, duration: dur, ease: 'power2.out',
        onUpdate: () => { el.textContent = fmt(Math.round(p.v)); },
      }, pos);
    };

    /* ── entrance: the layer receives, then reports ── */
    const intro = gsap.timeline({ paused: true, defaults: { ease: 'power2.out' } });
    intro
      .set(heads, { autoAlpha: 0, y: 14 }, 0)
      .set(ports, { autoAlpha: 0, y: -10 }, 0)
      .set(lines, { scaleY: 0, transformOrigin: '50% 0%' }, 0)
      .set(tiles, { autoAlpha: 0, y: 16 }, 0)
      .set(intel, { autoAlpha: 0, y: 12 }, 0);

    intro.to(heads, { autoAlpha: 1, y: 0, duration: 0.6, stagger: 0.12 }, 0.1)
      .to(ports, { autoAlpha: 1, y: 0, duration: 0.45, stagger: 0.09 }, 0.5)
      .to(lines, { scaleY: 1, duration: 0.55, stagger: 0.09, ease: 'power2.inOut' }, 0.75)
      .to(tiles, { autoAlpha: 1, y: 0, duration: 0.5, stagger: 0.08 }, 1.1);
    count(intro, q('[data-ml-v1]'), 38, 61, (v) => `${v}%`, 1.0, 1.3);
    count(intro, q('[data-ml-v2]'), 180, 284, (v) => `$${v}K`, 1.0, 1.38);
    count(intro, q('[data-ml-v3]'), 31, 22, (v) => `${v}%`, 1.0, 1.46);
    count(intro, q('[data-ml-v4]'), 101, 114, (v) => `${v}%`, 1.0, 1.54);
    count(intro, q('[data-ml-v5]'), 15, 11, (v) => `${v} mo`, 1.0, 1.62);
    count(intro, q('[data-ml-v6]'), 33, 47, (v) => `${v}`, 1.0, 1.7);
    intro.to(intel, { autoAlpha: 1, y: 0, duration: 0.55 }, 2.0);
    intro.timeScale(1.25);

    /* ── loop 1 · pulses drain down the four conduits, staggered ── */
    const pulseLoop = gsap.timeline({ paused: true, repeat: -1 });
    pulses.forEach((pu, i) => {
      pulseLoop.fromTo(pu, { y: -6, autoAlpha: 0 },
        { y: 34, autoAlpha: 1, duration: 0.9, ease: 'power1.in',
          onComplete: () => gsap.set(pu, { autoAlpha: 0 }) }, i * 0.55);
    });
    pulseLoop.to({}, { duration: 1.6 });

    /* ── loop 2 · a receiving glow crosses the strip as pulses land ── */
    const glowLoop = gsap.timeline({ paused: true, repeat: -1, repeatDelay: 2.2 });
    tiles.forEach((t, i) => {
      glowLoop.to(t, { borderColor: 'rgba(255,255,255,0.28)', duration: 0.3, ease: 'power1.out' }, i * 0.14)
        .to(t, { borderColor: 'rgba(255,255,255,0.1)', duration: 0.7, ease: 'power1.in' }, i * 0.14 + 0.3);
    });

    /* ── loop 3 · the intelligence line retypes, crediting each module ── */
    const INSIGHTS = [
      'Pipeline grew 24% this month. Largest driver: 14 accounts Signals flagged after funding and hiring events.',
      'Security reviews are closing 8 days faster since Proof shipped the trust center and questionnaire kit.',
      'NRR reached 114%. Pricing’s expansion plays converted 7 usage-ready accounts to annual plans.',
      'Share of Answer rose 12 points — Visibility’s citations now surface in 3 of 5 category questions.',
    ];
    let ii = 0;
    const typeLoop = gsap.timeline({ paused: true, repeat: -1 });
    typeLoop
      .to({}, { duration: 5.2 })
      .call(() => caret.classList.add('is-on'))
      .to(insight, { autoAlpha: 0, duration: 0.4, ease: 'power1.in' })
      .call(() => {
        ii = (ii + 1) % INSIGHTS.length;
        insight.textContent = '';
        gsap.set(insight, { autoAlpha: 1 });
        const text = INSIGHTS[ii];
        const p = { n: 0 };
        gsap.to(p, {
          n: text.length, duration: 1.9, ease: 'none',
          onUpdate: () => { insight.textContent = text.slice(0, Math.round(p.n)); },
          onComplete: () => caret.classList.remove('is-on'),
        });
      })
      .to({}, { duration: 2.4 });

    const loops = [pulseLoop, glowLoop, typeLoop];

    intro.seek(0.001).pause();

    let started = false;
    new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        intro.play();
        if (!started) {
          started = true;
          loops.forEach((l, i) => gsap.delayedCall(2.2 + i * 0.5, () => l.play()));
        } else {
          loops.forEach((l) => l.play());
        }
      } else {
        loops.forEach((l) => l.pause());
      }
    }, { threshold: 0.25 }).observe(ml);

    /* failsafe — never leave the layer dark AND empty */
    gsap.delayedCall(4, () => {
      if (intro.progress() > 0) return;
      const r = ml.getBoundingClientRect();
      if (r.top < window.innerHeight && r.bottom > 0) intro.progress(1).pause();
    });
    setTimeout(() => {
      if (intro.progress() === 0 && intro.totalTime() === 0) intro.progress(1).pause();
    }, 8000);

    if (import.meta.env.DEV) {
      (window as any).__ml = { intro, loops, gsap };
    }
  }
</script>

<!-- ══════════ WHY ORL MEDIA — the stop-paying experiment ══════════ -->
<script>
  import { gsap } from 'gsap';

  /* Resting markup shows the month-13 outcome (switch on, divergence drawn)
     so no-JS and reduced-motion readers get the argument statically. With
     motion, we rewind to "still paying", then run the experiment on a loop —
     until the visitor touches the switch, at which point it's theirs. */
  const why = document.querySelector<HTMLElement>('.why');
  const whyReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (why) {
    const q = (sel: string) => why.querySelector<HTMLElement>(sel)!;
    const qa = (sel: string) => [...why.querySelectorAll<HTMLElement>(sel)];
    const sw = q('[data-why-switch]');
    const stopSeg = why.querySelector<SVGGeometryElement>('[data-why-stop]')!;
    const keepSeg = why.querySelector<SVGGeometryElement>('[data-why-keep]')!;
    const flagStop = q('[data-why-flag-stop]');
    const flagKeep = q('[data-why-flag-keep]');
    const agencyRows = qa('.why__panel--agency [data-why-row]');
    let checked = true;

    const setChecked = (v: boolean) => { checked = v; sw.setAttribute('aria-checked', String(v)); };

    if (whyReduce) {
      /* reduced motion: keep the resting after-state, make the switch an
         instant toggle, and never autoplay */
      const apply = () => {
        const on = checked ? 1 : 0;
        [stopSeg, keepSeg].forEach((s) => { (s as any).style.opacity = `${on}`; });
        flagStop.style.opacity = `${on}`;
        flagKeep.style.opacity = `${on}`;
      };
      sw.addEventListener('click', () => { setChecked(!checked); apply(); });
    } else {
      const stopLen = stopSeg.getTotalLength();
      const keepLen = keepSeg.getTotalLength();

      /* rewind to the "still paying" state */
      gsap.set(stopSeg, { strokeDasharray: stopLen, strokeDashoffset: stopLen });
      gsap.set(keepSeg, { strokeDasharray: keepLen, strokeDashoffset: keepLen });
      gsap.set([flagStop, flagKeep], { autoAlpha: 0, y: 6 });
      setChecked(false);

      /* the experiment, as a scrubbed timeline */
      const exp = gsap.timeline({ paused: true, defaults: { ease: 'power2.inOut' } });
      exp.to(stopSeg, { strokeDashoffset: 0, duration: 0.9 }, 0)
        .to(keepSeg, { strokeDashoffset: 0, duration: 0.9 }, 0.12)
        .to(flagStop, { autoAlpha: 1, y: 0, duration: 0.4, ease: 'power2.out' }, 0.55)
        .to(flagKeep, { autoAlpha: 1, y: 0, duration: 0.4, ease: 'power2.out' }, 0.7)
        .to(agencyRows, { opacity: 0.55, duration: 0.5 }, 0.4);

      const runTo = (v: boolean) => { setChecked(v); v ? exp.play() : exp.reverse(); };

      /* autoplay until touched */
      let auto: gsap.core.Timeline | null = gsap.timeline({ paused: true, repeat: -1 });
      auto.to({}, { duration: 2.4 }).call(() => runTo(true))
        .to({}, { duration: 3.6 }).call(() => runTo(false))
        .to({}, { duration: 1.6 });
      const claim = () => {
        if (auto) { auto.kill(); auto = null; }
      };
      sw.addEventListener('click', () => { claim(); runTo(!checked); });
      sw.addEventListener('keydown', (e) => {
        if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); claim(); runTo(!checked); }
      });

      /* entrance */
      const ins = qa('[data-why-in]');
      const panels = qa('[data-why-panel]');
      const rows = qa('[data-why-row]');
      const note = q('[data-why-note]');
      const intro = gsap.timeline({ paused: true, defaults: { ease: 'power2.out' } });
      intro.set(ins, { autoAlpha: 0, y: 18 }, 0)
        .set(panels, { autoAlpha: 0, y: 20 }, 0)
        .set(rows, { autoAlpha: 0, x: -8 }, 0)
        .set(note, { autoAlpha: 0 }, 0);
      intro.to(ins, { autoAlpha: 1, y: 0, duration: 0.55, stagger: 0.11 }, 0.1)
        .to(panels, { autoAlpha: 1, y: 0, duration: 0.55, stagger: 0.14 }, 0.55)
        .to(rows, { autoAlpha: 1, x: 0, duration: 0.35, stagger: 0.05 }, 0.95)
        .to(note, { autoAlpha: 1, duration: 0.4 }, 1.4);
      // stat counters
      qa('[data-why-stat]').forEach((el, i) => {
        const to = parseFloat(el.dataset.whyStat || '0');
        const dec = parseInt(el.dataset.dec || '0', 10);
        const pre = el.dataset.prefix || '';
        const suf = el.dataset.suffix || '';
        const p = { v: 0 };
        intro.to(p, {
          v: to, duration: 1.0, ease: 'power2.out',
          onUpdate: () => { el.textContent = pre + p.v.toFixed(dec) + suf; },
        }, 0.5 + i * 0.08);
      });
      intro.timeScale(1.2);
      intro.seek(0.001).pause();

      let started = false;
      new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          intro.play();
          if (!started) { started = true; gsap.delayedCall(1.2, () => auto?.play()); }
          else auto?.play();
        } else {
          auto?.pause();
        }
      }, { threshold: 0.25 }).observe(why);

      /* failsafe — the section must never sit invisible */
      gsap.delayedCall(4, () => {
        if (intro.progress() > 0) return;
        const r = why.getBoundingClientRect();
        if (r.top < window.innerHeight && r.bottom > 0) { intro.progress(1).pause(); runTo(true); }
      });
      setTimeout(() => {
        if (intro.progress() === 0 && intro.totalTime() === 0) { intro.progress(1).pause(); runTo(true); }
      }, 8000);

      if (import.meta.env.DEV) {
        (window as any).__why = { intro, exp, runTo, gsap };
      }
    }
  }
</script>


<!-- ══════════ BRIDGE vapour text effect ══════════ -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Vanilla canvas "vaporize" text effect: sample the rendered text into pixel
  // particles, then a PINNED ScrollTrigger locks the page and maps scroll
  // progress (0 → 1) to the dispersal. Scroll can't advance to Section 3 until
  // the text is fully vaporized; scrolling back reassembles it.
  const vsec = document.getElementById('vaporbridge');
  const vcanvas = vsec?.querySelector<HTMLCanvasElement>('[data-vapor-canvas]');
  const vtext = vsec?.querySelector<HTMLElement>('[data-vapor-text]');
  const vReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (vsec && vcanvas && vtext && !vReduce) {
    const ctx = vcanvas.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const TEXT = 'HOW WE FIX THAT';

    // each particle disperses along a FIXED random vector — deterministic &
    // reversible so the effect scrubs cleanly both ways with scroll
    type P = { ox: number; oy: number; ang: number; dist: number };
    let particles: P[] = [];

    function sample() {
      const rect = vcanvas.getBoundingClientRect();
      vcanvas.width = Math.floor(rect.width * dpr);
      vcanvas.height = Math.floor(rect.height * dpr);
      // Measure, don't assume. The previous constant — 0.66em average advance
      // per glyph — overestimated General Sans 600 by 7.7% (measured: 0.6126),
      // so the text never reached the width it was being sized for.
      // measureText is exact and survives a change of face.
      ctx.font = `600 100px 'General Sans','Inter',sans-serif`;
      const emW = ctx.measureText(TEXT).width / 100;   // text width per 1px of font-size

      // +30%, bounded by what the canvas can actually hold. fillText is centred
      // and does not wrap, so anything past the canvas edge is silently clipped
      // — the width cap is the real guarantee, not the multiplier.
      // Above ~1530px the ×1.3 cap binds and the full +30% lands; below that the
      // width cap binds first and the text grows by whatever room exists.
      const GROW = 1.3;
      const maxFs = (rect.width * 0.94) / emW;
      // deliberately no lower bound: a floor could only ever force a clip, and
      // maxFs already scales with the viewport.
      const fs = Math.min(120 * GROW, maxFs);
      // guard: a 0-sized canvas (not yet laid out / display:none on mobile)
      // makes getImageData throw IndexSizeError — skip until it has dimensions
      if (!vcanvas.width || !vcanvas.height) return;
      ctx.clearRect(0, 0, vcanvas.width, vcanvas.height);
      ctx.fillStyle = '#111111';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.font = `600 ${fs * dpr}px 'General Sans','Inter',sans-serif`;
      ctx.fillText(TEXT, vcanvas.width / 2, vcanvas.height / 2);
      const data = ctx.getImageData(0, 0, vcanvas.width, vcanvas.height).data;
      const step = Math.max(2, Math.round(1.6 * dpr));
      particles = [];
      for (let y = 0; y < vcanvas.height; y += step) {
        for (let x = 0; x < vcanvas.width; x += step) {
          if (data[(y * vcanvas.width + x) * 4 + 3] > 128) {
            particles.push({
              ox: x, oy: y,
              ang: Math.random() * Math.PI * 2,
              dist: (40 + Math.random() * 90) * dpr,
            });
          }
        }
      }
      ctx.clearRect(0, 0, vcanvas.width, vcanvas.height);
    }

    const clamp = (v: number) => Math.min(1, Math.max(0, v));

    // render the vaporize at a given scroll progress (0 = solid, 1 = gone)
    function render(progress: number) {
      const W = vcanvas.width;
      ctx.clearRect(0, 0, W, vcanvas.height);
      for (const p of particles) {
        // left-to-right sweep: a particle's dispersal starts later the further right it sits
        const local = clamp((progress - (p.ox / W) * 0.55) / 0.45);
        if (local >= 1) continue;
        const x = p.ox + Math.cos(p.ang) * p.dist * local;
        const y = p.oy + Math.sin(p.ang) * p.dist * local - 30 * dpr * local;
        ctx.fillStyle = `rgba(17,17,17,${1 - local})`;
        ctx.fillRect(x, y, dpr, dpr);
      }
    }

    // JS active → the canvas owns the text (the <h2> is the no-JS fallback)
    vtext.style.visibility = 'hidden';
    vcanvas.style.display = 'block';

    function setup() {
      sample();
      render(0);
      // pin the section: scroll is locked here, driving the vaporize 0 → 1.
      // The page can't move on to Section 3 until the text is fully gone.
      ScrollTrigger.create({
        trigger: vsec,
        start: 'top top',
        end: '+=110%',          // scroll distance spent vaporizing while pinned
        pin: true,
        pinSpacing: true,
        scrub: 1.5,   // 1.2s more trailing time — the text dissolves after the scroll, not with it
        onUpdate: (self) => render(self.progress),
        onRefresh: (self) => render(self.progress),
      });
    }

    // sample once fonts are ready so metrics are correct, then refresh geometry.
    // sort() first: this pinned ST is created AFTER section 3's (fonts.ready),
    // so without re-sorting, refresh() processes it out of document order and
    // section 3's start never accounts for this pin's spacing.
    (document.fonts?.ready ?? Promise.resolve()).then(() => {
      setup();
      ScrollTrigger.sort();
      ScrollTrigger.refresh();
    });

    // keep pin geometry correct after full load (images can shift layout)
    window.addEventListener('load', () => ScrollTrigger.refresh());

    let rz: number | undefined;
    window.addEventListener('resize', () => {
      clearTimeout(rz);
      rz = window.setTimeout(() => { sample(); ScrollTrigger.refresh(); }, 200);
    });
  }
</script>

<!-- ══════════ SECTION 3 — Growth Engine driver ══════════ -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const o3 = document.getElementById('section3');
  if (o3) {
    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    /* [data-chapter], not .orl3__chapter — the Metrics layer is a full-bleed
       section with its own styling, but the rail still tracks it.
       Queried from the document, not from o3: the Metrics layer moved out of
       #section3 so it could stick under the Why panel. Document order is
       unchanged (visibility → signals → proof → pricing → metrics), which is
       all the rail depends on. */
    const chapters = [...document.querySelectorAll<HTMLElement>('[data-chapter]')];

    /* ── ambient particles (vanilla port of the shadcn Particles component) ── */
    const pHost = o3.querySelector<HTMLElement>('[data-orl3-particles]');
    /* decorative background canvas — skip its continuous rAF on touch devices */
    if (pHost && !mqReduce.matches && !window.matchMedia('(hover: none) and (pointer: coarse)').matches) {
      const canvas = document.createElement('canvas');
      pHost.appendChild(canvas);
      const ctx = canvas.getContext('2d')!;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const RGB = '90, 83, 70';                    // warm charcoal on ivory
      const QUANTITY = 55, STATICITY = 60, EASE = 60;
      let W = 0, H = 0, raf = 0, running = false;
      type P = { x: number; y: number; tx: number; ty: number; size: number;
                 alpha: number; target: number; dx: number; dy: number; mag: number };
      let dots: P[] = [];
      const mouse = { x: 0, y: 0 };

      const spawn = (): P => ({
        x: Math.random() * W, y: Math.random() * H, tx: 0, ty: 0,
        size: Math.random() * 1.6 + 0.6,
        alpha: 0, target: Math.random() * 0.42 + 0.08,
        dx: (Math.random() - 0.5) * 0.08, dy: (Math.random() - 0.5) * 0.08,
        mag: 0.1 + Math.random() * 3,
      });
      const sizeUp = () => {
        W = pHost.offsetWidth; H = pHost.offsetHeight;
        canvas.width = W * dpr; canvas.height = H * dpr;
        canvas.style.width = `${W}px`; canvas.style.height = `${H}px`;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        dots = Array.from({ length: QUANTITY }, spawn);
      };
      const frame = () => {
        ctx.clearRect(0, 0, W, H);
        for (let i = dots.length - 1; i >= 0; i--) {
          const c = dots[i];
          const edge = Math.min(c.x + c.tx, W - c.x - c.tx, c.y + c.ty, H - c.y - c.ty);
          const k = Math.max(0, Math.min(edge / 24, 1));
          c.alpha = Math.min(c.alpha + 0.02, c.target * k);
          c.x += c.dx; c.y += c.dy;
          c.tx += (mouse.x / (STATICITY / c.mag) - c.tx) / EASE;
          c.ty += (mouse.y / (STATICITY / c.mag) - c.ty) / EASE;
          if (c.x < -c.size || c.x > W + c.size || c.y < -c.size || c.y > H + c.size) {
            dots[i] = spawn();
            continue;
          }
          ctx.beginPath();
          ctx.arc(c.x + c.tx, c.y + c.ty, c.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${RGB}, ${c.alpha})`;
          ctx.fill();
        }
        if (running) raf = requestAnimationFrame(frame);
      };

      window.addEventListener('mousemove', (e) => {
        const r = canvas.getBoundingClientRect();
        const x = e.clientX - r.left - W / 2;
        const y = e.clientY - r.top - H / 2;
        if (Math.abs(x) < W / 2 && Math.abs(y) < H / 2) { mouse.x = x; mouse.y = y; }
      }, { passive: true });
      new ResizeObserver(sizeUp).observe(pHost);
      sizeUp();
      new IntersectionObserver(([entry]) => {
        const on = entry.isIntersecting;
        if (on && !running) { running = true; raf = requestAnimationFrame(frame); }
        else if (!on && running) { running = false; cancelAnimationFrame(raf); }
      }).observe(pHost);
    }

    /* ── shared demo-animation helpers ──────────────────────────
       All state changes are tween/set-based (never .call), so looping
       timelines reset cleanly on every repeat. */
    type TL = gsap.core.Timeline;

    const type = (tl: TL, el: Element, text: string, dur: number, pos: gsap.Position) => {
      const p = { n: 0 };
      tl.fromTo(p, { n: 0 }, {
        n: text.length, duration: dur, ease: 'none', snap: { n: 1 },
        onUpdate: () => { el.textContent = text.slice(0, Math.round(p.n)); },
      }, pos);
    };

    const count = (tl: TL, el: Element, from: number, to: number,
                   fmt: (v: number) => string, dur: number, pos: gsap.Position) => {
      const p = { v: from };
      tl.fromTo(p, { v: from }, {
        v: to, duration: dur, ease: 'power1.inOut', snap: { v: 1 },
        onUpdate: () => { el.textContent = fmt(Math.round(p.v)); },
      }, pos);
    };

    // cursor hotspot = arrow tip (top-left of the svg)
    const cursorTo = (tl: TL, cursor: HTMLElement, target: HTMLElement, dur: number, pos: gsap.Position) => {
      tl.to(cursor, {
        duration: dur, ease: 'power2.inOut', autoAlpha: 1,
        x: () => {
          const t = target.getBoundingClientRect(), b = cursor.parentElement!.getBoundingClientRect();
          return t.left - b.left + t.width / 2 - 3;
        },
        y: () => {
          const t = target.getBoundingClientRect(), b = cursor.parentElement!.getBoundingClientRect();
          return t.top - b.top + t.height / 2 - 3;
        },
      }, pos);
    };

    const click = (tl: TL, cursor: HTMLElement, target: HTMLElement, pos: gsap.Position) => {
      tl.to(cursor, { scale: 0.82, duration: 0.09, yoyo: true, repeat: 1 }, pos)
        .fromTo(target, { scale: 1 }, {
          scale: 0.96, duration: 0.09, yoyo: true, repeat: 1, transformOrigin: 'center',
        }, '<');
    };

    const swapPane = (tl: TL, from: Element, to: Element, pos: gsap.Position) => {
      tl.to(from, { autoAlpha: 0, duration: 0.3 }, pos)
        .fromTo(to, { autoAlpha: 0, y: 10 }, { autoAlpha: 1, y: 0, duration: 0.35 }, '<+0.12');
    };

    const notifIn = (tl: TL, notif: Element, pos: gsap.Position) => {
      tl.fromTo(notif, { autoAlpha: 0, y: 8 }, { autoAlpha: 1, y: 0, duration: 0.4, ease: 'power2.out' }, pos);
    };

    const pct = (v: number) => `${v}%`;
    const plain = (v: number) => String(v);

    /* ── demo timeline builders (one per system) ── */
    const q = (root: HTMLElement, sel: string) => root.querySelector<HTMLElement>(sel)!;
    const qa = (root: HTMLElement, sel: string) => [...root.querySelectorAll<HTMLElement>(sel)];

    /* empty since the Metrics layer got its own dedicated script — kept so a
       future chapter demo can register here without rebuilding the plumbing */
    const builders: Record<string, (root: HTMLElement) => TL> = {};

    /* ── activation: build lazily, play only the visible chapter ──
       (visibility, signals and proof each run their own demo in a
       dedicated script, so none of them are registered here) */
    const demos: Record<string, { root: HTMLElement; tl: TL | null }> = {};
    chapters.forEach((ch) => {
      const name = ch.dataset.chapter!;
      if (!builders[name]) return;
      const root = ch.querySelector<HTMLElement>('[data-demo]')!;
      demos[name] = { root, tl: null };
      if (mqReduce.matches) return;   // reduced motion → CSS shows each demo's final state
      // prime: show scene 1 instead of the CSS final-state fallback
      const panes = qa(root, '[data-pane]');
      gsap.set(panes, { autoAlpha: 0 });
      gsap.set(panes[0], { autoAlpha: 1 });
      new IntersectionObserver(([entry]) => {
        const d = demos[name];
        if (entry.isIntersecting) {
          if (!d.tl) d.tl = builders[name](root);
          d.tl.play();
        } else {
          d.tl?.pause();
        }
      }, { threshold: 0.3 }).observe(ch);
    });

    /* ── entrances (left copy + demo window rise once) ── */
    if (!mqReduce.matches) {
      const introEls = [...o3.querySelectorAll<HTMLElement>('[data-o3-in]')];
      const outroEls = [...o3.querySelectorAll<HTMLElement>('[data-o3-out]')];
      gsap.set([...introEls, ...outroEls], { opacity: 0, y: 22 });
      ScrollTrigger.create({
        trigger: o3.querySelector('.orl3__intro'), start: 'top 75%', once: true,
        onEnter: () => gsap.to(introEls, { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out', stagger: 0.09 }),
      });
      const outroTrig = o3.querySelector('.orl3__outro');
      if (outroTrig) ScrollTrigger.create({
        trigger: outroTrig, start: 'top 80%', once: true,
        onEnter: () => gsap.to(outroEls, { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out', stagger: 0.09 }),
      });
      chapters.forEach((ch) => {
        /* `chapters` deliberately includes [data-chapter="metrics"] so the
           rail can track it, but that layer has no copy/CTA/demo — the two
           non-null assertions here were false, and gsap.set(null) threw,
           aborting every statement after this loop (the dev hook, the rail,
           and the sky driver). Skip anything without a demo window. */
        const win = ch.querySelector<HTMLElement>('.orl3__demo');
        if (!win) return;
        const els = [
          ...ch.querySelectorAll<HTMLElement>('.orl3__copy > *'),
          ch.querySelector<HTMLElement>('.orl3__cta'),
        ].filter((el): el is HTMLElement => !!el);
        gsap.set(els, { opacity: 0, y: 24 });
        gsap.set(win, { opacity: 0, y: 34 });
        ScrollTrigger.create({
          trigger: ch, start: 'top 70%', once: true,
          onEnter: () => {
            const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });
            tl.to(els, { opacity: 1, y: 0, duration: 0.5, stagger: 0.08 }, 0)
              .to(win, { opacity: 1, y: 0, duration: 0.6 }, 0.18);
          },
        });
      });
    }

    // dev-only hook for automated verification
    if (import.meta.env.DEV) {
      (window as any).__o3 = {
        ST: ScrollTrigger, gsap, demos,
        activate: (name: string) => {
          const d = demos[name];
          if (d && !d.tl) d.tl = builders[name](d.root);
          d?.tl?.play();
          return !!d?.tl;
        },
      };
    }


    /* ── chapter progress rail ── */
    const rail = o3.querySelector<HTMLElement>('[data-orl3-rail]');
    if (rail) {
      const items = [...rail.querySelectorAll<HTMLElement>('[data-rail]')];
      new IntersectionObserver(
        ([entry]) => rail.classList.toggle('is-on', entry.isIntersecting),
        { rootMargin: '-15% 0px -15% 0px' },
      ).observe(o3);
      /* NOTE: .is-dark is owned by the sky driver (its own script block), which
         toggles it from the actual ground luminance under the rail. An
         observer on the flow used to do it here, but flipped too late — the
         intro's descent band darkens before the flow begins. */
      chapters.forEach((ch) => {
        new IntersectionObserver(([entry]) => {
          if (entry.isIntersecting)
            items.forEach((it) => it.classList.toggle('is-active', it.dataset.rail === ch.dataset.chapter));
        }, { rootMargin: '-45% 0px -45% 0px' }).observe(ch);
      });
    }
  }
</script>




