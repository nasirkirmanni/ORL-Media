      strokeDashoffset: ringLen * (1 - 0.88), duration: 2.6, ease: 'sine.inOut',
    });

    /* ── ambient loop 3 · review counter ticks up ── */
    const reviewLoop = gsap.timeline({ paused: true, repeat: -1 });
    reviewLoop.call(() => {
      const el = q('[data-px-reviews]');
      const next = (parseInt(el.textContent || '123', 10) + 1) % 400 || 121;
      gsap.fromTo(el, { y: -4, autoAlpha: 0.4 },
        { y: 0, autoAlpha: 1, duration: 0.45, ease: 'power2.out',
          onStart: () => { el.textContent = `${next}`; } });
    }).to({}, { duration: 5.5 });

    /* ── ambient loop 4 · featured case study rotates ── */
    const CASES = [
      { logo: 'AA', name: 'Acme AI', sector: 'B2B SaaS', m: [42, 31, 26],
        d: 'M2 48 30 42 58 44 86 32 114 35 142 22 170 26 198 13 238 6' },
      { logo: 'FL', name: 'Finova Labs', sector: 'Fintech', m: [37, 28, 31],
        d: 'M2 50 30 46 58 38 86 40 114 28 142 30 170 19 198 20 238 9' },
