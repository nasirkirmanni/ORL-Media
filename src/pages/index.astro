        d: 'M2 52 30 44 58 46 86 34 114 26 142 27 170 16 198 12 238 7' },
    ];
    let ci = 0;
    const caseCard = q('.px__card--case');
    const caseLoop = gsap.timeline({ paused: true, repeat: -1 });
    caseLoop
      .to([q('[data-px-logo]'), q('[data-px-company]'), q('[data-px-sector]')],
        { autoAlpha: 0, x: -8, duration: 0.35, ease: 'power2.in', stagger: 0.04 }, 6.5)
      .to(graph, { strokeDashoffset: graphLen, duration: 0.45, ease: 'power1.in' }, '<')
