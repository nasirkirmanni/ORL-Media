<script>
  /* ── stack reveal gate ──
     Turns on the Metrics-holds-while-Why-rises effect, but only when the
     Metrics layer actually fits one screen. `position: sticky; top: 0` grabs
     the panel the moment its top hits the ceiling, so a panel taller than the
     viewport would have its footer row cropped off and never seen.

     Measured rather than a media query: the layer's height moves with width
     (it reflows to a 3-column strip under 1024px) and the viewport moves with
     OS display scaling — a 1080p screen at 125% reports ~750 CSS px. Any
     hardcoded threshold is wrong for somebody. This asks the two questions
     directly and re-asks on resize and zoom. */
  const stackRoot = document.documentElement;
  const stackLayer = document.querySelector<HTMLElement>('.mlayer');

  if (stackLayer) {
    const syncStack = () => {
      /* Measure in .stack-measure: reveal padding applied, but no sticky and
         no min-height:100vh — those would make the measurement circular. */
      stackRoot.classList.remove('stack-reveal');
      stackRoot.classList.add('stack-measure');
      const natural = stackLayer.offsetHeight;
      stackRoot.classList.remove('stack-measure');

      const fits = natural <= window.innerHeight;
      stackRoot.classList.toggle('stack-reveal', fits);
      if (import.meta.env.DEV) {
        (window as any).__stack = { natural, viewport: window.innerHeight, fits };
      }
    };

    syncStack();
    // fonts land after first paint and change the layer's height
    document.fonts?.ready.then(syncStack);

    let t = 0;
    window.addEventListener('resize', () => {
      clearTimeout(t);
      t = window.setTimeout(syncStack, 150);
    });
  }
</script>


