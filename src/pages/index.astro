      const cur = reviews[ri];
      ri = (ri + 1) % reviews.length;
      const next = reviews[ri];
      gsap.to(cur, { autoAlpha: 0, y: -14, duration: 0.5, ease: 'power2.in' });
      gsap.fromTo(next, { autoAlpha: 0, y: 14 },
        { autoAlpha: 1, y: 0, duration: 0.55, delay: 0.18, ease: 'power2.out' });
    }).to({}, { duration: 4.8 });

    /* ── ambient loop 6 · a pulse walks the buyer journey ── */
    const stages = qa('[data-px-stage]');
    const journeyLoop = gsap.timeline({ paused: true, repeat: -1, repeatDelay: 1.4 });
    stages.forEach((st, i) => {
      journeyLoop.to(st, { duration: 0.5, ease: 'power2.out',
        onStart: () => st.classList.add('is-lit'),
        onComplete: () => st.classList.remove('is-lit') }, i * 0.75);
    });

    /* ── ambient loop 7 · toasts stack in and fade ── */
    const TOASTS = [
      'Security questionnaire completed', 'New G2 review published',
      'Case study downloaded', 'ROI calculator viewed',
      'Buyer entered evaluation stage', 'Trust score increased',
      'Proof recommendation accepted',
    ];
    const toast = q('[data-px-toast]');
    const toastTxt = q('[data-px-toasttxt]');
    let toi = 0;
    const toastLoop = gsap.timeline({ paused: true, repeat: -1 });
    toastLoop
      .call(() => { toastTxt.textContent = TOASTS[toi]; toi = (toi + 1) % TOASTS.length; })
      .fromTo(toast, { autoAlpha: 0, y: 12, scale: 0.97 },
        { autoAlpha: 1, y: 0, scale: 1, duration: 0.5, ease: 'back.out(1.6)' })
      .to(toast, { autoAlpha: 0, y: -8, duration: 0.45, ease: 'power2.in' }, '+=2.9')
      .to({}, { duration: 0.9 });

    const loops = [statusLoop, trustLoop, ringBreath, reviewLoop,
                   caseLoop, tickerLoop, journeyLoop, toastLoop];

    /* render t=0 now so nothing flashes before the trigger */
    intro.seek(0.001).pause();

    /* play while visible, pause everything when it leaves — an off-screen
       dashboard should cost zero frames */
    let started = false;
    new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        intro.play();
        if (!started) {
          started = true;
          // stagger loop starts so the panel doesn't pulse in lockstep
          loops.forEach((l, i) => gsap.delayedCall(1.6 + i * 0.4, () => l.play()));
        } else {
          loops.forEach((l) => l.play());
        }
      } else {
        loops.forEach((l) => l.pause());
      }
    }, { threshold: 0.3 }).observe(pxRoot);

    /* failsafe: seek(0.001) parks the cards at opacity 0, so if the observer
       or the rAF loop never runs the panel would sit blank. If the intro
       hasn't advanced a few seconds after the section is on screen, jump it
       to its finished state — a static dashboard beats an empty one. */
    gsap.delayedCall(4, () => {
      if (intro.progress() > 0) return;
      const r = pxRoot.getBoundingClientRect();
      const onScreen = r.top < window.innerHeight && r.bottom > 0;
      if (onScreen) intro.progress(1).pause();
    });
    setTimeout(() => {
      if (intro.progress() === 0 && intro.totalTime() === 0) intro.progress(1).pause();
    }, 8000);

    if (import.meta.env.DEV) {
      (window as any).__px = { intro, loops, gsap };
    }
  }
</script>

