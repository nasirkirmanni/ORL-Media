<!-- ══════════ SECTION 3 · VISIBILITY — one-shot engine demo ══════════ -->
<script>
  import { gsap } from 'gsap';

  const vxChapter = document.querySelector<HTMLElement>('[data-chapter="visibility"]');
  const vxRoot = vxChapter?.querySelector<HTMLElement>('[data-vx]') ?? null;
  const vxReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // reduced motion / no JS: the resting CSS already shows the finished dashboard
  if (vxChapter && vxRoot && !vxReduce) {
    const q = (sel: string) => vxChapter.querySelector<HTMLElement>(sel)!;
    const qa = (sel: string) => [...vxChapter.querySelectorAll<HTMLElement>(sel)];
    const body = q('[data-vx-body]');
    const cursor = q('[data-vx-cursor]');
    const result = q('[data-vx-result]');
    const search = q('[data-vx-search]');
    const mark = q('[data-vx-mark]');
    const caret = q('[data-vx-caret]');
    const queryEl = q('[data-vx-query]');
    const QUERY = queryEl.textContent ?? '';
    const line = vxChapter.querySelector<SVGGeometryElement>('[data-vx-line]')!;
    const lineLen = line.getTotalLength();

    /* split the answer lines into word spans for a streaming reveal */
    function words(el: HTMLElement): HTMLElement[] {
      const out: HTMLElement[] = [];
      const walk = (node: Node) => {
        [...node.childNodes].forEach((child) => {
          if (child.nodeType === Node.TEXT_NODE) {
            const frag = document.createDocumentFragment();
            (child.textContent ?? '').split(/(\s+)/).forEach((tok) => {
              if (!tok) return;
              if (/^\s+$/.test(tok)) { frag.appendChild(document.createTextNode(tok)); return; }
              const s = document.createElement('span');
              s.textContent = tok;
              out.push(s);
              frag.appendChild(s);
            });
            (child as ChildNode).replaceWith(frag);
          } else {
            walk(child);
          }
        });
      };
      walk(el);
      return out;
    }
    const l1w = words(q('[data-vx-l1]'));
    const l2w = words(q('[data-vx-l2]'));

    const type = (tl: gsap.core.Timeline, el: Element, text: string, dur: number, pos: gsap.Position) => {
      const p = { n: 0 };
      tl.fromTo(p, { n: 0 }, {
        n: text.length, duration: dur, ease: 'none', snap: { n: 1 },
        onUpdate: () => { el.textContent = text.slice(0, Math.round(p.n)); },
      }, pos);
    };
    const count = (tl: gsap.core.Timeline, el: Element, to: number, dur: number, pos: gsap.Position) => {
      const p = { v: 0 };
      tl.fromTo(p, { v: 0 }, {
        v: to, duration: dur, ease: 'power1.inOut', snap: { v: 1 },
        onUpdate: () => { el.textContent = `${Math.round(p.v)}%`; },
      }, pos);
    };
    // cursor hotspot ≈ arrow tip (top-left of the svg)
    const cursorTo = (tl: gsap.core.Timeline, target: Element, dur: number, pos: gsap.Position) => {
      tl.to(cursor, {
        duration: dur, ease: 'power2.inOut', autoAlpha: 1,
        x: () => {
          const t = target.getBoundingClientRect(), b = body.getBoundingClientRect();
          return t.left - b.left + t.width / 2 - 3;
        },
        y: () => {
          const t = target.getBoundingClientRect(), b = body.getBoundingClientRect();
          return t.top - b.top + t.height / 2 - 3;
        },
      }, pos);
    };

    const opps = qa('[data-vx-opp]');
    const tl = gsap.timeline({ paused: true, defaults: { ease: 'power2.out' } });

    /* resting → initial demo state (all at t=0 so restart() is clean) */
    tl.set(queryEl, { textContent: '' }, 0)
      .set(caret, { opacity: 0 }, 0)
      .set([...l1w, ...l2w], { opacity: 0 }, 0)
      .set(q('[data-vx-src]'), { autoAlpha: 0 }, 0)
      .set(mark, { backgroundColor: 'rgba(197, 164, 106, 0)' }, 0)
      .set(q('[data-vx-num]'), { textContent: '0%' }, 0)
      .set(q('[data-vx-chip]'), { autoAlpha: 0, y: 6 }, 0)
      .set(line, { strokeDasharray: lineLen, strokeDashoffset: lineLen }, 0)
      .set(q('[data-vx-area]'), { opacity: 0 }, 0)
      .set(qa('[data-vx-dot]'), { scale: 0, transformOrigin: 'center' }, 0)
      .set(q('[data-vx-tip]'), { scale: 0, transformOrigin: 'center' }, 0)
      .set(qa('[data-vx-panel]'), { autoAlpha: 0, y: 14 }, 0)
      .set(qa('[data-vx-bar]'), { scaleX: 0 }, 0)
      .set(qa('[data-vx-row]'), { autoAlpha: 0, y: 8 }, 0)
      .set(opps, { autoAlpha: 0, x: 8 }, 0)
      .set(opps[0], { backgroundColor: 'rgba(246, 241, 230, 0)' }, 0)
      .set(q('[data-vx-viewall]'), { autoAlpha: 0 }, 0)
      .set(result, { autoAlpha: 0, y: 18 }, 0)
      .set(cursor, { autoAlpha: 0, x: 70, y: 70, scale: 1 }, 0);

    /* 1-2 · cursor enters the search field and clicks */
    cursorTo(tl, search, 0.8, 0.4);
    tl.to(cursor, { scale: 0.84, duration: 0.09, yoyo: true, repeat: 1 }, '+=0.1')
      .to(search, { borderColor: '#2e5cff', boxShadow: '0 0 0 3px rgba(46,92,255,0.12)', duration: 0.25 }, '<')
      .set(caret, { opacity: 1 }, '<');

    /* 3 · the query types character by character */
    type(tl, queryEl, QUERY, 1.9, '+=0.2');

    /* 4 · thinking */
    tl.set(caret, { opacity: 0 }, '+=0.15')
      .to(search, { borderColor: '#e6ddcc', boxShadow: '0 0 0 0 rgba(46,92,255,0)', duration: 0.4 }, '<')
      .to(q('[data-vx-think]'), { autoAlpha: 1, duration: 0.3 }, '<')
      .to(q('[data-vx-think]'), { autoAlpha: 0, duration: 0.25 }, '+=0.8');

    /* 5 · the answer streams in */
    tl.to(l1w, { opacity: 1, duration: 0.18, stagger: 0.045, ease: 'none' }, '+=0.1')
      .to(l2w, { opacity: 1, duration: 0.18, stagger: 0.035, ease: 'none' }, '+=0.25');

    /* 6-7 · ORL Media highlighted, cursor pauses over it, sources fade in */
    cursorTo(tl, mark, 0.7, '+=0.15');
    tl.to(mark, { backgroundColor: 'rgba(197, 164, 106, 0.3)', duration: 0.45 }, '<+0.35')
      .to(q('[data-vx-src]'), { autoAlpha: 1, duration: 0.45 }, '+=0.25');

    /* 8 · Share of Answer updates: counter, chip, line draw, dots */
    count(tl, q('[data-vx-num]'), 34, 1.0, '+=0.3');
    tl.to(q('[data-vx-chip]'), { autoAlpha: 1, y: 0, duration: 0.4 }, '<+0.3')
      .to(line, { strokeDashoffset: 0, duration: 1.3, ease: 'power1.inOut' }, '<')
      .to(qa('[data-vx-dot]'), { scale: 1, duration: 0.3, stagger: 0.24 }, '<+0.1')
      .to(q('[data-vx-area]'), { opacity: 1, duration: 0.7 }, '<+0.5');

    /* cursor hovers the current data point → tooltip, one soft pulse */
    cursorTo(tl, q('.vx__pt--end') as unknown as Element, 0.75, '+=0.1');
    tl.to(q('[data-vx-tip]'), { scale: 1, duration: 0.4 }, '<+0.6')
      .fromTo(q('[data-vx-pulse]'), { scale: 1, opacity: 0.55, transformOrigin: 'center' },
        { scale: 2.6, opacity: 0, duration: 0.9, ease: 'power1.out' }, '<+0.1');

    /* lower dashboard assembles */
    tl.to(qa('[data-vx-panel]'), { autoAlpha: 1, y: 0, duration: 0.5, stagger: 0.14 }, '+=0.25')
      .to(qa('[data-vx-bar]'), { scaleX: 1, duration: 0.7, stagger: 0.1 }, '<+0.25');
    [34, 22, 17, 27].forEach((v, i) => count(tl, qa('[data-vx-pct]')[i], v, 0.8, i === 0 ? '<' : '<+0.08'));
    tl.to(qa('[data-vx-row]'), { autoAlpha: 1, y: 0, duration: 0.35, stagger: 0.12 }, '<');

    /* opportunities + cursor hover on the first row */
    tl.to(opps, { autoAlpha: 1, x: 0, duration: 0.35, stagger: 0.09 }, '+=0.1')
      .to(q('[data-vx-viewall]'), { autoAlpha: 1, duration: 0.35 }, '+=0.1');
    cursorTo(tl, opps[0], 0.8, '+=0.2');
    tl.to(opps[0], { backgroundColor: 'rgba(246, 241, 230, 1)', duration: 0.25 }, '+=0.05')
      .to(opps[0], { backgroundColor: 'rgba(246, 241, 230, 0)', duration: 0.5 }, '+=0.7');

    /* the outcome: floating success card rises in, cursor goes idle */
    tl.to(result, { autoAlpha: 1, y: 0, duration: 0.7 }, '-=0.9')
      .to(cursor, { autoAlpha: 0, duration: 0.5 }, '+=0.4');

    /* whole demo runs 1.75× faster — pacing tuned once, scaled globally */
    tl.timeScale(1.75);

    /* render the t=0 state now so nothing flashes before the trigger */
    tl.seek(0.001).pause();

    /* trigger at ~35 % visibility; replay only after leaving and re-entering */
    let armed = false;
    new IntersectionObserver((entries) => {
      const entry = entries[0];
      if (entry.isIntersecting) {
        if (armed) { armed = false; tl.restart(); }
        else tl.play();
      } else if (tl.progress() > 0) {
        if (tl.progress() >= 1) armed = true;
        else tl.pause();
      }
    }, { threshold: 0.35 }).observe(vxRoot);

    // dev-only hook for automated verification
    if (import.meta.env.DEV) {
      (window as any).__vx = { tl, gsap };
    }
  }
</script>

<!-- ══════════ SECTION 3 · 02 SIGNALS — one-shot engine demo ══════════ -->
<script>
  import { gsap } from 'gsap';

  const sxChapter = document.querySelector<HTMLElement>('[data-chapter="signals"]');
  const sxRoot = sxChapter?.querySelector<HTMLElement>('[data-sx]') ?? null;
  const sxReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // reduced motion / no JS: the resting CSS already shows the finished dashboard
  if (sxChapter && sxRoot && !sxReduce) {
    const q = (sel: string) => sxChapter.querySelector<HTMLElement>(sel)!;
    const qa = (sel: string) => [...sxChapter.querySelectorAll<HTMLElement>(sel)];
    const body = q('[data-sx-body]');
    const cursor = q('[data-sx-cursor]');
    const result = q('[data-sx-result]');
    const caret = q('[data-sx-caret]');
    const m1 = q('[data-sx-m1]');
    const m2 = q('[data-sx-m2]');
    const M1 = m1.textContent ?? '';
    const M2 = m2.textContent ?? '';
    const spark = sxChapter.querySelector<SVGGeometryElement>('[data-sx-spark]')!;
    const sparkLen = spark.getTotalLength();

    const sigs = qa('[data-sx-sig]');
    const accts = qa('[data-sx-acct]');
    const acts = qa('[data-sx-act]');
    const queue = q('[data-sx-queue]');

    /* the caret lives inside whichever line is currently typing */
    const type = (tl: gsap.core.Timeline, el: HTMLElement, text: string, dur: number, pos: gsap.Position) => {
      const node = document.createTextNode('');
      const p = { n: 0 };
      tl.fromTo(p, { n: 0 }, {
        n: text.length, duration: dur, ease: 'none', snap: { n: 1 },
        onStart: () => { el.textContent = ''; el.append(node, caret); },
        onUpdate: () => { node.textContent = text.slice(0, Math.round(p.n)); },
      }, pos);
    };
    const count = (tl: gsap.core.Timeline, el: Element, from: number, to: number, dur: number, pos: gsap.Position) => {
      const p = { v: from };
      tl.fromTo(p, { v: from }, {
        v: to, duration: dur, ease: 'power1.inOut', snap: { v: 1 },
        onUpdate: () => { el.textContent = `${Math.round(p.v)}`; },
      }, pos);
    };
    // cursor hotspot ≈ arrow tip (top-left of the svg)
    const cursorTo = (tl: gsap.core.Timeline, target: Element, dur: number, pos: gsap.Position) => {
      tl.to(cursor, {
        duration: dur, ease: 'power2.inOut', autoAlpha: 1,
        x: () => {
          const t = target.getBoundingClientRect(), b = body.getBoundingClientRect();
          return t.left - b.left + t.width / 2 - 3;
        },
        y: () => {
          const t = target.getBoundingClientRect(), b = body.getBoundingClientRect();
          return t.top - b.top + t.height / 2 - 3;
        },
      }, pos);
    };

    const tl = gsap.timeline({ paused: true, defaults: { ease: 'power2.out' } });

    /* resting → initial demo state (all at t=0 so restart() is clean) */
    tl.set([m1, m2], { textContent: '' }, 0)
      .set(caret, { className: 'sx__caret' }, 0)
      .set(q('[data-sx-drafting]'), { autoAlpha: 0 }, 0)
      .set(q('[data-sx-num]'), { textContent: '71' }, 0)
      .set(q('[data-sx-chip]'), { autoAlpha: 0, y: 6 }, 0)
      .set(q('[data-sx-fill]'), { width: '71%' }, 0)
      .set(sigs, { autoAlpha: 0, y: 10 }, 0)
      .set(qa('[data-sx-panel]'), { autoAlpha: 0, y: 14 }, 0)
      .set(qa('[data-sx-count]'), { textContent: '0' }, 0)
      .set(qa('[data-sx-row]'), { autoAlpha: 0, x: -6 }, 0)
      .set(accts, { autoAlpha: 0, y: 8 }, 0)
      .set(accts[0], { backgroundColor: 'rgba(250, 246, 236, 0)' }, 0)
      .set(acts, { autoAlpha: 0, x: 8 }, 0)
      .set(qa('[data-sx-more]'), { autoAlpha: 0 }, 0)
      .set(queue, { autoAlpha: 0 }, 0)
      .set(result, { autoAlpha: 0, y: 18 }, 0)
      .set(q('[data-sx-final]'), { textContent: '0' }, 0)
      .set(spark, { strokeDasharray: sparkLen, strokeDashoffset: sparkLen }, 0)
      .set(cursor, { autoAlpha: 0, x: 80, y: 80, scale: 1 }, 0);

    /* 1-4 · signals land one by one; each one lifts the intent score */
    const STEPS = [79, 86, 91];
    sigs.forEach((sig, i) => {
      tl.to(sig, { autoAlpha: 1, y: 0, duration: 0.45 }, i === 0 ? 0.5 : '+=0.5');
      count(tl, q('[data-sx-num]'), i === 0 ? 71 : STEPS[i - 1], STEPS[i], 0.55, '<+0.1');
      tl.to(q('[data-sx-fill]'), { width: `${STEPS[i]}%`, duration: 0.55, ease: 'power1.inOut' }, '<');
    });
    tl.to(q('[data-sx-chip]'), { autoAlpha: 1, y: 0, duration: 0.4 }, '-=0.2');

    /* 5 · the lower dashboard assembles; detected-signal tallies count up */
    tl.to(qa('[data-sx-panel]'), { autoAlpha: 1, y: 0, duration: 0.5, stagger: 0.13 }, '+=0.2')
      .to(qa('[data-sx-row]'), { autoAlpha: 1, x: 0, duration: 0.35, stagger: 0.09 }, '<+0.25');
    [24, 38, 17, 19, 26].forEach((v, i) => count(tl, qa('[data-sx-count]')[i], 0, v, 0.8, i === 0 ? '<' : '<+0.07'));

    /* 6 · high-intent accounts appear in rank order, Acme AI first */
    tl.to(accts, { autoAlpha: 1, y: 0, duration: 0.35, stagger: 0.12 }, '<+0.3');

    /* 7-8 · the AI drafts the outreach: dots, then the message types in */
    tl.to(q('[data-sx-drafting]'), { autoAlpha: 1, duration: 0.3 }, '+=0.15');
    tl.call(() => caret.classList.add('is-on'), undefined, '+=0.35');
    type(tl, m1, M1, 1.5, '<');
    type(tl, m2, M2, 1.1, '+=0.2');
    tl.call(() => caret.classList.remove('is-on'), undefined, '+=0.25')
      .to(q('[data-sx-drafting]'), { autoAlpha: 0, duration: 0.3 }, '<');

    /* 9 · recommended actions check in, then the cursor walks the workflow */
    tl.to(acts, { autoAlpha: 1, x: 0, duration: 0.35, stagger: 0.11 }, '-=0.4')
      .to(qa('[data-sx-more]'), { autoAlpha: 1, duration: 0.35, stagger: 0.08 }, '<+0.2')
      .to(queue, { autoAlpha: 1, duration: 0.35 }, '<');

    cursorTo(tl, accts[0], 0.85, '+=0.15');
    tl.to(accts[0], { backgroundColor: 'rgba(250, 246, 236, 1)', duration: 0.25 }, '+=0.05')
      .to(accts[0], { backgroundColor: 'rgba(250, 246, 236, 0)', duration: 0.45 }, '+=0.6');
    cursorTo(tl, queue, 0.85, '-=0.2');
    tl.to(cursor, { scale: 0.84, duration: 0.09, yoyo: true, repeat: 1 }, '+=0.25');
    cursorTo(tl, acts[0], 0.75, '+=0.3');

    /* 10-11 · the outcome: conversions counter and the trend line draw in */
    tl.to(result, { autoAlpha: 1, y: 0, duration: 0.7 }, '-=0.5');
    count(tl, q('[data-sx-final]'), 0, 24, 0.9, '<+0.2');
    tl.to(spark, { strokeDashoffset: 0, duration: 1.1, ease: 'power1.inOut' }, '<')
      .to(cursor, { autoAlpha: 0, duration: 0.5 }, '+=0.4');

    /* whole demo runs 1.7× faster — pacing tuned once, scaled globally */
    tl.timeScale(1.7);

    /* render the t=0 state now so nothing flashes before the trigger */
    tl.seek(0.001).pause();

    /* trigger at ~35 % visibility; replay only after leaving and re-entering */
    let sxArmed = false;
    new IntersectionObserver((entries) => {
      const entry = entries[0];
      if (entry.isIntersecting) {
        if (sxArmed) { sxArmed = false; tl.restart(); }
        else tl.play();
      } else if (tl.progress() > 0) {
        if (tl.progress() >= 1) sxArmed = true;
        else tl.pause();
      }
    }, { threshold: 0.35 }).observe(sxRoot);

    // dev-only hook for automated verification
    if (import.meta.env.DEV) {
      (window as any).__sx = { tl, gsap };
    }
  }
</script>

<!-- ══════════ SECTION 3 · 03 PROOF — live Proof Engine ══════════ -->
<script>
  import { gsap } from 'gsap';

  /* Unlike Visibility and Signals — which each play a one-shot sequence —
     Proof is a *live* dashboard: an entrance timeline assembles it, then a
     set of independent ambient loops keep it running for as long as it is
     on screen. Every loop pauses on exit so an off-screen section costs
     nothing. Resting CSS is the finished dashboard, so reduced-motion and
     no-JS readers still see a complete, correct panel. */
  const pxChapter = document.querySelector<HTMLElement>('[data-chapter="proof"]');
  const pxRoot = pxChapter?.querySelector<HTMLElement>('[data-px]') ?? null;
  const pxReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  /* Mobile: skip the 8 ambient loops — resting CSS is the finished panel.
     Gated on touch-primary devices (not width), so hybrid laptops keep it. */
  const pxTouch = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

  if (pxChapter && pxRoot && !pxReduce && !pxTouch) {
    const q = (sel: string) => pxChapter.querySelector<HTMLElement>(sel)!;
    const qa = (sel: string) => [...pxChapter.querySelectorAll<HTMLElement>(sel)];

    const cards = qa('[data-px-card]');
    const ring = pxChapter.querySelector<SVGCircleElement>('[data-px-ring]')!;
    const graph = pxChapter.querySelector<SVGGeometryElement>('[data-px-graph]')!;
    const ringLen = 2 * Math.PI * 30;
    const graphLen = graph.getTotalLength();

    const count = (tl: gsap.core.Timeline, el: Element, from: number, to: number,
                   dur: number, pos: gsap.Position, dec = 0) => {
      const p = { v: from };
      tl.fromTo(p, { v: from }, {
        v: to, duration: dur, ease: 'power2.out',
        onUpdate: () => { el.textContent = p.v.toFixed(dec); },
      }, pos);
    };

    /* ── entrance: the dashboard assembles once on first view ── */
    const intro = gsap.timeline({ paused: true, defaults: { ease: 'power2.out' } });
    intro
      .set(cards, { autoAlpha: 0, y: 16 }, 0)
