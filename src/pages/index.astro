      const from = TRUST[ti];
      ti = (ti + 1) % TRUST.length;
      const to = TRUST[ti];
      const p = { v: from };
      gsap.to(p, {
        v: to, duration: 1.6, ease: 'power2.inOut',
        onUpdate: () => { q('[data-px-trust]').textContent = `${Math.round(p.v)}`; },
      });
      gsap.to(q('[data-px-trustfill]'), { width: `${to}%`, duration: 1.6, ease: 'power2.inOut' });
