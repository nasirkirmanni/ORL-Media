      autoAlpha: 0, duration: 0.35, delay: 3.2, ease: 'power1.in',
      onComplete: () => { si = (si + 1) % STATUSES.length; statusEl.textContent = STATUSES[si]; },
    }).to(statusEl, { autoAlpha: 1, duration: 0.35, ease: 'power1.out' });

    /* ── ambient loop 2 · trust score drifts, ring breathes ── */
