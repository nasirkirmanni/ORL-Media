        ci = (ci + 1) % CASES.length;
        const c = CASES[ci];
        q('[data-px-logo]').textContent = c.logo;
        q('[data-px-company]').textContent = c.name;
        q('[data-px-sector]').textContent = c.sector;
        graph.setAttribute('d', c.d);
        // metrics count from their current values to the new company's
        ([['[data-px-m1]', c.m[0]], ['[data-px-m2]', c.m[1]], ['[data-px-m3]', c.m[2]]] as const)
          .forEach(([sel, to]) => {
            const el = q(sel);
            const p = { v: parseInt(el.textContent || '0', 10) };
            gsap.to(p, { v: to, duration: 0.9, ease: 'power2.out',
              onUpdate: () => { el.textContent = `${Math.round(p.v)}`; } });
          });
      })
      .to([q('[data-px-logo]'), q('[data-px-company]'), q('[data-px-sector]')],
        { autoAlpha: 1, x: 0, duration: 0.4, ease: 'power2.out', stagger: 0.05 })
