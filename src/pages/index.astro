    const bits = [...faq.querySelectorAll<HTMLElement>('[data-faq-in]')];
    gsap.set(bits, { opacity: 0, y: 20 });
    const io = new IntersectionObserver(([entry]) => {
      if (!entry.isIntersecting) return;
      io.disconnect();
      gsap.to(bits, { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out', stagger: 0.08 });
    }, { threshold: 0.15 });
    io.observe(faq);
  }
</script>

