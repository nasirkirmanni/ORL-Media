</script>

<!-- ══════════ GROWTH INFRASTRUCTURE — 3D floating dashboard ══════════ -->
<script>
  import { gsap } from 'gsap';

  /* ── wordmark pass over the pinned scene ──
     Maps scroll position within the pin track onto the wordmark's travel:
     progress 0 parks it one screen below the fold, progress 1 has its last
     pixel clearing the top. The section unsticks at exactly progress 1, so the
     page starts moving on the frame the wordmark finishes leaving.

     Driven off the scroll event rather than rAF: one style write per event,
     and reading straight from scroll position means it can't drift out of sync
     with the pin the way a tweened value can. CSS holds the resting state, so
     if this never runs the wordmark simply stays parked below the fold. */
  const pinTrack = document.querySelector<HTMLElement>('.s3dpin');
  const wordmark = document.querySelector<HTMLElement>('[data-s3dmark]');
  const markText = wordmark?.querySelector<HTMLElement>('.s3dmark__text');
  const scenePin = document.getElementById('infra');
  const sceneCanvas = scenePin?.querySelector<HTMLElement>('.s3d__canvas');
  const pinRoot = document.documentElement;
  /* Declared locally, not borrowed: each <script> in this file is its own
     module, and REDUCED lives in the hero's. Reaching for it here threw a
     ReferenceError that took this whole module down — card parallax included. */
  const markReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* NOTE: reduced-motion is deliberately NOT part of this guard.
     Pinning is a LAYOUT decision — position:sticky plus a fit scale — not an
     animation. Gating the whole block on it meant anyone with "reduce motion"
     enabled (Windows: Accessibility → Visual effects → Animation effects, and
     battery saver flips it too) lost the pin, the scene fit AND the rising
     wordmark, and the section just scrolled past like a plain block with no
     error anywhere. Only the scroll-LINKED travel below is real motion, and
     only that is skipped. */
  if (pinTrack && wordmark && markText && scenePin && sceneCanvas) {
    let travel = 0;
    let range = 0;

    /* Was 0.72. That was tuned as "below this the scene is too small to be
       worth it", but the cost of failing the check is not a smaller scene —
       it is losing the pin, the sticky and the wordmark outright, with the
       section silently degrading to a plain scrolling block. A slightly
       shrunken scene is far better than no scene, so the floor is low enough
       that only genuinely tiny viewports fall through. */
    const MIN_SCALE = 0.55;
    const BREATHING = 32;     // px of air top and bottom

    /* Make the scene fit rather than asking whether it does. Measured, not
       assumed: the scene's height moves with width and the viewport moves with
       OS display scaling — a 1080p screen at 125% reports ~750 CSS px, so no
       hardcoded breakpoint is right for both. offsetHeight is layout height and
       ignores transforms, so it can be read while already scaled. */
    const gate = () => {
      pinRoot.classList.add('s3dpin-on');
      scenePin.style.setProperty('--s3d-fit', '1');
      const sceneH = sceneCanvas.offsetHeight;
      /* The section keeps its nav-clearance padding now, so the canvas only
         has the viewport MINUS that padding to live in. Reading it rather than
         hardcoding 4.5rem keeps this correct if the clearance is ever retuned. */
      const padTop = parseFloat(getComputedStyle(scenePin).paddingTop) || 0;
      const scale = Math.min(1, (window.innerHeight - padTop - BREATHING) / sceneH);
      const on = scale >= MIN_SCALE;
      pinRoot.classList.toggle('s3dpin-on', on);
      scenePin.style.setProperty('--s3d-fit', String(on ? scale : 1));
      return { sceneH, scale, on };
    };

    /* Size the wordmark to span the viewport. Measured at a reference size and
       scaled by the ratio, because px-of-width per px-of-font-size is a
       property of the typeface — hardcoding it would break the moment the
       family, the tracking, or the string changed. */
    const MARK_SPAN = 0.94;
    const REF = 100;

    const fitWordmark = () => {
      wordmark.style.setProperty('--mark-size', `${REF}px`);
      const refWidth = markText.getBoundingClientRect().width;
      if (!refWidth) return;
      const size = (window.innerWidth * MARK_SPAN) / (refWidth / REF);
      wordmark.style.setProperty('--mark-size', `${Math.round(size)}px`);
    };

    const measure = () => {
      fitWordmark();     // before the travel maths — it sets the mark's height
      range = pinTrack.offsetHeight - window.innerHeight;
      /* Fully below the fold to fully above the top, plus a 56px overshoot so
         the last pixel retires before the section unsticks — landing both on
         the same frame leaves a sliver on screen that reads as a snag. */
      travel = window.innerHeight + wordmark.offsetHeight + 56;
    };

    const update = () => {
      if (range <= 0) return;
      if (markReduced) {
        /* No scroll-linked travel for anyone who asked for less motion — but
           the wordmark still belongs on screen, so it rests in the upper third
           of the pinned scene instead of sweeping through it. */
        wordmark.style.setProperty('--mark-y', `${Math.round(window.innerHeight * 0.3)}px`);
        return;
      }
      const p = Math.min(1, Math.max(0, -pinTrack.getBoundingClientRect().top / range));
      wordmark.style.setProperty('--mark-y', `${window.innerHeight - p * travel}px`);
    };

    const sync = () => { gate(); measure(); update(); };

    sync();
    document.fonts?.ready.then(sync);   // the wordmark's height moves with the font
    /* the travel is the only part that needs per-scroll work */
    if (!markReduced) window.addEventListener('scroll', update, { passive: true });

    let rt = 0;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = window.setTimeout(sync, 150);
    });

    /* Why is the pin off? Previously there was no way to tell — it just did
       nothing. Now the reason is always available. */
    if (import.meta.env.DEV) {
      (window as any).__pinWhy = () => {
        const g = gate();
        return {
          pinned: pinRoot.classList.contains('s3dpin-on'),
          reducedMotion: markReduced,
          sceneHeight: g.sceneH,
          viewportHeight: window.innerHeight,
          fitScale: +g.scale.toFixed(3),
          minScale: MIN_SCALE,
          passesFitCheck: g.on,
          minViewportHeightNeeded: Math.ceil(MIN_SCALE * g.sceneH + BREATHING
            + (parseFloat(getComputedStyle(scenePin).paddingTop) || 0)),
        };
      };
    }

    if (import.meta.env.DEV) {
      (window as any).__s3dmarkUpdate = update;
      (window as any).__s3dmark = () => ({
        pinned: pinRoot.classList.contains('s3dpin-on'),
        sceneH: sceneCanvas.offsetHeight,
        sceneFit: scenePin.style.getPropertyValue('--s3d-fit'),
        viewportH: window.innerHeight,
        range,
        travel,
        progress: Math.min(1, Math.max(0, -pinTrack.getBoundingClientRect().top / range)),
        markTop: Math.round(markText.getBoundingClientRect().top),
        sceneTop: Math.round(scenePin.getBoundingClientRect().top),
      });
    }
  }

  const s3d = document.getElementById('infra');
  if (s3d) {
    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    const mqScene = window.matchMedia('(min-width: 1024px)');   // absolute composition active
    const mqHover = window.matchMedia('(hover: hover) and (pointer: fine)');

    const scene = s3d.querySelector<HTMLElement>('[data-s3d-scene]')!;
    const cards = [...s3d.querySelectorAll<HTMLElement>('[data-s3d-card]')];
    const q = (sel: string) => s3d.querySelector<HTMLElement>(sel);
    const qa = (sel: string) => [...s3d.querySelectorAll<HTMLElement>(sel)];

    /* ── count-up (writes back the exact resting text when done) ── */
    function countUp(el: HTMLElement, dur = 1.1) {
      const target = (el.textContent ?? '').trim();
      const m = target.match(/^(\D*)(\d+(?:\.\d+)?)(\D*)$/);
      if (!m) return;
      const [, pre, numStr, suf] = m;
      const dec = numStr.includes('.') ? numStr.split('.')[1].length : 0;
      const o = { v: 0 };
      gsap.to(o, {
        v: parseFloat(numStr), duration: dur, ease: 'power2.out',
        onUpdate() { el.textContent = pre + o.v.toFixed(dec) + suf; },
        onComplete() { el.textContent = target; },
      });
    }

    /* ── charts (fired the moment their parent card has entered) ── */
    let visDone = false;
    function visChart() {
      if (visDone) { return; } visDone = true;
      const line = q('[data-vis-line]') as unknown as SVGGeometryElement | null;
      if (!line) return;
      const len = line.getTotalLength();
      const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });
      tl.fromTo(line, { strokeDasharray: len, strokeDashoffset: len },
          { strokeDashoffset: 0, duration: 1.25, ease: 'power2.inOut' }, 0)
        .fromTo(q('[data-vis-area]'), { opacity: 0 }, { opacity: 1, duration: 0.8 }, 0.45)
        .fromTo(qa('[data-vis-dot]'), { scale: 0, transformOrigin: 'center' },
          { scale: 1, duration: 0.4, stagger: 0.14, ease: 'back.out(2.5)' }, 0.35)
        .fromTo(q('[data-vis-tip]'), { scale: 0, transformOrigin: 'center' },
          { scale: 1, duration: 0.5, ease: 'back.out(2)' }, 1.15)
        .add(() => countUp(q('[data-vis-count]')!, 1.2), 0.15);
    }
    let metDone = false;
    function metChart() {
      if (metDone) { return; } metDone = true;
      const tl = gsap.timeline();
      tl.fromTo(qa('[data-met-bar]'), { scaleY: 0 },
          { scaleY: 1, duration: 0.8, stagger: 0.13, ease: 'power3.out' }, 0)
        .fromTo(q('[data-met-tip]'), { scale: 0, opacity: 0 },
          { scale: 1, opacity: 1, duration: 0.5, ease: 'back.out(2)' }, 0.75)
        .add(() => countUp(q('[data-met-count]')!, 1.1), 0.1);
    }
    const chartFor = (card: HTMLElement) => {
      if (card.classList.contains('s3dcard--vis')) return visChart;
      if (card.classList.contains('s3dcard--met')) return metChart;
      return null;
    };

    if (!mqReduce.matches) {
      /* ── scroll entrance: cards assemble from different depths ── */
      const copyEls = qa('[data-s3d-copy]');
      const trust = q('[data-s3d-trust]');
      gsap.set(copyEls, { opacity: 0, y: 24 });
      if (trust) gsap.set(trust, { opacity: 0, y: 18 });

      const copyIO = new IntersectionObserver(([entry]) => {
        if (!entry.isIntersecting) return;
        copyIO.disconnect();
        gsap.to(copyEls, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', stagger: 0.09 });
      }, { threshold: 0.2 });
      copyIO.observe(s3d);

      // GSAP owns the card transform entirely: the -50/-50 centering must live
      // in xPercent/yPercent (not CSS `translate:`), or the entrance y-tween
      // would fold the CSS translate in and erase the vertical centering.
      const applyCentering = () => {
        gsap.set(cards, mqScene.matches
          ? { xPercent: -50, yPercent: -50 }
          : { xPercent: 0, yPercent: 0 });
      };
      applyCentering();

      cards.forEach((card, i) => {
        const depth = parseFloat(card.dataset.depth ?? '0.5');
        gsap.set(card, { opacity: 0, y: 30 + depth * 44, filter: 'blur(7px)' });
        const io = new IntersectionObserver(([entry]) => {
          if (!entry.isIntersecting) return;
          io.disconnect();
          gsap.to(card, {
            opacity: 1, y: 0, filter: 'blur(0px)',
            duration: 0.9, delay: i * 0.07,
            ease: 'power3.out', clearProps: 'filter',
            onComplete: () => chartFor(card)?.(),
          });
        }, { threshold: 0.35 });
        io.observe(card);
      });

      if (trust) {
        const tio = new IntersectionObserver(([entry]) => {
          if (!entry.isIntersecting) return;
          tio.disconnect();
          gsap.to(trust, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out', delay: 0.35 });
        }, { threshold: 0.4 });
        tio.observe(trust);
      }

      /* ── idle float: selected cards drift on their own clocks ── */
      const floats: gsap.core.Tween[] = [];
      function startFloats() {
        qa('[data-float]').forEach((card, i) => {
          const inner = card.querySelector<HTMLElement>('.s3dcard__float')!;
          floats.push(gsap.to(inner, {
            y: 2.5 + (i % 3) * 1.3,
            rotation: (i % 2 ? 1 : -1) * 0.28,
            duration: 3.6 + (i % 4) * 0.7,
            delay: i * 0.45,
            ease: 'sine.inOut', yoyo: true, repeat: -1,
          }));
        });
      }
      function stopFloats() {
        floats.forEach((t) => t.kill());
        floats.length = 0;
        qa('.s3dcard__float').forEach((el) => gsap.set(el, { clearProps: 'transform' }));
      }

      /* ── mouse parallax: depth-graded drift + a whisper of scene tilt ── */
      let parallaxOn = false;
      let quickies: Array<{ x: (v: number) => void; y: (v: number) => void }> = [];
      let sceneRX: ((v: number) => void) | null = null;
      let sceneRY: ((v: number) => void) | null = null;

      function onMove(e: PointerEvent) {
        const r = s3d!.getBoundingClientRect();
        const nx = ((e.clientX - r.left) / r.width - 0.5) * 2;   // −1 … 1
        const ny = ((e.clientY - r.top) / r.height - 0.5) * 2;
        sceneRY?.(nx * 1.5);
        sceneRX?.(-ny * 1.1);
        quickies.forEach((qt, i) => {
          const depth = parseFloat(cards[i].dataset.depth ?? '0.5');
          qt.x(nx * 15 * depth);
          qt.y(ny * 11 * depth);
        });
      }
      function startParallax() {
        if (parallaxOn) return;
        parallaxOn = true;
        quickies = cards.map((card) => {
          const par = card.querySelector<HTMLElement>('.s3dcard__par')!;
          return {
            x: gsap.quickTo(par, 'x', { duration: 0.9, ease: 'power3.out' }),
            y: gsap.quickTo(par, 'y', { duration: 0.9, ease: 'power3.out' }),
          };
        });
        sceneRX = gsap.quickTo(scene, 'rotationX', { duration: 1.1, ease: 'power3.out' });
        sceneRY = gsap.quickTo(scene, 'rotationY', { duration: 1.1, ease: 'power3.out' });
        s3d!.addEventListener('pointermove', onMove);
      }
      function stopParallax() {
        if (!parallaxOn) return;
        parallaxOn = false;
        s3d!.removeEventListener('pointermove', onMove);
        quickies = [];
        sceneRX = sceneRY = null;
        gsap.to(scene, { rotationX: 0, rotationY: 0, duration: 0.6, overwrite: 'auto' });
        cards.forEach((card) => gsap.to(card.querySelector('.s3dcard__par'), { x: 0, y: 0, duration: 0.6, overwrite: 'auto' }));
      }

      /* ── hover: the card physically approaches the viewer ── */
      cards.forEach((card) => {
        const body = card.querySelector<HTMLElement>('[data-s3d-body]')!;
        const hs = parseFloat(card.dataset.hs ?? '1.02');
        card.addEventListener('pointerenter', (e) => {
          if (!mqHover.matches || (e as PointerEvent).pointerType === 'touch') return;
          const baseRot = parseFloat(getComputedStyle(body).rotate) || 0;
          card.classList.add('is-hover');
          gsap.to(body, {
            y: -7, scale: hs, rotation: -baseRot * 0.45,
            duration: 0.5, ease: 'power3.out', overwrite: 'auto',
          });
        });
        card.addEventListener('pointerleave', () => {
          card.classList.remove('is-hover');
          gsap.to(body, {
            y: 0, scale: 1, rotation: 0,
            duration: 1.05, ease: 'elastic.out(1, 0.58)', overwrite: 'auto',
          });
        });
      });

      /* scene-wide effects only make sense in the absolute composition */
      function applyMode() {
        applyCentering();
        if (mqScene.matches && mqHover.matches) startParallax(); else stopParallax();
        stopFloats();
        if (mqScene.matches) startFloats();
      }
      applyMode();
      mqScene.addEventListener('change', applyMode);
    } else {
      /* reduced motion: the resting CSS is the finished design — nothing to do */
    }

    // dev-only hook for automated verification
    if (import.meta.env.DEV) {
      (window as any).__s3d = { gsap, cards, visChart, metChart };
    }
  }
</script>

<!-- ══════════ SECTION 2 problem deck ══════════ -->
<script>
  import { gsap } from 'gsap';
  import { CustomEase } from 'gsap/CustomEase';
  gsap.registerPlugin(CustomEase);

  const s2 = document.getElementById('section2');
  if (s2) {
    const deck = s2.querySelector<HTMLElement>('[data-deck]')!;
    const stage = s2.querySelector<HTMLElement>('[data-deck-stage]')!;
    const cards = [...s2.querySelectorAll<HTMLElement>('[data-dcard]')];
    const N = cards.length;
    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    CustomEase.create('deckEase', '0.22, 1, 0.36, 1');

    let active = 2;                        // Outbound starts centered

    const metrics = () => {
      const w = cards[0].offsetWidth;
      const gap = Math.min(24, Math.round(w * 0.08));
      return { step: w + gap };
    };
    const slotOf = (i: number) => (((i - active + 2) % N) + N) % N;
    // blur grades by distance from front: slot0 max, slot4 heavy, slots1/3 light, slot2 sharp
    const slotProps = (s: number) =>
      s === 2 ? { scale: 1.04, opacity: 1, rotationY: 0, zIndex: 3, filter: 'blur(0px)' }
      : s === 1 ? { scale: 0.99, opacity: 0.9, rotationY: 5, zIndex: 2, filter: 'blur(2px)' }
      : s === 3 ? { scale: 0.99, opacity: 0.9, rotationY: -5, zIndex: 2, filter: 'blur(2px)' }
      : s === 0 ? { scale: 0.93, opacity: 0.4, rotationY: 12, zIndex: 1, filter: 'blur(6.5px)' }
      :           { scale: 0.93, opacity: 0.5, rotationY: -12, zIndex: 1, filter: 'blur(4.5px)' };

    // editorial cards sliding across a table — no 3D cylinder
    function layout(animate: boolean, dur = 0.7) {
      const { step } = metrics();
      cards.forEach((c, i) => {
        const s = slotOf(i);
        const p = slotProps(s);
        const x = (s - 2) * step;
        c.classList.toggle('is-active', s === 2);
        if (!animate || mqReduce.matches) {
          gsap.set(c, { xPercent: -50, x, y: 0, ...p });
          return;
        }
        // a card wrapping across the whole deck fades out/in instead of flying over
        const wrap = Math.abs(x - Number(gsap.getProperty(c, 'x'))) > step * 2.5;
        if (wrap) {
          gsap.timeline()
            .to(c, { opacity: 0, duration: 0.16, ease: 'power1.in' })
            .set(c, { x, rotationY: p.rotationY, scale: p.scale, zIndex: p.zIndex, filter: p.filter })
            .to(c, { opacity: p.opacity, duration: 0.34, ease: 'power1.out' });
        } else {
          gsap.to(c, { x, ...p, duration: dur, ease: 'deckEase', overwrite: 'auto' });
        }
      });
    }

    /* — slow living deck: auto-glide every few seconds, paused on hover/off-screen — */
    let autoTimer: gsap.core.Tween | null = null;
    let deckInView = false, hovering = false, modalOpen = false;
    const queue = () => {
      autoTimer?.kill();
      /* no auto-glide on touch — the deck stays fully swipeable/tappable; we
         just don't run the periodic blur transition unprompted on mobile */
      if (mqReduce.matches || window.matchMedia('(hover: none) and (pointer: coarse)').matches) return;
      autoTimer = gsap.delayedCall(5.5, () => {
        if (deckInView && !hovering && !modalOpen) go(1, 1.2);   // long, slow glide
        queue();
      });
    };
    deck.addEventListener('pointerenter', () => { hovering = true; });
    deck.addEventListener('pointerleave', () => { hovering = false; });
    new IntersectionObserver(
      ([entry]) => { deckInView = entry.isIntersecting; },
      { threshold: 0.35 },
    ).observe(s2);

    function go(delta: number, dur = 0.7) {
      active = ((active + delta) % N + N) % N;
      layout(true, dur);
      if (!mqReduce.matches) { animateViz(cards[active], true); pulseCard(cards[active]); }  // focal card comes alive
      queue();               // any move (auto or manual) resets the auto clock
    }
    function centerTo(i: number) {
      active = i;
      layout(true, 0.55);
      if (!mqReduce.matches) { animateViz(cards[active], true); pulseCard(cards[active]); }
      queue();
    }
    // every card animates when it reaches the front — even the text-only ones
    function pulseCard(card: HTMLElement) {
      if (mqReduce.matches) return;
      const icon = card.querySelector<HTMLElement>('.dcard__icon');
      if (icon) gsap.fromTo(icon, { scale: 0.7, rotate: -8, opacity: 0.35 },
        { scale: 1, rotate: 0, opacity: 1, duration: 0.55, ease: 'back.out(2)' });
      const desc = card.querySelector<HTMLElement>('.dcard__desc');
      if (desc) gsap.fromTo(desc, { opacity: 0, y: 8 },
        { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out', delay: 0.08 });
    }
    queue();

    deck.classList.add('deck--js');
    layout(false);
    new ResizeObserver(() => layout(false)).observe(stage);

    s2.querySelector('[data-deck-prev]')?.addEventListener('click', () => go(-1));
    s2.querySelector('[data-deck-next]')?.addEventListener('click', () => go(1));

    // keyboard
    deck.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); go(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); go(1); }
    });

    // horizontal trackpad / wheel over the deck steps through the cards
    let wheelAcc = 0, wheelLock = false;
    deck.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return;   // vertical intent → let the page scroll
      e.preventDefault();
      if (wheelLock) return;
      wheelAcc += e.deltaX;
      if (Math.abs(wheelAcc) > 42) {
        go(wheelAcc > 0 ? 1 : -1);
        wheelAcc = 0; wheelLock = true;
        gsap.delayedCall(0.45, () => { wheelLock = false; });
      }
    }, { passive: false });

    // drag / swipe: one step per gesture; click a side card to centre it
    let downX: number | null = null;
    let moved = false;
    stage.addEventListener('pointerdown', (e) => { downX = e.clientX; moved = false; });
    window.addEventListener('pointermove', (e) => {
      if (downX !== null && Math.abs(e.clientX - downX) > 6) moved = true;
    }, { passive: true });
    window.addEventListener('pointerup', (e) => {
      if (downX === null) return;
      const dx = e.clientX - downX;
      downX = null;
      if (Math.abs(dx) > 40) go(dx < 0 ? 1 : -1);
    });
    cards.forEach((c) => {
      c.addEventListener('click', () => {
        if (moved) return;
        const i = cards.indexOf(c);
        if (slotOf(i) === 2) openModal(c);   // only the sharp front card opens its detail
        else centerTo(i);                     // a blurred side card just steps to the front
      });
      c.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter' && e.key !== ' ') return;
        e.preventDefault();
        const i = cards.indexOf(c);
        if (slotOf(i) === 2) openModal(c); else centerTo(i);
      });
    });

    /* ── problem detail modal (click a card → blurred popup) ── */
    const modal = s2.querySelector<HTMLElement>('[data-p2modal]')!;
    const pmCat = modal.querySelector<HTMLElement>('[data-pm-cat]')!;
    const pmTitle = modal.querySelector<HTMLElement>('[data-pm-title]')!;
    const pmBody = modal.querySelector<HTMLElement>('[data-pm-body]')!;
    const pmCost = modal.querySelector<HTMLElement>('[data-pm-cost]')!;
    const pmViz = modal.querySelector<HTMLElement>('[data-pm-viz]')!;
    const pmClose = modal.querySelector<HTMLElement>('.p2modal__close')!;
    let lastFocus: HTMLElement | null = null;

    const DETAILS: Record<string, { cat: string; title: string; body: string; cost: string; stat?: [string, string] }> = {
      search: {
        cat: 'Search', title: 'You rank #1. The click never comes.',
        body: 'Ranking stopped being the finish line. When an AI Overview sits above your result, it answers the question outright and the click never happens \u2014 roughly halving organic click-through. Most searches now end without anyone visiting a website at all. You can win the ranking and still lose the visit.',
        cost: 'The page you optimised is no longer the page they read.',
        stat: ['8%', 'click-through with an AI Overview'],
      },
      aisearch: {
        cat: 'AI Search', title: 'Buyers now ask ChatGPT \u2014 are you in the answer?',
        body: 'A growing share of your buying committee starts research inside an LLM. If the model doesn\u2019t name and cite you, you never make the shortlist \u2014 and you never see the deal you lost. There is no ad unit inside an AI answer: presence there is earned or it is absent. Classic SEO doesn\u2019t move this; entity and citation work does.',
        cost: '34% share of answer vs 66% for competitors.',
      },
      outbound: {
        cat: 'Outbound', title: 'You emailed 10,000 people. 120 replied.',
        body: 'At any moment about 95% of your market is not buying anything. Send to all of them and a 1.2% reply rate isn\u2019t a copywriting failure \u2014 it\u2019s close to the mathematical ceiling. AI made it free for everyone to send more, so buyers now dismiss outreach by category before they read a word of it. Volume was never the strategy; it was a substitute for knowing who was ready.',
        cost: '1.2% reply rate \u00b7 95% of the list was never buying.',
      },
      pipeline: {
        cat: 'Pipeline', title: 'The quarter always ends with \u201cit slipped.\u201d',
        body: 'When pipeline isn\u2019t built on signal and cadence, forecasting is hope. Deals \u201cslip\u201d because nothing was engineered to move them on time \u2014 or to flag them the moment they stall. By the time the number misses, it\u2019s already too late to fix.',
        cost: 'Pipeline coverage down 28% quarter over quarter.',
      },
      stall: {
        cat: 'Deals', title: 'Deals don\u2019t die. They go quiet.',
        body: 'Your most expensive competitor isn\u2019t another vendor \u2014 it\u2019s no decision. Win rates fell from 29% to 19% in a single year while cycles stretched past six months. A median of thirteen stakeholders now sit in the room, security review alone eats weeks, and nobody on your side owns the moment a deal goes silent.',
        cost: '89% of sellers report deals stalling into no-decision.',
      },
      trust: {
        cat: 'Trust', title: 'Buyers trust reviews. Your content ranks last.',
        body: 'This is the uncomfortable one: vendor marketing collateral ranks dead last among the resources buyers consult, while 74% read customer reviews. More content doesn\u2019t fix it, because the least-trusted asset in the deal is the one you wrote about yourself. Evidence somebody else can verify is the only thing that moves a stalled buyer.',
        cost: 'The asset you control is the one they believe least.',
        stat: ['Dead last', 'where vendor content ranks'],
      },
      expansion: {
        cat: 'Expansion', title: 'You\u2019re buying growth at twice the price.',
        body: 'Expansion revenue costs roughly half what new-customer acquisition does, and above $50M ARR it is the majority of new ARR. Yet almost every GTM system is pointed at logos you don\u2019t have instead of accounts you already won. The cheaper half of your growth is the half nobody is running.',
        cost: 'Roughly 2\u00d7 the cost, for the harder revenue.',
        stat: ['2\u00d7', 'the cost of expansion revenue'],
      },
      pricing: {
        cat: 'Pricing', title: 'Your pricing page is a guess nobody tested.',
        body: '75% of B2B software companies changed pricing or packaging in the past year. Hybrid models jumped from 25% to 37% in twelve months and AI credits are growing fast. Almost none of it is tested against real conversion, and almost nobody has a communications plan for the change \u2014 so the number on the page stays a hypothesis.',
        cost: 'Repricing without evidence is repricing on vibes.',
        stat: ['75%', 'repriced in the last year'],
      },
      reporting: {
        cat: 'Reporting', title: 'Six tools. Zero answers.',
        body: 'Every problem got its own point solution, and now the stack contradicts itself. Data lives in six places, none of them agree, and answering a simple question means exporting spreadsheets and reconciling by hand. More tools didn\u2019t create clarity \u2014 they created reconciliation work.',
        cost: 'The fix isn\u2019t another subscription. It\u2019s architecture.',
        stat: ['12+', 'disconnected tools'],
      },
    };

    function openModal(card: HTMLElement) {
      const d = DETAILS[card.dataset.key!];
      if (!d) return;
      pmCat.textContent = d.cat;
      pmTitle.textContent = d.title;
      pmBody.textContent = d.body;
      pmCost.textContent = d.cost;
      pmViz.innerHTML = '';
      const mod = card.querySelector<HTMLElement>('.dcard__mod');
      if (mod) {
        const clone = mod.cloneNode(true) as HTMLElement;
        clone.classList.add('p2modal__mod');
        pmViz.appendChild(clone);
        requestAnimationFrame(() => animateViz(clone, true));
      } else if (d.stat) {
        const box = document.createElement('div');
        box.className = 'p2stat';
        box.innerHTML = `<strong class="p2stat__num" data-count>${d.stat[0]}</strong><span class="p2stat__label">${d.stat[1]}</span>`;
        pmViz.appendChild(box);
        requestAnimationFrame(() => animateViz(box, true));
      }
      lastFocus = card;
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      modalOpen = true;
      pmClose.focus();
    }
    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      modalOpen = false;
      lastFocus?.focus();
    }
    modal.querySelectorAll('[data-p2modal-close]').forEach((el) =>
      el.addEventListener('click', closeModal));
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });

    /* ── data-viz animation: count-ups + chart draws (function declarations, hoisted) ── */
    function countUp(el: HTMLElement, dur: number) {
      const target = (el.dataset.target ?? el.textContent ?? '').trim();
      el.dataset.target = target;
      const m = target.match(/^(\D*)(\d+(?:\.\d+)?)(\D*)$/);
      if (!m) return;
      const pre = m[1], numStr = m[2], suf = m[3];
      const dec = numStr.includes('.') ? numStr.split('.')[1].length : 0;
      const to = parseFloat(numStr);
      const o = { v: 0 };
      gsap.to(o, {
        v: to, duration: dur, ease: 'power2.out',
        onUpdate() { el.textContent = pre + o.v.toFixed(dec) + suf; },
      });
    }
    function animateViz(scope: HTMLElement, animate: boolean) {
      if (!scope) return;
      const nums = scope.querySelectorAll<HTMLElement>('[data-count]');
      nums.forEach((el) => { el.dataset.target = (el.dataset.target ?? el.textContent ?? '').trim(); });
      if (!animate || mqReduce.matches) return;
      nums.forEach((el) => countUp(el, 0.9));
      scope.querySelectorAll<SVGGeometryElement>('[data-draw]').forEach((pl) => {
        const len = pl.getTotalLength();
        gsap.fromTo(pl, { strokeDasharray: len, strokeDashoffset: len },
          { strokeDashoffset: 0, duration: 1.1, ease: 'power2.out' });
      });
      scope.querySelectorAll<HTMLElement>('[data-bar]').forEach((b) =>
        gsap.fromTo(b, { scaleX: 0 }, { scaleX: 1, duration: 1, ease: 'power2.out', transformOrigin: 'left center' }));
      scope.querySelectorAll<SVGGeometryElement>('[data-arc]').forEach((a) =>
        gsap.fromTo(a, { strokeDashoffset: 60 }, { strokeDashoffset: 0, duration: 1.1, ease: 'power2.out' }));
    }
    cards.forEach((c) => animateViz(c, false));   // stash count-up targets once, up front

    // entrances
    if (!mqReduce.matches) {
      const heads = [...s2.querySelectorAll<HTMLElement>('[data-p2-in]')];
      gsap.set(heads, { opacity: 0, y: 20 });
      gsap.set(cards, { opacity: 0, y: 34 });
      const io = new IntersectionObserver(([entry]) => {
        if (!entry.isIntersecting) return;
        io.disconnect();
        gsap.to(heads, { opacity: 1, y: 0, duration: 0.55, ease: 'power2.out', stagger: 0.09 });
        cards.forEach((c, i) => {
          const p = slotProps(slotOf(i));
          gsap.to(c, {
            opacity: p.opacity, y: 0, duration: 0.65, ease: 'power2.out',
            delay: 0.2 + slotOf(i) * 0.07,
          });
        });
        gsap.delayedCall(0.9, () => { animateViz(cards[active], true); pulseCard(cards[active]); });   // the focal card comes alive
        // gentle perpetual 3D sway once the cards have settled (y + rotationX only —
        // never rotationY/x/scale, which belong to the slot layout)
        gsap.delayedCall(1.4, () => cards.forEach((c, i) => {
          gsap.to(c, {
            y: 5, rotationX: 0.9,
            duration: 4.5 + i * 0.8, delay: i * 0.35,
            ease: 'sine.inOut', yoyo: true, repeat: -1,
          });
        }));
      }, { threshold: 0.25 });
      io.observe(s2);
    }
  }
</script>

