<!-- ══════════ SECTION 2B — where growth actually breaks ══════════
     Editorial column grid: four measures divided by hairlines, one selected
     at a time, its breakdown opening beneath the row.

     Loud without dark. The previous dark-slab version got its volume from
     inversion; this gets it from scale and structure — display-size heading,
     oversized numerals, 2px rules against 1px dividers, and a tinted active
     column. Ivory ground throughout, so section 2 → 2B → the vapour bridge
     stay one continuous environment.

     Tabs, not accordion: there is a single panel region and four controls
     selecting into it, which is what the tab pattern describes. -->
<section class="rl" id="section2b" aria-labelledby="rl-title">
  <div class="rl__wrap">

    <div class="rl__head">
      <h2 class="rl__title" id="rl-title" data-rl-in>Where B2B SaaS<br />and AI startups <em>lose the revenue.</em></h2>
      <p class="rl__lede" data-rl-in>Revenue doesn&rsquo;t disappear. It leaks&mdash;quietly, at every stage of the buyer journey.</p>
    </div>

    <!-- ── the horizontal revenue journey ── -->
    <div class="rl__journey">
      <p class="rl__oppo mono" data-rl-in><b>$1M revenue opportunity</b><i>illustrative</i></p>
      <div class="rl__rail" role="tablist" aria-label="Four stages where revenue leaks">
        <span class="rl__line" aria-hidden="true"></span>
        {STAGES.map((s, i) => {
          const disc = ({
            visibility: '<circle cx="11" cy="11" r="6.4" stroke="currentColor" stroke-width="1.6"/><path d="M20 20l-4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>',
            signals: '<circle cx="12" cy="12" r="2.3" fill="currentColor"/><path d="M7.6 16.4a6 6 0 0 1 0-8.8M16.4 7.6a6 6 0 0 1 0 8.8M5 19a9.5 9.5 0 0 1 0-14M19 5a9.5 9.5 0 0 1 0 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
            proof: '<path d="M12 3l7 3v5c0 4.4-3 7.6-7 9-4-1.4-7-4.6-7-9V6z" stroke="currentColor" stroke-width="1.5"/><path d="M9 12l2 2 4-4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
            pricing: '<path d="M4 15l5-5 3 3 8-8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 5h5v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
          })[s.key];
          return (
            <button
              class="rl__stage"
              role="tab"
              id={`rl-tab-${i}`}
              aria-controls={`rl-panel-${i}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              tabindex={i === 0 ? '0' : '-1'}
              data-rl-tab
              data-rl-in
              style={`--acc:${s.acc}; --acc-soft:${s.soft}`}
            >
              <span class="rl__badge mono">{s.n}</span>
              <span class="rl__disc" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" set:html={disc} /></span>
              <span class="rl__slabel mono">{s.label}</span>
              <span class="rl__shead">{s.head}</span>
              <span class="rl__leak">
                <span class="rl__leakval">{s.leak}</span>
                <span class="rl__leaknote">{s.leakNote}</span>
              </span>
            </button>
          );
        })}
      </div>
    </div>

    <!-- ── the large dynamic panel ── -->
    <div class="rl__panels">

      <!-- 01 · VISIBILITY -->
      <div class="rl__panel" role="tabpanel" id="rl-panel-0" aria-labelledby="rl-tab-0" data-rl-panel style={`--acc:${STAGES[0].acc}; --acc-soft:${STAGES[0].soft}`}>
        <div class="rl__pin">
          <div class="rl__phead">
            <div>
              <p class="rl__pkicker mono">{STAGES[0].kicker}</p>
              <h3 class="rl__ph">{STAGES[0].ph}</h3>
              <p class="rl__psub">{STAGES[0].psub}</p>
            </div>
            <a class="rl__cta" href={STAGES[0].href}>{STAGES[0].cta}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          </div>

          <div class="rl__plats" role="group" aria-label="AI platforms monitored — logos are trademarks of their owners; no endorsement implied">
            <span class="mono">Monitored</span>
            <span class="rl__plat" title="OpenAI ChatGPT"><img src="/logos/ai/openai.svg" alt="OpenAI ChatGPT" width="15" height="15" loading="lazy" decoding="async" /></span>
            <span class="rl__plat" title="Google Gemini"><img src="/logos/ai/gemini.svg" alt="Google Gemini" width="15" height="15" loading="lazy" decoding="async" /></span>
            <span class="rl__plat" title="Perplexity"><img src="/logos/ai/perplexity.svg" alt="Perplexity" width="15" height="15" loading="lazy" decoding="async" /></span>
            <span class="rl__plat" title="Microsoft Copilot"><img src="/logos/ai/copilot.svg" alt="Microsoft Copilot" width="15" height="15" loading="lazy" decoding="async" /></span>
            <span class="rl__plat" title="Claude by Anthropic"><img src="/logos/ai/claude.svg" alt="Claude by Anthropic" width="15" height="15" loading="lazy" decoding="async" /></span>
          </div>

          <div class="rl__flow">
            <div class="rl__col">
              <span class="rl__step mono">Buyer asks AI</span>
              <div class="rl__card rlv__q">
                <p class="rlv__qbody"><span data-rl-type>What are the best security compliance platforms for B2B SaaS companies?</span><span class="rlv__caret" data-rl-caret></span></p>
                <div class="rlv__qbar">
                  <span class="rlv__ava" aria-hidden="true"><svg width="12" height="12" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.7"/><path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></span>
                  <span class="rlv__send mono">Sent<span class="rlv__sendbtn" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 24 24" fill="none"><path d="M4 12l16-7-7 16-2.5-6.5z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg></span></span>
                </div>
              </div>
            </div>

            <div class="rl__col">
              <span class="rl__step mono">AI answer &middot; 5.4 vendors</span>
              <div class="rl__card">
                <div class="rlv__ansbar"><b>AI Overview</b><svg class="rlv__spark" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3l1.6 5.2L19 10l-5.4 1.7L12 17l-1.6-5.3L5 10l5.4-1.8z"/></svg></div>
                <div class="rlv__rank" data-rl-step><span class="rlv__rk">1</span><span class="rlv__co" aria-hidden="true">A</span><span class="rlv__cn">Competitor A</span></div>
                <div class="rlv__rank" data-rl-step><span class="rlv__rk">2</span><span class="rlv__co" aria-hidden="true">B</span><span class="rlv__cn">Competitor B</span></div>
                <div class="rlv__rank" data-rl-step><span class="rlv__rk">3</span><span class="rlv__co" aria-hidden="true">C</span><span class="rlv__cn">Competitor C</span></div>
                <div class="rlv__rank rlv__rank--me" data-rl-step><span class="rlv__rk">&ndash;</span><span class="rlv__co" aria-hidden="true"><svg width="11" height="11" viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="4" stroke="currentColor" stroke-width="1.7"/></svg></span><span class="rlv__cn">Your Brand</span><span class="rlv__nf">Not found</span></div>
              </div>
            </div>

            <div class="rl__col">
              <span class="rl__step mono">What you&rsquo;re seeing</span>
              <ul class="rlv__see">
                <li data-rl-step><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M8.4 12l2.3 2.3L15.6 9.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Competitors are repeatedly recommended.</span></li>
                <li data-rl-step><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M8.4 12l2.3 2.3L15.6 9.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Your content exists, but isn&rsquo;t cited.</span></li>
                <li data-rl-step><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M8.4 12l2.3 2.3L15.6 9.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Buyers arrive with a pre-built shortlist.</span></li>
              </ul>
            </div>

            <div class="rl__col">
              <span class="rl__step mono">Without / with visibility</span>
              <div class="rl__card rlv__cmp" data-rl-step>
                <span class="rlv__cmplab mono">Without visibility</span>
                <div class="rlv__chips">
                  <span class="rlv__chip rlv__chip--ai">AI Answer</span><span class="rlv__arrowc">&rarr;</span>
                  <span class="rlv__chip">Comp A</span><span class="rlv__arrowc">&rarr;</span>
                  <span class="rlv__chip">Comp B</span><span class="rlv__arrowc">&rarr;</span>
                  <span class="rlv__chip">Comp C</span>
                </div>
              </div>
              <div class="rl__card rlv__cmp" data-rl-step>
                <span class="rlv__cmplab mono">With visibility</span>
                <div class="rlv__chips">
                  <span class="rlv__chip rlv__chip--ai">AI Answer</span><span class="rlv__arrowc">&rarr;</span>
                  <span class="rlv__chip rlv__chip--me">Your Brand &uarr;</span><span class="rlv__arrowc">&rarr;</span>
                  <span class="rlv__chip">Comp A</span><span class="rlv__arrowc">&rarr;</span>
                  <span class="rlv__chip">Comp B</span>
                </div>
              </div>
            </div>
